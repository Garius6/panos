импорт "коллекции" как кол

функ старт() -> Булево
	пер числа = массив(5, 3, 8, 1, 9, 2)
	пер большие = кол.отфильтровать(числа, функ(x: Число) -> Булево x > 4 конец)
	пер удвоенные = кол.отобразить(числа, функ(x: Число) -> Число x * 2 конец)
	пер сумма = кол.свернуть(числа, 0, функ(накопитель: Число, x: Число) -> Число накопитель + x конец)
	пер отсортированные = кол.отсортировать(числа, функ(а: Число, б: Число) -> Булево а < б конец)

	большие.длина() == 3 и большие[0] == 5 и большие[1] == 8 и большие[2] == 9 и удвоенные[0] == 10 и удвоенные[5] == 4 и сумма == 28 и отсортированные[0] == 1 и отсортированные[5] == 9
конец

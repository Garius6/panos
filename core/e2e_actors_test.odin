#+build !js
package core

import "core:testing"

// Стадия 24 (actor model): дословный ROADMAP-пример — запусти счётчик(0)
// возвращает Процесс(Сообщение), отправить кладёт сообщения в mailbox,
// старт() (процесс #0) завершается СРАЗУ по возврату, НЕ дожидаясь
// осиротевший счётчик (который навсегда остаётся приостановлен на
// получить()) — Go-`main()`-style завершение программы.
@(test)
test_actor_spawn_send_start_exits_without_waiting_for_child :: proc(t: ^testing.T) {
	result, ok := run_code(`
		тип Сообщение = перечисление
			Увеличить
		конец

		функ счётчик(состояние: Число) -> Пусто
			выбор получить()
				Сообщение.Увеличить -> счётчик(состояние + 1)
			конец
		конец

		функ старт() -> Число
			пер proc: Процесс(Сообщение) = запусти счётчик(0)
			отправить(proc, Сообщение.Увеличить)
			отправить(proc, Сообщение.Увеличить)
			42
		конец
	`)
	testing.expectf(t, ok, "[actor: spawn+send] стек пуст")
	n, is_num := result.(f64)
	testing.expectf(t, is_num && n == 42, "[actor: spawn+send] ожидалось 42, получено %v", result)
}

// получить() возвращает InferVar (T неизвестен на месте вызова) —
// infer_match_expr должен связать его с enum'ом ЧЕРЕЗ квалифицированный
// паттерн (Тип.Вариант), а не через уже известный subject_type (которого
// тут нет). Проверяет и T-инференцию для запусти-спавненной функции
// (объявлена ПОСЛЕ места запусти — ensure_body_checked), и себя() —
// хэндл текущего процесса, единственный способ получить ответ обратно
// (полный цикл: спавн → отправить(..., себя()) → suspend на получить() →
// удалённый отправить → resume → значение).
@(test)
test_actor_self_handle_reply_round_trip :: proc(t: ^testing.T) {
	result, ok := run_code(`
		тип Сообщение = перечисление
			Прочитать(Процесс(Число))
		конец

		функ старт() -> Число
			пер proc: Процесс(Сообщение) = запусти эхо()
			отправить(proc, Сообщение.Прочитать(себя()))
			получить()
		конец

		функ эхо() -> Пусто
			выбор получить()
				Сообщение.Прочитать(куда) -> отправить(куда, 77)
			конец
		конец
	`)
	testing.expectf(t, ok, "[actor: self-handle reply] стек пуст")
	n, is_num := result.(f64)
	testing.expectf(t, is_num && n == 77, "[actor: self-handle reply] ожидалось 77, получено %v", result)
}

// Copy-on-send (без реализация Копируемое): mailbox получает НЕЗАВИСИМУЮ
// копию, сделанную В МОМЕНТ отправить() (message_deep_copy, vm.odin), а
// не ссылку — мутация структуры-отправителя ПОСЛЕ отправить() не должна
// быть видна получателю. Тест различает эти два случая по значению:
// сломанная (by-reference) отправка вернула бы 999 (мутация видна),
// корректная reflective-copy — 1 (значение на момент отправки).
@(test)
test_actor_copy_on_send_isolates_sender_mutation :: proc(t: ^testing.T) {
	result, ok := run_code(`
		тип Точка = структура
			x: Число
		конец

		тип Ответ = перечисление
			Значение(Число)
		конец

		тип Сообщение = перечисление
			Проверь(Точка, Процесс(Ответ))
		конец

		функ хранитель() -> Пусто
			выбор получить()
				Сообщение.Проверь(точка, куда) -> отправить(куда, Ответ.Значение(точка.x))
			конец
		конец

		функ старт() -> Число
			пер точка = Точка(1)
			пер proc: Процесс(Сообщение) = запусти хранитель()
			отправить(proc, Сообщение.Проверь(точка, себя()))
			точка.x = 999
			выбор получить()
				Ответ.Значение(v) -> v
			конец
		конец
	`)
	testing.expectf(t, ok, "[actor: copy-on-send изоляция] стек пуст")
	n, is_num := result.(f64)
	testing.expectf(t, is_num && n == 1, "[actor: copy-on-send изоляция] ожидалось 1 (копия на момент отправки), получено %v", result)
}

// Копируемое-override: компилятор вставляет явный .клонировать() ПЕРЕД
// "отправить" (Call_Kind.Send_Copy, компилируется в внутреннее имя
// "отправить_без_копии" — НЕ настоящий "отправить", иначе рантайм
// reflective copy исказил бы намеренно НЕ скопированные пользователем
// поля). Проверяет только что путь компилируется/исполняется без ошибок
// (независимость уже покрыта reflective-веткой выше — Копируемое отдаёт
// копирование пользователю, гарантия та же, что у обычного .клонировать()
// вне actor-контекста, см. test_copyable_clone_gives_independent_copy).
@(test)
test_actor_copy_on_send_uses_explicit_copyable_override :: proc(t: ^testing.T) {
	result, ok := run_code(`
		тип Точка = структура
			x: Число
		конец

		реализация Копируемое для Точка
			функ клонировать(это: Точка) -> Точка
				Точка(это.x)
			конец
		конец

		тип Сообщение = перечисление
			Данные(Точка)
		конец

		функ хранитель() -> Пусто
			выбор получить()
				Сообщение.Данные(точка) -> хранитель()
			конец
		конец

		функ старт() -> Число
			пер точка = Точка(1)
			пер proc: Процесс(Сообщение) = запусти хранитель()
			отправить(proc, Сообщение.Данные(точка))
			42
		конец
	`)
	testing.expectf(t, ok, "[actor: Копируемое-override] стек пуст")
	n, is_num := result.(f64)
	testing.expectf(t, is_num && n == 42, "[actor: Копируемое-override] ожидалось 42, получено %v", result)
}

// Отправка мёртвому процессу — тихий no-op (Erlang-поведение), НЕ
// Результат/паника (ROADMAP §Стадия 24, п.8). будильник-процесс даёт
// старт()'у зацепку дождаться (через получить()), пока планировщик
// успевает прогнать мгновенный() ДО КОНЦА (пустое тело — завершается на
// первом же прогоне) — к моменту, когда старт() возобновляется и шлёт
// сообщение в уже мёртвый proc, is_alive уже false.
@(test)
test_actor_send_to_dead_process_is_silent_no_op :: proc(t: ^testing.T) {
	result, ok := run_code(`
		тип Сообщение = перечисление
			X
		конец

		тип Пинг = перечисление
			Готово
		конец

		функ мгновенный() -> Пусто
		конец

		функ будильник(куда: Процесс(Пинг)) -> Пусто
			отправить(куда, Пинг.Готово)
		конец

		функ старт() -> Число
			пер proc: Процесс(Сообщение) = запусти мгновенный()
			пер будильник_proc: Процесс(Пинг) = запусти будильник(себя())
			выбор получить()
				Пинг.Готово -> 0
			конец
			отправить(proc, Сообщение.X)
			42
		конец
	`)
	testing.expectf(t, ok, "[actor: отправить мёртвому процессу] стек пуст")
	n, is_num := result.(f64)
	testing.expectf(t, is_num && n == 42, "[actor: отправить мёртвому процессу] ожидалось 42, получено %v", result)
}

// Genuine (не approximate) deadlock detection: старт() блокируется на
// получить(), никто больше не спавнен — некому его разбудить.
// run_scheduler паникует понятной русской диагностикой вместо вечного
// цикла/тихого зависания.
@(test)
test_actor_deadlock_detected_when_nobody_can_send :: proc(t: ^testing.T) {
	testing.expect_assert(t, "Runtime Error: все процессы заблокированы в ожидании сообщений (дедлок)")
	run_code(`
		тип Сообщение = перечисление
			X
		конец

		функ старт() -> Число
			выбор получить()
				Сообщение.X -> 0
			конец
		конец
	`)
}

// запусти требует bare-имя ФУНКЦИИ — понятная diagnostic, не крэш, если
// операнд не функция.
@(test)
test_actor_spawn_non_function_reports_type_error :: proc(t: ^testing.T) {
	diags := typecheck_only(`
		функ старт() -> Число
			пер x = 5
			запусти x()
			42
		конец
	`)
	expect_diagnostic(t, diags, "Type Error: 'запусти' ожидает вызов функции, 'x' — не функция")
}

// отправить() первым аргументом ожидает Процесс(T) — понятная diagnostic
// вместо крэша при попытке отправить не-процессу.
@(test)
test_actor_send_to_non_process_reports_type_error :: proc(t: ^testing.T) {
	diags := typecheck_only(`
		тип Сообщение = перечисление
			Увеличить
		конец

		функ старт() -> Число
			отправить(5, Сообщение.Увеличить)
			42
		конец
	`)
	expect_diagnostic(t, diags, "Type Error: отправить() ожидает Процесс(T) первым аргументом, получен 'Число'")
}

// Стадия 38 (monitor): наблюдать(ребёнок) + получить_сигнал() — при
// штатном завершении наблюдаемого watcher видит (id, Нет), id совпадает
// с ребёнок.номер().
@(test)
test_monitor_normal_exit_notifies_watcher :: proc(t: ^testing.T) {
	result, ok := run_code(`
		тип Сообщение = перечисление
			Стоп
		конец

		функ дитя() -> Пусто
			выбор получить()
				Сообщение.Стоп -> 0
			конец
		конец

		функ старт() -> Булево
			пер ребёнок: Процесс(Сообщение) = запусти дитя()
			наблюдать(ребёнок)
			отправить(ребёнок, Сообщение.Стоп)
			пер (id, причина) = получить_сигнал()
			пер id_совпал = id == ребёнок.номер()
			выбор причина
				Нет -> id_совпал
				Есть(_) -> ложь
			конец
		конец
	`)
	testing.expectf(t, ok, "[monitor: штатное завершение] стек пуст")
	b, is_bool := result.(bool)
	testing.expectf(t, is_bool && b, "[monitor: штатное завершение] ожидалось true, получено %v", result)
}

// Краш дитя через паника() — watcher получает (id, Есть(причина)), И
// программа НЕ падает целиком (раньше любой краш в дочернем процессе
// ронял fmt.panicf'ом всё — теперь изолирован).
@(test)
test_monitor_crash_isolates_and_notifies :: proc(t: ^testing.T) {
	result, ok := run_code(`
		функ падающий() -> Пусто
			паника("бум")
		конец

		функ старт() -> Булево
			пер плохой = запусти падающий()
			наблюдать(плохой)
			пер (id, причина) = получить_сигнал()
			выбор причина
				Нет -> ложь
				Есть(текст) -> id == плохой.номер() и текст == "Runtime Panic: бум"
			конец
		конец
	`)
	testing.expectf(t, ok, "[monitor: краш изоляция] стек пуст (программа не должна была упасть целиком)")
	b, is_bool := result.(bool)
	testing.expectf(t, is_bool && b, "[monitor: краш изоляция] ожидалось true, получено %v", result)
}

// Деление на ноль в дочернем процессе — та же изоляция, что паника()
// (Стадия 38, п.2 grilled — все catchable-сайты, не только явный builtin,
// см. ROADMAP §Стадия 38 "Полный список catchable-сайтов").
@(test)
test_monitor_division_by_zero_isolates :: proc(t: ^testing.T) {
	result, ok := run_code(`
		функ делитель() -> Пусто
			пер a: Целое = 1
			пер b: Целое = 0
			пер c: Целое = a / b
		конец

		функ старт() -> Булево
			пер плохой = запусти делитель()
			наблюдать(плохой)
			пер (id, причина) = получить_сигнал()
			выбор причина
				Нет -> ложь
				Есть(текст) -> id == плохой.номер() и текст == "Runtime Error: деление на ноль"
			конец
		конец
	`)
	testing.expectf(t, ok, "[monitor: деление на ноль изоляция] стек пуст (программа не должна была упасть целиком)")
	b, is_bool := result.(bool)
	testing.expectf(t, is_bool && b, "[monitor: деление на ноль изоляция] ожидалось true, получено %v", result)
}

// Индекс за границей массива в дочернем процессе — тот же принцип.
@(test)
test_monitor_array_index_out_of_bounds_isolates :: proc(t: ^testing.T) {
	result, ok := run_code(`
		функ читатель() -> Пусто
			пер числа = массив(1, 2, 3)
			пер x = числа[99]
		конец

		функ старт() -> Булево
			пер плохой = запусти читатель()
			наблюдать(плохой)
			пер (id, причина) = получить_сигнал()
			выбор причина
				Нет -> ложь
				Есть(_) -> id == плохой.номер()
			конец
		конец
	`)
	testing.expectf(t, ok, "[monitor: индекс за границей изоляция] стек пуст (программа не должна была упасть целиком)")
	b, is_bool := result.(bool)
	testing.expectf(t, is_bool && b, "[monitor: индекс за границей изоляция] ожидалось true, получено %v", result)
}

// наблюдать() на уже мёртвый процесс — немедленный синтетический сигнал
// (не приходится ждать: цель уже никогда не завершится "по-настоящему").
@(test)
test_monitor_dead_target_gets_immediate_signal :: proc(t: ^testing.T) {
	result, ok := run_code(`
		тип Сообщение = перечисление
			Стоп
		конец

		тип Пинг = перечисление
			Готово
		конец

		функ дитя() -> Пусто
		конец

		функ будильник(куда: Процесс(Пинг)) -> Пусто
			отправить(куда, Пинг.Готово)
		конец

		функ старт() -> Булево
			пер ребёнок: Процесс(Сообщение) = запусти дитя()
			// будильник, спавненный ПОСЛЕ ребёнка, шлёт себе() пинг —
			// получить() ниже блокирует старт() ровно до этого пинга,
			// планировщик успевает прогнать ребёнка (пустое тело —
			// завершается на первом же прогоне) ДО КОНЦА первым (тот же
			// приём, что test_actor_send_to_dead_process_is_silent_no_op).
			// К моменту, когда старт() возобновляется, ребёнок уже мёртв
			// — наблюдать() должен породить синтетический сигнал.
			пер будильник_proc: Процесс(Пинг) = запусти будильник(себя())
			выбор получить()
				Пинг.Готово -> 0
			конец
			наблюдать(ребёнок)
			пер (id, причина) = получить_сигнал()
			выбор причина
				Нет -> ложь
				Есть(_) -> истина
			конец
		конец
	`)
	testing.expectf(t, ok, "[monitor: мёртвая цель] стек пуст")
	b, is_bool := result.(bool)
	testing.expectf(t, is_bool && b, "[monitor: мёртвая цель] ожидалось true, получено %v", result)
}

// Несколько наблюдателей на одного ребёнка — все получают сигнал (не
// только первый зарегистрировавшийся).
@(test)
test_monitor_multiple_watchers_all_notified :: proc(t: ^testing.T) {
	result, ok := run_code(`
		тип Сообщение = перечисление
			Стоп
		конец

		тип Уведомление = перечисление
			Готово
		конец

		функ дитя() -> Пусто
			выбор получить()
				Сообщение.Стоп -> 0
			конец
		конец

		функ наблюдатель_а(цель: Процесс(Сообщение), родитель: Процесс(Уведомление)) -> Пусто
			наблюдать(цель)
			пер (id_а, причина_а) = получить_сигнал()
			отправить(родитель, Уведомление.Готово)
		конец

		функ наблюдатель_б(цель: Процесс(Сообщение), родитель: Процесс(Уведомление)) -> Пусто
			наблюдать(цель)
			пер (id_б, причина_б) = получить_сигнал()
			отправить(родитель, Уведомление.Готово)
		конец

		функ старт() -> Булево
			пер ребёнок: Процесс(Сообщение) = запусти дитя()
			пер а = запусти наблюдатель_а(ребёнок, себя())
			пер б = запусти наблюдатель_б(ребёнок, себя())
			отправить(ребёнок, Сообщение.Стоп)
			пер первый = выбор получить()
				Уведомление.Готово -> истина
			конец
			пер второй = выбор получить()
				Уведомление.Готово -> истина
			конец
			первый и второй
		конец
	`)
	testing.expectf(t, ok, "[monitor: несколько наблюдателей] стек пуст")
	b, is_bool := result.(bool)
	testing.expectf(t, is_bool && b, "[monitor: несколько наблюдателей] ожидалось true, получено %v", result)
}

// Стадия 40: реализация Модуль.Интерфейс для Тип — cross-module интерфейс.
// Позитив: тип из ОДНОГО файла реализует интерфейс, объявленный в
// ДРУГОМ (fixtures/supervisor_fixture_main.ps импортирует супервизор и
// реализует супервизор.ДочерняяЗадача) — работает end-to-end через
// std/супервизор.ps (one_for_one, лимит=1): рабочий падает, супервизор
// перезапускает один раз, падает снова, лимит исчерпан — супервизор
// (это "старт()", i==0) паникует понятным сообщением, называющим
// ребёнка и оригинальную причину краша.
@(test)
test_qualified_impl_supervisor_restarts_then_gives_up :: proc(t: ^testing.T) {
	// Стадия 45: наблюдать(proc) переехал из старт_рабочего() в
	// per-child relay (ретранслятор_рабочего) — наблюдать() регистрирует
	// ТЕКУЩИЙ процесс как наблюдателя, значит наблюдателем обязан быть
	// именно relay (см. std/супервизор.ps). Это узкий, детерминированный
	// побочный эффект: в ЭТОЙ фикстуре (один ребёнок, крашится СРАЗУ на
	// первое же сообщение, отправленное синхронно в том же вызове
	// запустить()) worker успевает выполниться и упасть РАНЬШЕ, чем
	// scheduler впервые дойдёт до его relay (порядок обхода vm.processes
	// — по индексу, worker всегда спавнится раньше relay). наблюдать()
	// на уже мёртвую цель — штатный (Стадия 38) синтетический сигнал
	// "процесс уже не существует" вместо РЕАЛЬНОГО текста паники — restart/
	// лимит-логика на это НЕ влияет (Есть(причина) обрабатывается
	// одинаково), меняется только текст. Реальный воркер-краш ("рабочий
	// сломался") НАДЁЖНО виден в фикстурах с несколькими детьми
	// (supervisor_one_for_all/rest_for_one) — там на момент паники это
	// уже РЕСТАРТ (после swap-remove'ов), relay успевает зарегистрироваться
	// первым.
	testing.expect_assert(
		t,
		"Runtime Panic: супервизор (один-за-одного): 'падающий-рабочий' превысил лимит перезапусков (1 за 60000мс): процесс уже не существует",
	)
	run_module_file("fixtures/supervisor_fixture_main.ps")
}

// Стадия 41: ВсеЗаОдного (one_for_all) — краш "падающей" задачи
// рестартует ВСЮ группу (включая "тихую", которая никогда не падала),
// лимит общий на супервизор, не на ребёнка.
@(test)
test_supervisor_one_for_all_restarts_whole_group_then_gives_up :: proc(t: ^testing.T) {
	testing.expect_assert(
		t,
		"Runtime Panic: супервизор (групповой рестарт): краш 'падающая' исчерпал лимит групповых перезапусков (1 за 60000мс): Runtime Panic: бум",
	)
	run_module_file("fixtures/supervisor_one_for_all_fixture_main.ps")
}

// Стадия 41: ОстальныеЗаОдним (rest_for_one) — краш "падающей" (индекс 1
// из трёх) рестартует её саму и всё, что объявлено ПОСЛЕ неё; задача с
// индексом 0 (объявлена ДО) в этот рестарт не входит.
@(test)
test_supervisor_rest_for_one_restarts_tail_then_gives_up :: proc(t: ^testing.T) {
	testing.expect_assert(
		t,
		"Runtime Panic: супервизор (групповой рестарт): краш 'падающая' исчерпал лимит групповых перезапусков (1 за 60000мс): Runtime Panic: бум",
	)
	run_module_file("fixtures/supervisor_rest_for_one_fixture_main.ps")
}

// Негатив: реализация НесуществующийМодуль.Икс для Тип — модуль не
// найден, понятная Type Error, не крэш компилятора.
@(test)
test_qualified_impl_unknown_module_reports_type_error :: proc(t: ^testing.T) {
	diags := typecheck_only(`
		тип Моя = структура
			x: Число
		конец

		реализация несуществующий.Штука для Моя
			функ значение(это: Моя) -> Число
				это.x
			конец
		конец

		функ старт() -> Число
			0
		конец
	`)
	expect_diagnostic(t, diags, "Type Error: неизвестный модуль 'несуществующий'")
}

// Негатив: модуль существует, но не экспортирует такое имя.
@(test)
test_qualified_impl_module_does_not_export_reports_type_error :: proc(t: ^testing.T) {
	diags := typecheck_only(`
		импорт строки

		тип Моя = структура
			x: Число
		конец

		реализация строки.НетТакогоИнтерфейса для Моя
			функ значение(это: Моя) -> Число
				это.x
			конец
		конец

		функ старт() -> Число
			0
		конец
	`)
	expect_diagnostic(t, diags, "Type Error: модуль 'строки' не экспортирует 'НетТакогоИнтерфейса'")
}

// Негатив: квалификация допустима ТОЛЬКО в форме "Модуль.Интерфейс для
// Тип" — "реализация Модуль.Тип" (без "для", расширение метода на чужой
// тип) не имеет смысла и должна давать понятную синтаксическую ошибку,
// не крэш парсера.
@(test)
test_qualified_impl_without_for_is_syntax_error :: proc(t: ^testing.T) {
	diags := typecheck_only(`
		тип Моя = структура
			x: Число
		конец

		реализация строки.Моя
			функ значение(это: Моя) -> Число
				это.x
			конец
		конец

		функ старт() -> Число
			0
		конец
	`)
	expect_diagnostic(
		t,
		diags,
		"Синтаксическая ошибка: квалифицированное имя допустимо только в форме 'реализация Модуль.Интерфейс для Тип'",
	)
}

// Стадия 42 (kill-примитив): убить(процесс) принудительно останавливает
// чужой процесс — наблюдатель видит (id, Есть(причина)), программа
// продолжает работать (та же изоляция, что у обычного краша, Стадия 38).
@(test)
test_kill_stops_process_and_notifies_watcher :: proc(t: ^testing.T) {
	result, ok := run_code(`
		тип Задача = перечисление
			Выполнить
		конец

		функ бесконечный() -> Пусто
			выбор получить()
				Задача.Выполнить -> бесконечный()
			конец
		конец

		функ старт() -> Булево
			пер жертва = запусти бесконечный()
			наблюдать(жертва)
			убить(жертва)
			пер (id, причина) = получить_сигнал()
			выбор причина
				Нет -> ложь
				Есть(текст) -> id == жертва.номер() и текст == "процесс принудительно остановлен (убить())"
			конец
		конец
	`)
	testing.expectf(t, ok, "[kill] стек пуст (программа не должна была упасть целиком)")
	b, is_bool := result.(bool)
	testing.expectf(t, is_bool && b, "[kill] ожидалось true, получено %v", result)
}

// Убийство уже мёртвого процесса — тихий no-op (симметрично отправить()
// на мёртвый процесс), программа продолжает работать без единого сигнала.
@(test)
test_kill_dead_process_is_silent_no_op :: proc(t: ^testing.T) {
	result, ok := run_code(`
		функ мгновенный() -> Пусто
		конец

		тип Пинг = перечисление
			Готово
		конец

		функ будильник(куда: Процесс(Пинг)) -> Пусто
			отправить(куда, Пинг.Готово)
		конец

		функ старт() -> Число
			пер proc = запусти мгновенный()
			пер будильник_proc: Процесс(Пинг) = запусти будильник(себя())
			выбор получить()
				Пинг.Готово -> 0
			конец
			убить(proc)
			убить(proc)
			42
		конец
	`)
	testing.expectf(t, ok, "[kill: мёртвая цель] стек пуст")
	n, is_num := result.(f64)
	testing.expectf(t, is_num && n == 42, "[kill: мёртвая цель] ожидалось 42, получено %v", result)
}

// Самоубийство запрещено явно — понятная фатальная ошибка, не
// неопределённое поведение (execute() не умеет прервать сам себя
// посреди своих же инструкций).
@(test)
test_kill_self_is_fatal_error :: proc(t: ^testing.T) {
	testing.expect_assert(t, "Runtime Error: убить() нельзя применить к самому себе")
	run_code(`
		функ старт() -> Число
			убить(себя())
			0
		конец
	`)
}

// Убийство "старт()" (процесс #0) извне запрещено явно — корневой
// процесс уже имеет особую семантику (крах/завершение останавливает всю
// программу), убийство его из другого процесса не прокидывается наверх.
@(test)
test_kill_root_process_is_fatal_error :: proc(t: ^testing.T) {
	testing.expect_assert(t, "Runtime Error: убить() нельзя применить к главному процессу")
	run_code(`
		тип Задача = перечисление
			X
		конец

		функ убийца(цель: Процесс(Задача)) -> Пусто
			убить(цель)
		конец

		функ старт() -> Число
			пер призрак = запусти убийца(себя())
			выбор получить()
				Задача.X -> 0
			конец
		конец
	`)
}

// Стадия 44 (link-примитив): краш одной связанной стороны каскадно
// завершает другую — наблюдатель сos видит "связанный процесс #N упал:
// <причина>", а не свою собственную панику (у сос её и не было).
// жертва спавнится/связывается ДО того, как получает сообщение,
// вызывающее краш — синхронизация через пинг родителю, чтобы связать()
// гарантированно выполнился раньше отправить(жертва, ...).
@(test)
test_link_cascades_crash_to_linked_process :: proc(t: ^testing.T) {
	result, ok := run_code(`
		тип Задача = перечисление
			Выполнить
		конец

		тип Пинг = перечисление
			Готово
		конец

		функ падающий() -> Пусто
			выбор получить()
				Задача.Выполнить -> паника("бум")
			конец
		конец

		функ сосед(партнёр: Процесс(Задача), родитель: Процесс(Пинг)) -> Пусто
			связать(партнёр)
			отправить(родитель, Пинг.Готово)
			выбор получить()
				Задача.Выполнить -> сосед(партнёр, родитель)
			конец
		конец

		функ старт() -> Строка
			пер жертва: Процесс(Задача) = запусти падающий()
			пер сосед_proc: Процесс(Задача) = запусти сосед(жертва, себя())
			наблюдать(сосед_proc)
			выбор получить()
				Пинг.Готово -> 0
			конец
			отправить(жертва, Задача.Выполнить)
			пер (id, причина) = получить_сигнал()
			выбор причина
				Нет -> "НЕОЖИДАННО: нормально"
				Есть(текст) -> текст
			конец
		конец
	`)
	testing.expectf(t, ok, "[link: каскад краша] стек пуст (программа не должна была упасть целиком)")
	testing.expectf(
		t,
		value_str_eq(result, "связанный процесс #1 упал: Runtime Panic: бум"),
		"[link: каскад краша] неожиданный результат: %v",
		result,
	)
}

// Штатное завершение НЕ каскадирует через связь (тот же принцип, что у
// Erlang: 'normal' exit не убивает linked процессы) — сосед остаётся
// жив, старт() явно убивает его сам, чтобы получить хоть какой-то сигнал.
@(test)
test_link_does_not_cascade_on_normal_exit :: proc(t: ^testing.T) {
	result, ok := run_code(`
		тип Задача = перечисление
			Выполнить
		конец

		тип Пинг = перечисление
			Готово
		конец

		функ тихий() -> Пусто
			выбор получить()
				Задача.Выполнить -> 0
			конец
		конец

		функ сосед(партнёр: Процесс(Задача), родитель: Процесс(Пинг)) -> Пусто
			связать(партнёр)
			отправить(родитель, Пинг.Готово)
			выбор получить()
				Задача.Выполнить -> сосед(партнёр, родитель)
			конец
		конец

		функ будильник(куда: Процесс(Пинг)) -> Пусто
			отправить(куда, Пинг.Готово)
		конец

		функ старт() -> Строка
			пер жертва: Процесс(Задача) = запусти тихий()
			пер сосед_proc: Процесс(Задача) = запусти сосед(жертва, себя())
			наблюдать(сосед_proc)
			выбор получить()
				Пинг.Готово -> 0
			конец
			отправить(жертва, Задача.Выполнить)
			пер будильник_proc: Процесс(Пинг) = запусти будильник(себя())
			выбор получить()
				Пинг.Готово -> 0
			конец
			убить(сосед_proc)
			пер (id, причина) = получить_сигнал()
			выбор причина
				Нет -> "НЕОЖИДАННО: нормально"
				Есть(текст) -> текст
			конец
		конец
	`)
	testing.expectf(t, ok, "[link: без каскада на нормальном завершении] стек пуст")
	testing.expectf(
		t,
		value_str_eq(result, "процесс принудительно остановлен (убить())"),
		"[link: без каскада на нормальном завершении] неожиданный результат: %v",
		result,
	)
}

// Самолинковка безвредна — cycle guard в terminate_process не даёт ей
// вызвать двойную обработку/бесконечную рекурсию.
@(test)
test_link_self_is_harmless :: proc(t: ^testing.T) {
	result, ok := run_code(`
		тип Задача = перечисление
			X
		конец

		функ саможивущий() -> Пусто
			связать(себя())
			выбор получить()
				Задача.X -> 0
			конец
		конец

		функ будильник(куда: Процесс(Задача)) -> Пусто
			отправить(куда, Задача.X)
		конец

		функ старт() -> Число
			пер proc: Процесс(Задача) = запусти саможивущий()
			пер б = запусти будильник(proc)
			наблюдать(proc)
			пер (id, причина) = получить_сигнал()
			выбор причина
				Нет -> 1
				Есть(_) -> 2
			конец
		конец
	`)
	testing.expectf(t, ok, "[link: самолинковка] стек пуст")
	n, is_int := result.(f64)
	testing.expectf(t, is_int && n == 1, "[link: самолинковка] ожидалось 1 (штатное завершение), получено %v", result)
}

// Линковка на уже мёртвый процесс — тихий no-op (симметрично убить()/
// отправить() на мёртвую цель).
@(test)
test_link_dead_process_is_silent_no_op :: proc(t: ^testing.T) {
	result, ok := run_code(`
		тип Задача = перечисление
			X
		конец

		тип Пинг = перечисление
			Готово
		конец

		функ мгновенный() -> Пусто
		конец

		функ будильник(куда: Процесс(Пинг)) -> Пусто
			отправить(куда, Пинг.Готово)
		конец

		функ линкер(цель: Процесс(Задача)) -> Пусто
			связать(цель)
		конец

		функ старт() -> Число
			пер proc: Процесс(Задача) = запусти мгновенный()
			пер будильник_proc: Процесс(Пинг) = запусти будильник(себя())
			выбор получить()
				Пинг.Готово -> 0
			конец
			пер линкер_proc = запусти линкер(proc)
			42
		конец
	`)
	testing.expectf(t, ok, "[link: мёртвая цель] стек пуст")
	n, is_num := result.(f64)
	testing.expectf(t, is_num && n == 42, "[link: мёртвая цель] ожидалось 42, получено %v", result)
}

// Самоуправление извне запрещено с обеих сторон — иначе root мог бы
// попасть в чей-то links и получить каскад, который terminate_process
// не умеет корректно довести до конца программы (только run_scheduler
// умеет для i == 0).
@(test)
test_link_from_root_is_fatal_error :: proc(t: ^testing.T) {
	testing.expect_assert(t, "Runtime Error: связать() нельзя вызвать из главного процесса")
	run_code(`
		тип Задача = перечисление
			X
		конец

		функ чтолибо() -> Пусто
		конец

		функ старт() -> Число
			пер proc: Процесс(Задача) = запусти чтолибо()
			связать(proc)
			0
		конец
	`)
}

@(test)
test_link_to_root_is_fatal_error :: proc(t: ^testing.T) {
	testing.expect_assert(t, "Runtime Error: связать() нельзя применить к главному процессу")
	run_code(`
		тип Задача = перечисление
			X
		конец

		функ линкер(цель: Процесс(Задача)) -> Пусто
			связать(цель)
		конец

		функ старт() -> Число
			пер призрак = запусти линкер(себя())
			выбор получить()
				Задача.X -> 0
			конец
		конец
	`)
}

// Стадия 45: `запусти Модуль.функция(...)` (qualified-форма) — раньше
// `запусти` жёстко требовал bare-ident callee (infer_spawn_expr,
// type_cheker.odin). Позитив: handle РЕАЛЬНО типобезопасен (не
// unconstrained fire-and-forget) — сообщение доходит с правильным
// payload'ом (видно через панику "эхо получило: привет", пойманную
// наблюдать()+получить_сигнал() в старт()).
@(test)
test_spawn_qualified_call_gives_typed_handle :: proc(t: ^testing.T) {
	testing.expect_assert(t, "Runtime Panic: Runtime Panic: эхо получило: привет")
	run_module_file("fixtures/spawn_qualified_fixture_main.ps")
}

// Негатив: handle от qualified-запусти отвергает НЕПОДХОДЯЩИЙ тип на
// этапе typecheck — доказывает, что T реально выведен из получить()-
// паттерна ВНУТРИ спавненной функции (эхо()), а не оставлен свободным.
@(test)
test_spawn_qualified_call_rejects_wrong_message_type :: proc(t: ^testing.T) {
	diags := typecheck_only_module_file("fixtures/spawn_qualified_bad_type_fixture_main.ps")
	expect_diagnostic(t, diags, "Type Error: ожидался 'Команда', получен 'Строка'")
}

// Негатив: `запусти НесуществующийМодуль.функция()` — понятная ошибка,
// не крэш компилятора.
@(test)
test_spawn_qualified_call_unknown_module_reports_error :: proc(t: ^testing.T) {
	diags := typecheck_only_module_file("fixtures/spawn_qualified_bad_module_fixture_main.ps")
	expect_diagnostic(t, diags, "Type Error: 'запусти' ожидает вызов функции по имени")
}

// Негатив: `запусти Модуль.Экспорт(...)`, где Экспорт существует, но не
// функция (тип-перечисление) — понятная Type Error.
@(test)
test_spawn_qualified_call_non_function_export_reports_error :: proc(t: ^testing.T) {
	diags := typecheck_only_module_file("fixtures/spawn_qualified_not_function_fixture_main.ps")
	expect_diagnostic(t, diags, "Type Error: 'запусти' ожидает вызов функции, 'супервизор.Стратегия' — не функция")
}

// Стадия 45: динамическое добавление ребёнка во время работы супервизора
// — супервизор спавнится напрямую (qualified запусти), получает
// типобезопасный Процесс(СобытиеСупервизора), внешний код шлёт
// ДобавитьЗадачу(...). Добавленный ребёнок падает, супервизор его
// перезапускает до лимита, затем паникует — доказывает, что динамически
// добавленный ребёнок реально под наблюдением (не осиротевший).
//
// Текст причины ("процесс уже не существует" вместо "динамический
// рабочий сломался") — тот же детерминированный нюанс планировщика, что
// у test_qualified_impl_supervisor_restarts_then_gives_up (см. её
// пометку): единственный ребёнок крашится на первое же сообщение,
// отправленное синхронно в том же вызове запустить(), — worker
// успевает упасть раньше, чем scheduler впервые дойдёт до его relay.
// Restart/лимит-логика не зависит от точного текста причины.
@(test)
test_supervisor_dynamic_add_child_gets_supervised :: proc(t: ^testing.T) {
	testing.expect_assert(
		t,
		"Runtime Panic: Runtime Panic: супервизор (один-за-одного): 'динамический-рабочий' превысил лимит перезапусков (1 за 60000мс): процесс уже не существует",
	)
	run_module_file("fixtures/supervisor_dynamic_add_fixture_main.ps")
}

// Стадия 45: динамическое удаление ребёнка — "тихая" задача на индексе 0
// удаляется (УбратьЗадачу(0), tombstone id_ов[0] = -1) ДО того, как
// добавляется падающая задача (индекс 1). Итоговая паника ссылается
// ИМЕННО на падающую задачу с ОЖИДАЕМЫМ (не перепутанным) именем/лимитом
// — доказательство, что tombstone-запись не путает индексацию
// последующих задач.
@(test)
test_supervisor_dynamic_remove_child_stops_and_untracked :: proc(t: ^testing.T) {
	testing.expect_assert(
		t,
		"Runtime Panic: Runtime Panic: супервизор (один-за-одного): 'падающая-после-удаления' превысил лимит перезапусков (1 за 60000мс): процесс уже не существует",
	)
	run_module_file("fixtures/supervisor_dynamic_remove_fixture_main.ps")
}

// Стадия 46: доказательство, что окно_мс супервизора РЕАЛЬНО
// консультируется, не молча игнорируется. Ребёнок падает РОВНО 3 раза
// (бюджет-поле осталось в фикстуре), макс_рестартов=2 — СТАРАЯ
// (Стадия 45, счётчик за всю жизнь) семантика запаниковала бы на 3-м
// крахе. Окно (0.001мс) заведомо уже, чем реальное время одного цикла
// краш→relay→сигнал→рестарт (на 2+ порядка) — sliding window "забывает"
// каждый предыдущий крах ДО следующего, лимит не достигается ни разу за
// все 3 краха. После исчерпания бюджета ребёнок больше не падает —
// ничего в программе больше не проснётся — детерминированный дедлок
// планировщика (НЕ паника лимита рестартов) — единственный исход,
// который отличал бы "окно реально фильтрует" от "окно принимается, но
// игнорируется" (при игнорировании — обычная паника лимита на 3-м
// крахе, см. ручную проверку в ROADMAP §Стадия 46 с тем же сценарием на
// широком окне). Первая версия этого теста (без бюджета, окно=0.1мс,
// макс_рестартов=5) была отброшена — эмпирически требовала ~2660
// циклов рестарта до дедлока (иногда две метки СЛУЧАЙНО попадали в
// 0.1мс друг от друга под системным джиттером, лимит почти
// накапливался) — это проверяло исчерпание системных ресурсов после
// тысяч спавнов, а не логику окна. Бюджетная версия — ровно 3 цикла,
// быстро и без опоры на джиттер планировщика.
@(test)
test_supervisor_narrow_window_never_exhausts_limit :: proc(t: ^testing.T) {
	testing.expect_assert(t, "Runtime Error: все процессы заблокированы в ожидании сообщений (дедлок)")
	run_module_file("fixtures/supervisor_narrow_window_fixture_main.ps")
}

#+build !js
package core

import "core:testing"

@(test)
test_explicit_panic :: proc(t: ^testing.T) {
	testing.expect_assert(t, "Runtime Panic: критичный сбой")
	run_code(`
		функ старт() -> Число
			паника("критичный сбой")
		конец
	`)
}

@(test)
test_option_expect_panics_on_empty :: proc(t: ^testing.T) {
	testing.expect_assert(t, "Runtime Panic: нет значения")
	run_code(`
		функ старт() -> Число
			пер о: Опция(Число) = Опция.Нет()
			о.ожидать("нет значения")
		конец
	`)
}

@(test)
test_result_expect_panics_on_error :: proc(t: ^testing.T) {
	// Стадия 7 Phase F: Результат.ожидать теперь настоящий generic-метод
	// (реализация в prelude.ps) — E может быть ЛЮБЫМ типом, не только
	// Ошибка, поэтому паника больше не может автоматически дописывать
	// error.сообщение (это было спецкейсом старого VM-диспетчера под
	// конкретно Error_Value). Паникует с одним переданным сообщением.
	testing.expect_assert(t, "Runtime Panic: не удалось")
	run_code(`
		функ старт() -> Число
			пер р: Результат(Число, Ошибка) = Результат.Неудача(Ошибка("фс", "нет файла"))
			р.ожидать("не удалось")
		конец
	`)
}

@(test)
test_result_expect_error_panics_on_success :: proc(t: ^testing.T) {
	testing.expect_assert(t, "Runtime Panic: ожидалась ошибка")
	run_code(`
		функ старт() -> Ошибка
			пер р: Результат(Число, Ошибка) = Результат.Успех(42)
			р.ожидать_ошибку("ожидалась ошибка")
		конец
	`)
}

@(test)
test_strict_index_panics_out_of_bounds :: proc(t: ^testing.T) {
	testing.expect_assert(t, "Runtime Error: индекс 1 выходит за границы массива")
	run_code(`
		функ старт() -> Число
			пер числа = массив(10)
			числа[1]
		конец
	`)
}

@(test)
test_continue_outside_loop_is_type_error :: proc(t: ^testing.T) {
	testing.expect_assert(t, "Type Error: 'продолжить' можно использовать только внутри цикла")
	run_code(`
		функ старт() -> Число
			продолжить
			1
		конец
	`)
}

@(test)
test_break_outside_loop_is_type_error :: proc(t: ^testing.T) {
	testing.expect_assert(t, "Type Error: 'прервать' можно использовать только внутри цикла")
	run_code(`
		функ старт() -> Число
			прервать
			1
		конец
	`)
}

@(test)
test_math_and_logic :: proc(t: ^testing.T) {
	TestCase :: struct {
		name:     string,
		source:   string,
		expected: Value,
	}

	tests := []TestCase {
		{
			"Простая математика",
			"функ старт() -> Число  10 + 20 конец",
			f64(30.0),
		},
		{
			"Унарный минус",
			"функ старт() -> Число  -5 конец",
			f64(-5.0),
		},
		{"Логика", "функ старт() -> Булево истина конец", true},
		{
			"Сравнения <= и >=",
			`
			функ старт() -> Булево
				пер а = 5
				пер б = 5
				пер семь = 7
				пер р1 = а <= б
				пер р2 = а >= б
				пер р3 = не (семь <= а)
				пер р4 = семь >= а
				пер р5 = не (а <= 3)
				пер р6 = не (3 >= а)
				р1 и р2 и р3 и р4 и р5 и р6
			конец
		`,
			true,
		},
		{
			// Регрессия: '(' в начале statement'а (на новой строке после
			// предыдущего токена) раньше ошибочно читался как продолжение
			// ПРЕДЫДУЩЕГО выражения — либо как generic-тип-аргументы у
			// `-> Число`(тип, к которому эта скобка на деле не относится),
			// либо как вызов предыдущего значения (`7\n(...)` → `7(...)`).
			// См. Token.nl_before в token.odin/lexer.odin и обе проверки
			// в parser.odin (parse_type + основной Pratt-цикл parse_expr).
			"Скобка в начале statement'а после перевода строки",
			`
			функ старт() -> Булево
				пер а = 5
				пер б = 7
				(а <= б) и (б >= а)
			конец
		`,
			true,
		},
		{
			"Сложный if",
			`
			функ старт() -> Число
				пер х = если истина тогда 10 иначе 20 конец
				х + 5
		    конец
		`,
			f64(15.0),
		},
		{
			"Вызов функции",
			`
			функ удвоить(х: Число) -> Число  х * 2 конец
			функ старт() -> Число  удвоить(10) конец
		`,
			f64(20.0),
		},
		{
			"Конкатенация строк",
			`
			функ старт() -> Строка
				пер имя = "pan"
				имя + "os" + "!"
			конец
		`,
			Value(perm_string("panos!")),
		},
		{
			"Строки: escape-последовательности",
			`
			функ старт() -> Строка
				"a\n\tb\rc\"d\\e"
			конец
		`,
			Value(perm_string("a\n\tb\rc\"d\\e")),
		},
		{
			"Длина строк и коллекций",
			`
			функ старт() -> Целое
				пер числа = массив(1, 2, 3)
				пер цены = соответствие("яблоко" = 10, "груша" = 20)
				длина("привет") + длина(числа) + длина(цены)
			конец
		`,
			f64(11.0),
		},
		{
			"Массивы: индекс, запись и методы",
			`
			функ старт() -> Целое
				пер числа: Массив(Целое) = массив()
				числа.добавить(1)
				числа.добавить(2)
				числа[1] = 10
				числа[0] + числа[1] + числа.длина() + числа.получить(5, 7)
			конец
		`,
			f64(20.0),
		},
		{
			"Массивы: проверки наличия",
			`
			функ старт() -> Булево
				пер числа = массив(3, 4)
				числа.есть(1)
			конец
		`,
			true,
		},
		{
			"Цикл: продолжить",
			`
			функ старт() -> Число
				пер i = 0
				пер сумма = 0
				пока i < 5 цикл
					i = i + 1
					если i == 3 тогда
						продолжить
					конец
					сумма = сумма + i
				конец
				сумма
			конец
		`,
			f64(12.0),
		},
		{
			"Цикл: прервать",
			`
			функ старт() -> Число
				пер i = 0
				пер сумма = 0
				пока i < 10 цикл
					i = i + 1
					если i > 3 тогда
						прервать
					конец
					сумма = сумма + i
				конец
				сумма
			конец
		`,
			f64(6.0),
		},
		{
			"Соответствие: литерал, индекс и методы",
			`
			функ старт() -> Целое
				пер цены: Соответствие(Строка, Целое) = соответствие(
					"яблоко" = 10,
					"груша" = 20,
				)
				цены["банан"] = 5
				если цены.есть("банан") тогда
					цены["яблоко"] + цены.получить("банан", 0) + цены.длина()
				иначе
					0
				конец
			конец
		`,
			f64(18.0),
		},
		{
			"Соответствие: удаление",
			`
			функ старт() -> Целое
				пер цены = соответствие("яблоко" = 10, "груша" = 20)
				пер удалено = цены.удалить("груша")
				если удалено тогда цены.длина() иначе 0 конец
			конец
		`,
			f64(1.0),
		},
		{
			"Лямбда: вывод параметров и возврата из тела",
			`
			функ старт() -> Число
				пер удвоить = функ(х)
					х * 2
				конец
				удвоить(7)
			конец
		`,
			f64(14.0),
		},
		{
			"Лямбда: вывод из аннотации переменной",
			`
			функ старт() -> Число
				пер длина_фн: функ(Строка) -> Число = функ(текст)
					42
				конец
				длина_фн("panos")
			конец
		`,
			f64(42.0),
		},
		{
			"Лямбда: вывод из типа параметра функции",
			`
			функ применить(ф: функ(Число) -> Число, значение: Число) -> Число
				ф(значение)
			конец

			функ старт() -> Число
				применить(функ(х)
					х + 3
				конец, 9)
			конец
		`,
			f64(12.0),
		},
		{
			// Стадия 7 Phase A: пер id = функ(x) x конец без generalize/
			// instantiate типизировался бы монoморфно — первый вызов id(5)
			// "запирал" бы InferVar в Число, и id("привет") падал бы Type
			// Error'ом. С Phase A каждое использование id инстанцирует
			// свежую копию схемы.
			"Стадия 7 Phase A: полиморфная лямбда на двух типах",
			`
			функ старт() -> Число
				пер id = функ(x) x конец
				пер a = id(5)
				пер b = id("привет")
				a
			конец
		`,
			f64(5.0),
		},
		{
			// Guard от over-eager generalization: outer обобщается один раз
			// при объявлении, оба вызова инстанцируются независимо, но
			// каждый обязан сойтись к Число по своим собственным аргументам.
			"Стадия 7 Phase A: лямбда без свободных InferVar не обобщается лишний раз",
			`
			функ старт() -> Число
				пер outer = функ(y) y конец
				outer(3) + outer(3)
			конец
		`,
			f64(6.0),
		},
		{
			// Стадия 7 Phase B: явный generic-функция синтаксис функ имя[T].
			// Схема строится из аннотаций сигнатуры (не из инференса тела,
			// как у Phase A), но инстанцируется на каждом вызове тем же
			// symbol_schemes-механизмом.
			"Стадия 7 Phase B: generic-функция на двух типах",
			`
			функ id[T](x: T) -> T
				x
			конец

			функ старт() -> Число
				пер a = id(5)
				пер b = id("привет")
				a
			конец
		`,
			f64(5.0),
		},
		{
			// T внутри Массив(T) резолвится рекурсивно через тот же
			// current_type_params, что и голый T — без отдельного кода.
			"Стадия 7 Phase B: generic-функция с Массив(T) в сигнатуре",
			`
			функ первый[T](xs: Массив(T)) -> T
				xs[0]
			конец

			функ старт() -> Число
				первый(массив(7, 8, 9))
			конец
		`,
			f64(7.0),
		},
		{
			// Стадия 7 Phase C: generic-структура, A/B выводятся из
			// аргументов конструктора (тот же symbol_schemes-механизм,
			// что Phase A/B, применённый к полям структуры).
			"Стадия 7 Phase C: generic-структура, конструктор с выводом типов",
			`
			тип Пара[A, B] = структура
				ключ: A
				значение: B
			конец

			функ старт() -> Число
				пер p = Пара(1, "текст")
				p.ключ
			конец
		`,
			f64(1.0),
		},
		{
			// Главный тест на generic_instance_cache: явная аннотация типа
			// (resolve_type_node, Type_Generic case) и конструктор
			// (infer_call_expr, .Struct case) должны дать ОДИН и тот же
			// ^Type — unify_types сравнивает .Struct только по identity
			// указателя, без кэша это не типизировалось бы.
			"Стадия 7 Phase C: аннотация типа + конструктор — совместимый тип",
			`
			тип Пара[A, B] = структура
				ключ: A
				значение: B
			конец

			функ старт() -> Число
				пер p: Пара(Число, Строка) = Пара(1, "текст")
				p.ключ
			конец
		`,
			f64(1.0),
		},
		{
			// Guard: две разные инстанциации одной generic-структуры не
			// должны схлопнуться в один кэш-инстанс (ключ кэша должен
			// различать Пара(Число,Число) и Пара(Строка,Строка)).
			"Стадия 7 Phase C: разные инстанциации не путаются",
			`
			тип Пара[A, B] = структура
				ключ: A
				значение: B
			конец

			функ старт() -> Число
				пер a = Пара(1, 2)
				пер b = Пара("x", "y")
				a.ключ
			конец
		`,
			f64(1.0),
		},
		{
			// Стадия 7 Phase D: рекурсивный generic ADT — главный тест,
			// проверяет [T]-синтаксис у перечисления, самоссылку Дерево(T)
			// внутри Узел, вывод T из аргументов конструктора (Дерево.Лист,
			// без явных type-аргументов), выбор-destructuring на
			// инстанцированном enum.
			"Стадия 7 Phase D: рекурсивный generic ADT (Дерево[T])",
			`
			тип Дерево[T] = перечисление
				Лист(T)
				Узел(Дерево(T), T, Дерево(T))
			конец

			функ сумма(д: Дерево(Число)) -> Число
				возврат выбор д
					Лист(x) -> x
					Узел(лево, x, право) -> сумма(лево) + x + сумма(право)
				конец
			конец

			функ старт() -> Число
				пер л1 = Дерево.Лист(3)
				пер л2 = Дерево.Лист(5)
				пер узел = Дерево.Узел(л1, 7, л2)
				сумма(узел)
			конец
		`,
			f64(15.0),
		},
		{
			// Явная аннотация типа + конструктор дают совместимый тип —
			// тот же identity-кэш тест, что Phase C, для enum.
			"Стадия 7 Phase D: аннотация типа + конструктор совместимы (enum)",
			`
			тип Коробка[T] = перечисление
				Значение(T)
			конец

			функ старт() -> Число
				пер к: Коробка(Число) = Коробка.Значение(42)
				выбор к
					Значение(x) -> x
				конец
			конец
		`,
			f64(42.0),
		},
		{
			// Стадия 7 Phase D: самоссылающаяся generic-структура (не ADT,
			// но та же bootstrapping-проблема) — тип Список[T] со ссылкой
			// на Опция(Список(T)) внутри своих же полей. Раньше сегфолтил
			// (SIGSEGV, необработанная циклическая структура в обходчиках
			// типов) до фикса cycle-guard в collect_free_infer_vars/
			// instantiate_type/unify_types.
			"Стадия 7 Phase D: самоссылающаяся generic-структура (Список[T])",
			`
			тип Список[T] = структура
				значение: T
				следующий: Опция(Список(T))
			конец

			функ старт() -> Число
				пер хвост = Список(2, Опция.Нет())
				пер голова = Список(1, Опция.Есть(хвост))
				если голова.следующий.есть() тогда
					голова.значение + голова.следующий.значение().значение
				иначе
					0
				конец
			конец
		`,
			f64(3.0),
		},
		{
			"Результат: успех",
			`
			функ старт() -> Число
				пер р: Результат(Число, Ошибка) = Результат.Успех(41)
				если р.успех() тогда р.значение() + 1 иначе 0 конец
			конец
		`,
			f64(42.0),
		},
		{
			"Результат: ошибка и причина",
			`
			функ старт() -> Строка
				пер р: Результат(Число, Ошибка) = Результат.Неудача(Ошибка("фс", "нет файла"))
				если р.ошибка() тогда р.причина().сообщение иначе "" конец
			конец
		`,
			Value(perm_string("нет файла")),
		},
		{
			"Результат: оператор ? разворачивает успех",
			`
			функ добавить_один() -> Результат(Число, Ошибка)
				пер р: Результат(Число, Ошибка) = Результат.Успех(41)
				Результат.Успех(р? + 1)
			конец

			функ старт() -> Число
				добавить_один().получить(0)
			конец
		`,
			f64(42.0),
		},
		{
			"Результат: оператор ? возвращает ошибку",
			`
			функ дать_результат() -> Результат(Число, Ошибка)
				Результат.Неудача(Ошибка("фс", "нет файла"))
			конец

			функ пробросить() -> Результат(Число, Ошибка)
				Результат.Успех(дать_результат()? + 1)
			конец

			функ старт() -> Строка
				пер р = пробросить()
				если р.ошибка() тогда р.причина().сообщение иначе "" конец
			конец
		`,
			Value(perm_string("нет файла")),
		},
		{
			"Результат: получить ошибку из успеха возвращает умолчание",
			`
			функ старт() -> Строка
				пер р: Результат(Число, Ошибка) = Результат.Успех(42)
				р.получить_ошибку(Ошибка("нет", "нет ошибки")).сообщение
			конец
		`,
			Value(perm_string("нет ошибки")),
		},
		{
			"Результат: получить ошибку из неудачи",
			`
			функ старт() -> Строка
				пер р: Результат(Число, Ошибка) = Результат.Неудача(Ошибка("фс", "нет файла"))
				р.получить_ошибку(Ошибка("нет", "нет ошибки")).сообщение
			конец
		`,
			Value(perm_string("нет файла")),
		},
		{
			"Результат: ожидать возвращает успех",
			`
			функ старт() -> Число
				пер р: Результат(Число, Ошибка) = Результат.Успех(42)
				р.ожидать("должен быть успех")
			конец
		`,
			f64(42.0),
		},
		{
			"Результат: ожидать ошибку возвращает причину",
			`
			функ старт() -> Строка
				пер р: Результат(Число, Ошибка) = Результат.Неудача(Ошибка("фс", "нет файла"))
				р.ожидать_ошибку("должна быть ошибка").сообщение
			конец
		`,
			Value(perm_string("нет файла")),
		},
		{
			"Результат: успех в опцию",
			`
			функ старт() -> Число
				пер р: Результат(Число, Ошибка) = Результат.Успех(42)
				р.опция().получить(0)
			конец
		`,
			f64(42.0),
		},
		{
			"Результат: ошибка в пустую опцию",
			`
			функ старт() -> Число
				пер р: Результат(Число, Ошибка) = Результат.Неудача(Ошибка("фс", "нет файла"))
				р.опция().получить(42)
			конец
		`,
			f64(42.0),
		},
		{
			"Результат: успех в пустую опцию ошибки",
			`
			функ старт() -> Строка
				пер р: Результат(Число, Ошибка) = Результат.Успех(42)
				р.ошибка_опция().получить(Ошибка("нет", "нет ошибки")).сообщение
			конец
		`,
			Value(perm_string("нет ошибки")),
		},
		{
			"Результат: ошибка в опцию ошибки",
			`
			функ старт() -> Строка
				пер р: Результат(Число, Ошибка) = Результат.Неудача(Ошибка("фс", "нет файла"))
				р.ошибка_опция().получить(Ошибка("нет", "нет ошибки")).сообщение
			конец
		`,
			Value(perm_string("нет файла")),
		},
		{
			"Результат: заменить ошибку сохраняет успех",
			`
			функ старт() -> Число
				пер р: Результат(Число, Ошибка) = Результат.Успех(42)
				р.заменить_ошибку(Ошибка("новая", "не важно")).получить(0)
			конец
		`,
			f64(42.0),
		},
		{
			"Результат: заменить ошибку меняет причину",
			`
			функ старт() -> Строка
				пер р: Результат(Число, Ошибка) = Результат.Неудача(Ошибка("старая", "старое"))
				пер новый = р.заменить_ошибку(Ошибка("новая", "новое"))
				если новый.ошибка() тогда новый.причина().сообщение иначе "" конец
			конец
		`,
			Value(perm_string("новое")),
		},
		{
			"Результат: заменить значение меняет успех",
			`
			функ старт() -> Строка
				пер р: Результат(Число, Ошибка) = Результат.Успех(42)
				р.заменить_значение("готово").получить("нет")
			конец
		`,
			Value(perm_string("готово")),
		},
		{
			"Результат: заменить значение сохраняет ошибку",
			`
			функ старт() -> Строка
				пер р: Результат(Число, Ошибка) = Результат.Неудача(Ошибка("старая", "старое"))
				пер новый = р.заменить_значение("готово")
				если новый.ошибка() тогда новый.причина().сообщение иначе "" конец
			конец
		`,
			Value(perm_string("старое")),
		},
		{
			"Результат: запас сохраняет успех",
			`
			функ старт() -> Число
				пер р: Результат(Число, Ошибка) = Результат.Успех(42)
				р.запас(Результат.Успех(7)).получить(0)
			конец
		`,
			f64(42.0),
		},
		{
			"Результат: запас возвращает запасной результат",
			`
			функ старт() -> Число
				пер р: Результат(Число, Ошибка) = Результат.Неудача(Ошибка("нет", "нет значения"))
				р.запас(Результат.Успех(42)).получить(0)
			конец
		`,
			f64(42.0),
		},
		{
			"Опция: значение по умолчанию",
			`
			функ старт() -> Число
				пер о: Опция(Число) = Опция.Нет()
				о.получить(42)
			конец
		`,
			f64(42.0),
		},
		{
			"Паника: ветка имеет тип Никогда",
			`
			функ старт() -> Число
				если истина тогда 42 иначе паника("невозможно") конец
			конец
		`,
			f64(42.0),
		},
		{
			"Опция: есть значение",
			`
			функ старт() -> Число
				пер о = Опция.Есть(10)
				если о.есть() тогда о.значение() иначе 0 конец
			конец
		`,
			f64(10.0),
		},
		{
			"Опция: оператор ? разворачивает значение",
			`
			функ добавить_один() -> Опция(Число)
				пер о: Опция(Число) = Опция.Есть(41)
				Опция.Есть(о? + 1)
			конец

			функ старт() -> Число
				добавить_один().получить(0)
			конец
		`,
			f64(42.0),
		},
		{
			"Опция: оператор ? возвращает Нет",
			`
			функ дать_опцию() -> Опция(Число)
				Опция.Нет()
			конец

			функ пробросить() -> Опция(Число)
				Опция.Есть(дать_опцию()? + 1)
			конец

			функ старт() -> Число
				пробросить().получить(42)
			конец
		`,
			f64(42.0),
		},
		{
			"Опция: ожидать возвращает значение",
			`
			функ старт() -> Число
				пер о: Опция(Число) = Опция.Есть(42)
				о.ожидать("должно быть значение")
			конец
		`,
			f64(42.0),
		},
		{
			"Опция: заменить значение меняет значение",
			`
			функ старт() -> Строка
				пер о: Опция(Число) = Опция.Есть(42)
				о.заменить_значение("готово").получить("нет")
			конец
		`,
			Value(perm_string("готово")),
		},
		{
			"Опция: заменить значение сохраняет пусто",
			`
			функ старт() -> Строка
				пер о: Опция(Число) = Опция.Нет()
				о.заменить_значение("готово").получить("нет")
			конец
		`,
			Value(perm_string("нет")),
		},
		{
			"Опция: запас сохраняет значение",
			`
			функ старт() -> Число
				пер о: Опция(Число) = Опция.Есть(42)
				о.запас(Опция.Есть(7)).получить(0)
			конец
		`,
			f64(42.0),
		},
		{
			"Опция: запас возвращает запасную опцию",
			`
			функ старт() -> Число
				пер о: Опция(Число) = Опция.Нет()
				о.запас(Опция.Есть(42)).получить(0)
			конец
		`,
			f64(42.0),
		},
		{
			"Опция: значение в результат",
			`
			функ старт() -> Число
				пер о: Опция(Число) = Опция.Есть(42)
				о.результат_или(Ошибка("опция", "пусто")).получить(0)
			конец
		`,
			f64(42.0),
		},
		{
			"Опция: пусто в ошибочный результат",
			`
			функ старт() -> Строка
				пер о: Опция(Число) = Опция.Нет()
				пер р = о.результат_или(Ошибка("опция", "пусто"))
				если р.ошибка() тогда р.причина().сообщение иначе "" конец
			конец
		`,
			Value(perm_string("пусто")),
		},
		{
			"Стандартная библиотека: файловая система",
			`
			импорт фс

			функ старт() -> Строка
				пер путь = "/tmp/panos_stdlib_e2e.txt"
				пер запись = фс.записать(путь, "panos")
				если запись.успех() тогда
					если фс.есть(путь) тогда
						фс.прочитать(путь).получить("ошибка")
					иначе
						"нет файла"
					конец
				иначе
					запись.причина().сообщение
				конец
			конец
		`,
			Value(perm_string("panos")),
		},
		{
			"Стандартная библиотека: вывод",
			`
			импорт ввод_вывод

			функ старт() -> Число
				ввод_вывод.печать("panos")
				ввод_вывод.строка("")
				42
			конец
		`,
			f64(42.0),
		},
		{
			"Стандартная библиотека: строки",
			`
			импорт строки

			функ старт() -> Строка
				пер срез = строки.срез("panos-lang", 0, 5)
				пер цифра = строки.это_цифра("7")
				пер буква = строки.это_буква("ф")
				пер ни_то_ни_то = строки.цифра_или_буква("-")
				если цифра и буква и не ни_то_ни_то тогда
					срез
				иначе
					"провал"
				конец
			конец
		`,
			Value(perm_string("panos")),
		},
		{
			"Стандартная библиотека: строки — найти/содержит/заменить/регистр",
			`
			импорт строки

			функ старт() -> Строка
				пер найдено = строки.найти("привет мир", "мир", 0)
				пер не_найдено = строки.найти("привет мир", "нет", 0)
				пер содержит = строки.содержит("привет мир", "вет")
				пер заменено = строки.заменить("а-б-в", "-", "_")
				пер верхний = строки.верхний_регистр("привет Мир")
				пер нижний = строки.нижний_регистр("ПРИВЕТ Мир")
				если найдено == 7 и не_найдено == -1 и содержит и заменено == "а_б_в" и верхний == "ПРИВЕТ МИР" и нижний == "привет мир" тогда
					"ок"
				иначе
					"провал"
				конец
			конец
		`,
			Value(perm_string("ок")),
		},
		{
			"Стандартная библиотека: строки — разбить/соединить/обрезать/аффиксы/сравнить",
			`
			импорт строки

			функ старт() -> Строка
				пер части = строки.разбить("а,б,в", ",")
				пер обратно = строки.соединить(части, "|")
				пер обрезано = строки.обрезать("  привет  ")
				пер префикс = строки.начинается_с("привет", "при")
				пер суффикс = строки.заканчивается_на("привет", "вет")
				пер сравнение = строки.сравнить("а", "б")
				если части.длина() == 3 и обратно == "а|б|в" и обрезано == "привет" и префикс и суффикс и сравнение == -1 тогда
					"ок"
				иначе
					"провал"
				конец
			конец
		`,
			Value(perm_string("ок")),
		},
	}

	for tc in tests {
		result, ok := run_code(tc.source)
		testing.expectf(
			t,
			ok,
			"[%s] ПРОВАЛ: Стек пуст, нет результата",
			tc.name,
		)

		if !ok do continue

		testing.expectf(
			t,
			value_equals(result, tc.expected),
			"[%s] ПРОВАЛ: Ожидалось %v, получено %v",
			tc.name,
			tc.expected,
			result,
		)
	}

	args_result, args_ok := run_code_with_args(
		`
		импорт ос

		функ старт() -> Строка
			пер аргументы = ос.аргументы()
			аргументы[1]
		конец
	`,
		[]string{"альфа", "бета"},
	)
	testing.expectf(
		t,
		args_ok,
		"[Стандартная библиотека: аргументы] стек пуст",
	)
	if args_ok {
		testing.expectf(
			t,
			value_str_eq(args_result, "бета"),
			"[Стандартная библиотека: аргументы] ожидалось бета, получено %v",
			args_result,
		)
	}

	env_result, env_ok := run_code(
		`
		импорт ос

		функ старт() -> Строка
			пер запись = ос.установить_окружение("PANOS_E2E_ENV", "значение")
			если запись.успех() тогда
				ос.окружение("PANOS_E2E_ENV").получить("нет")
			иначе
				запись.причина().сообщение
			конец
		конец
	`,
	)
	testing.expectf(
		t,
		env_ok,
		"[Стандартная библиотека: окружение] стек пуст",
	)
	if env_ok {
		testing.expectf(
			t,
			value_str_eq(env_result, "значение"),
			"[Стандартная библиотека: окружение] ожидалось значение, получено %v",
			env_result,
		)
	}
}

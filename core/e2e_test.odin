	if !ok do return
	v, is_variant := result.(^Variant_Value)
	testing.expectf(t, is_variant, "cross-module short: ожидался ^Variant_Value")
	if !is_variant do return
	f0, _ := v.fields[0].(f64)
	testing.expectf(
		t,
		v.tag_index == 1 && f0 == 11.0,
		"cross-module short: неверная форма",
	)
}


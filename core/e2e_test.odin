@(test)
test_method_own_type_param :: proc(t: ^testing.T) {
	// Стадия 7 Phase F: метод может иметь СОБСТВЕННЫЙ type-параметр,
	// даже когда владелец НЕ generic (Коробка здесь без [T]) — нужно для
	// Опция.результат_или[E](ошибка: E), E не входит в [T] Опции. Раньше
	// (Phase B/E) любой метод с [T] отклонялся парсером безусловно.
	result, ok := run_code(`
		тип Коробка = структура
			значение: Число
		конец

		реализация Коробка
			функ метод[T](это: Коробка, x: T) -> T
				x
			конец
		конец

		функ старт() -> Число
			пер к = Коробка(1)
			к.метод(42)
		конец
	`)
	testing.expectf(t, ok, "method own type param: пустой стек")
	f, is_num := result.(f64)
	testing.expectf(t, is_num && f == 42.0, "method own type param: %v != 42.0", result)
}

@(test)
test_generic_struct_method_call :: proc(t: ^testing.T) {
	// Стадия 7 Phase E: реализация методов на generic-структурах — раньше
	// (Phase C/D) отклонялась целиком, теперь работает. это: Коробка
	// (bare) резолвится в сам шаблонный тип, метод получает свою
	// Type_Scheme и инстанцируется заново на каждый вызов.
	result, ok := run_code(`
		тип Коробка[T] = структура
			значение: T
		конец

		реализация Коробка
			функ получить(это: Коробка) -> T
				это.значение
			конец
		конец

		функ старт() -> Число
			пер к = Коробка(42)
			к.получить()
		конец
	`)
	testing.expectf(t, ok, "generic-struct method call: пустой стек")
	f, is_num := result.(f64)
	testing.expectf(t, is_num && f == 42.0, "generic-struct method call: %v != 42.0", result)
}

@(test)
test_generic_method_no_cemented_type_param :: proc(t: ^testing.T) {
	// Стадия 7 Phase E: главный guard-тест — без своей Type_Scheme у
	// метода первый же вызов (a.получить(), T=Число) зацементировал бы
	// T шаблона навсегда через structural fallback в unify_types (Phase
	// D, generic_origin совпадает у это: Коробка и любой инстанциации).
	// Второй вызов с другим T (b.получить(), T=Строка) тогда падал бы
	// Type Error'ом, хотя код корректен.
	result, ok := run_code(`
		тип Коробка[T] = структура
			значение: T
		конец

		реализация Коробка
			функ получить(это: Коробка) -> T
				это.значение
			конец
		конец

		функ старт() -> Число
			пер a = Коробка(1)
			пер b = Коробка("текст")
			a.получить()
		конец
	`)
	testing.expectf(t, ok, "generic method, два T подряд: пустой стек")
	f, is_num := result.(f64)
	testing.expectf(t, is_num && f == 1.0, "generic method, два T подряд: %v != 1.0", result)
}

@(test)
test_generic_enum_method_recursive :: proc(t: ^testing.T) {
	// Стадия 7 Phase E: метод на рекурсивном ADT (Дерево ссылается на
	// себя же в Узел) — generalize должен пройти сквозь cycle-guard
	// (Phase D) при обнаружении T в это: Дерево, не зациклившись.
	result, ok := run_code(`
		тип Дерево[T] = перечисление
			Лист(T)
			Узел(Дерево(T), T, Дерево(T))
		конец

		реализация Дерево
			функ корень(это: Дерево) -> T
				выбор это
					Лист(x) -> x
					Узел(_, x, _) -> x
				конец
			конец
		конец

		функ старт() -> Число
			пер д = Дерево.Узел(Дерево.Лист(1), 7, Дерево.Лист(3))
			д.корень()
		конец
	`)
	testing.expectf(t, ok, "generic enum method (рекурсивный): пустой стек")
	f, is_num := result.(f64)
	testing.expectf(t, is_num && f == 7.0, "generic enum method (рекурсивный): %v != 7.0", result)
}

@(test)
test_generic_interface_impl :: proc(t: ^testing.T) {
	// Стадия 7: реализация ИНТЕРФЕЙСА на generic-типе больше не
	// отклоняется (интерфейс сам не generic — см. заметку в ROADMAP
	// §Стадия 7). Просто объявление + вызов метода напрямую (без
	// полиморфизма через параметр интерфейсного типа — это отдельный
	// тест ниже, т.к. ловит другой баг).
	result, ok := run_code(`
		тип Печатаемый = интерфейс
			функ вСтроку() -> Строка
		конец

		тип Коробка[T] = структура
			значение: T
		конец

		реализация Печатаемый для Коробка
			функ вСтроку(это: Коробка) -> Строка
				"коробка"
			конец
		конец

		функ старт() -> Строка
			пер к = Коробка(5)
			к.вСтроку()
		конец
	`)
	testing.expectf(t, ok, "[generic-интерфейс: объявление] стек пуст")
	if ok {
		testing.expectf(
			t,
			value_str_eq(result, "коробка"),
			"[generic-интерфейс: объявление] ожидалось 'коробка', получено %v",
			result,
		)
	}
}

@(test)
test_generic_interface_polymorphic_use :: proc(t: ^testing.T) {
	// Ловит баг в instantiate_type: implemented_interfaces раньше был
	// пустым dynamic-array на КАЖДОЙ инстанциации generic-структуры
	// (не снимком шаблона), из-за чего передача Коробка(Число)-значения
	// в параметр интерфейсного типа Печатаемый молча проваливалась бы
	// на type mismatch, даже когда реализация интерфейса объявлена
	// корректно.
	result, ok := run_code(`
		тип Печатаемый = интерфейс
			функ вСтроку() -> Строка
		конец

		тип Коробка[T] = структура
			значение: T
		конец

		реализация Печатаемый для Коробка
			функ вСтроку(это: Коробка) -> Строка
				"коробка"
			конец
		конец

		функ показать(x: Печатаемый) -> Строка
			x.вСтроку()
		конец

		функ старт() -> Строка
			показать(Коробка(5))
		конец
	`)
	testing.expectf(t, ok, "[generic-интерфейс: полиморфное использование] стек пуст")
	if ok {
		testing.expectf(
			t,
			value_str_eq(result, "коробка"),
			"[generic-интерфейс: полиморфное использование] ожидалось 'коробка', получено %v",
			result,
		)
	}
}

@(test)
test_non_generic_struct_parenthesized_type_is_error :: proc(t: ^testing.T) {
	// Стадия 7 Phase C: resolve_type_node раньше не имел fallback для
	// нераспознанного Type_Generic-имени — Флаг(Число) на НЕ-generic
	// структуре Флаг молча стирался в Пусто (TY_VOID в конце функции),
	// компилировался без единой ошибки. Новая ветка чинит это заодно.
	diags := typecheck_only(`
		тип Флаг = структура
			имя: Строка
		конец

		функ плохо(x: Флаг(Число)) -> Пусто
		конец

		функ старт() -> Пусто
		конец
	`)
	expect_diagnostic(t, diags, "Type Error: 'Флаг' не является generic-типом")
}

@(test)
test_different_enums_are_incompatible :: proc(t: ^testing.T) {
	// Стадия 7 Phase D: unify_types/types_are_equal раньше не имели case
	// для .Enum вообще — свитч проваливался, функция возвращала true
	// БЕЗУСЛОВНО для любых двух разных enum-типов. Подтверждено живым
	// тестом до фикса: этот ровно этот исходник компилировался без единой
	// ошибки. Не связано с generics — предсуществующая дыра
	// типобезопасности, найдена и закрыта по пути к Phase D.
	diags := typecheck_only(`
		тип А = перечисление
			ВариантА
		конец

		тип Б = перечисление
			ВариантБ
		конец

		функ принимает_а(x: А) -> Пусто
		конец

		функ старт() -> Пусто
			принимает_а(Б.ВариантБ)
		конец
	`)
	expect_diagnostic(t, diags, "Type Error: ожидался 'А', получен 'Б'")
}

@(test)
test_math_and_logic :: proc(t: ^testing.T) {
	TestCase :: struct {
		name:     string,
		source:   string,
		expected: Value,
	}

	tests := []TestCase {
		{
			"Простая математика",
			"функ старт() -> Число  10 + 20 конец",
			f64(30.0),
		},
		{
			"Унарный минус",
			"функ старт() -> Число  -5 конец",
			f64(-5.0),
		},
		{"Логика", "функ старт() -> Булево истина конец", true},
		{
			"Сравнения <= и >=",
			`
			функ старт() -> Булево
				пер а = 5
				пер б = 5
				пер семь = 7
				пер р1 = а <= б
				пер р2 = а >= б
				пер р3 = не (семь <= а)
				пер р4 = семь >= а
				пер р5 = не (а <= 3)
				пер р6 = не (3 >= а)
				р1 и р2 и р3 и р4 и р5 и р6
			конец
		`,
			true,
		},
		{
			// Регрессия: '(' в начале statement'а (на новой строке после

	)
	testing.expectf(t, v.tag_index == 0, "US1 zero-field: tag_index %d != 0", v.tag_index)
	testing.expectf(t, len(v.fields) == 0, "US1 zero-field: fields не пустые (%d)", len(v.fields))
}


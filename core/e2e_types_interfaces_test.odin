#+build !js
package core

import "core:testing"

@(test)
test_method_own_type_param :: proc(t: ^testing.T) {
	// Стадия 7 Phase F: метод может иметь СОБСТВЕННЫЙ type-параметр,
	// даже когда владелец НЕ generic (Коробка здесь без [T]) — нужно для
	// Опция.результат_или[E](ошибка: E), E не входит в [T] Опции. Раньше
	// (Phase B/E) любой метод с [T] отклонялся парсером безусловно.
	result, ok := run_code(`
		тип Коробка = структура
			значение: Число
		конец

		реализация Коробка
			функ метод[T](это: Коробка, x: T) -> T
				x
			конец
		конец

		функ старт() -> Число
			пер к = Коробка(1)
			к.метод(42)
		конец
	`)
	testing.expectf(t, ok, "method own type param: пустой стек")
	f, is_num := result.(f64)
	testing.expectf(t, is_num && f == 42.0, "method own type param: %v != 42.0", result)
}

@(test)
test_generic_struct_method_call :: proc(t: ^testing.T) {
	// Стадия 7 Phase E: реализация методов на generic-структурах — раньше
	// (Phase C/D) отклонялась целиком, теперь работает. это: Коробка
	// (bare) резолвится в сам шаблонный тип, метод получает свою
	// Type_Scheme и инстанцируется заново на каждый вызов.
	result, ok := run_code(`
		тип Коробка[T] = структура
			значение: T
		конец

		реализация Коробка
			функ получить(это: Коробка) -> T
				это.значение
			конец
		конец

		функ старт() -> Число
			пер к = Коробка(42)
			к.получить()
		конец
	`)
	testing.expectf(t, ok, "generic-struct method call: пустой стек")
	f, is_num := result.(f64)
	testing.expectf(t, is_num && f == 42.0, "generic-struct method call: %v != 42.0", result)
}

@(test)
test_generic_method_no_cemented_type_param :: proc(t: ^testing.T) {
	// Стадия 7 Phase E: главный guard-тест — без своей Type_Scheme у
	// метода первый же вызов (a.получить(), T=Число) зацементировал бы
	// T шаблона навсегда через structural fallback в unify_types (Phase
	// D, generic_origin совпадает у это: Коробка и любой инстанциации).
	// Второй вызов с другим T (b.получить(), T=Строка) тогда падал бы
	// Type Error'ом, хотя код корректен.
	result, ok := run_code(`
		тип Коробка[T] = структура
			значение: T
		конец

		реализация Коробка
			функ получить(это: Коробка) -> T
				это.значение
			конец
		конец

		функ старт() -> Число
			пер a = Коробка(1)
			пер b = Коробка("текст")
			a.получить()
		конец
	`)
	testing.expectf(t, ok, "generic method, два T подряд: пустой стек")
	f, is_num := result.(f64)
	testing.expectf(t, is_num && f == 1.0, "generic method, два T подряд: %v != 1.0", result)
}

@(test)
test_generic_enum_method_recursive :: proc(t: ^testing.T) {
	// Стадия 7 Phase E: метод на рекурсивном ADT (Дерево ссылается на
	// себя же в Узел) — generalize должен пройти сквозь cycle-guard
	// (Phase D) при обнаружении T в это: Дерево, не зациклившись.
	result, ok := run_code(`
		тип Дерево[T] = перечисление
			Лист(T)
			Узел(Дерево(T), T, Дерево(T))
		конец

		реализация Дерево
			функ корень(это: Дерево) -> T
				выбор это
					Лист(x) -> x
					Узел(_, x, _) -> x
				конец
			конец
		конец

		функ старт() -> Число
			пер д = Дерево.Узел(Дерево.Лист(1), 7, Дерево.Лист(3))
			д.корень()
		конец
	`)
	testing.expectf(t, ok, "generic enum method (рекурсивный): пустой стек")
	f, is_num := result.(f64)
	testing.expectf(t, is_num && f == 7.0, "generic enum method (рекурсивный): %v != 7.0", result)
}

@(test)
test_generic_interface_impl :: proc(t: ^testing.T) {
	// Стадия 7: реализация ИНТЕРФЕЙСА на generic-типе больше не
	// отклоняется (интерфейс сам не generic — см. заметку в ROADMAP
	// §Стадия 7). Просто объявление + вызов метода напрямую (без
	// полиморфизма через параметр интерфейсного типа — это отдельный
	// тест ниже, т.к. ловит другой баг).
	result, ok := run_code(`
		тип Печатаемый = интерфейс
			функ вСтроку() -> Строка
		конец

		тип Коробка[T] = структура
			значение: T
		конец

		реализация Печатаемый для Коробка
			функ вСтроку(это: Коробка) -> Строка
				"коробка"
			конец
		конец

		функ старт() -> Строка
			пер к = Коробка(5)
			к.вСтроку()
		конец
	`)
	testing.expectf(t, ok, "[generic-интерфейс: объявление] стек пуст")
	if ok {
		testing.expectf(
			t,
			value_str_eq(result, "коробка"),
			"[generic-интерфейс: объявление] ожидалось 'коробка', получено %v",
			result,
		)
	}
}

@(test)
test_generic_interface_polymorphic_use :: proc(t: ^testing.T) {
	// Ловит баг в instantiate_type: implemented_interfaces раньше был
	// пустым dynamic-array на КАЖДОЙ инстанциации generic-структуры
	// (не снимком шаблона), из-за чего передача Коробка(Число)-значения
	// в параметр интерфейсного типа Печатаемый молча проваливалась бы
	// на type mismatch, даже когда реализация интерфейса объявлена
	// корректно.
	result, ok := run_code(`
		тип Печатаемый = интерфейс
			функ вСтроку() -> Строка
		конец

		тип Коробка[T] = структура
			значение: T
		конец

		реализация Печатаемый для Коробка
			функ вСтроку(это: Коробка) -> Строка
				"коробка"
			конец
		конец

		функ показать(x: Печатаемый) -> Строка
			x.вСтроку()
		конец

		функ старт() -> Строка
			показать(Коробка(5))
		конец
	`)
	testing.expectf(t, ok, "[generic-интерфейс: полиморфное использование] стек пуст")
	if ok {
		testing.expectf(
			t,
			value_str_eq(result, "коробка"),
			"[generic-интерфейс: полиморфное использование] ожидалось 'коробка', получено %v",
			result,
		)
	}
}

@(test)
test_non_generic_struct_parenthesized_type_is_error :: proc(t: ^testing.T) {
	// Стадия 7 Phase C: resolve_type_node раньше не имел fallback для
	// нераспознанного Type_Generic-имени — Флаг(Число) на НЕ-generic
	// структуре Флаг молча стирался в Пусто (TY_VOID в конце функции),
	// компилировался без единой ошибки. Новая ветка чинит это заодно.
	diags := typecheck_only(`
		тип Флаг = структура
			имя: Строка
		конец

		функ плохо(x: Флаг(Число)) -> Пусто
		конец

		функ старт() -> Пусто
		конец
	`)
	expect_diagnostic(t, diags, "Type Error: 'Флаг' не является generic-типом")
}

@(test)
test_different_enums_are_incompatible :: proc(t: ^testing.T) {
	// Стадия 7 Phase D: unify_types/types_are_equal раньше не имели case
	// для .Enum вообще — свитч проваливался, функция возвращала true
	// БЕЗУСЛОВНО для любых двух разных enum-типов. Подтверждено живым
	// тестом до фикса: этот ровно этот исходник компилировался без единой
	// ошибки. Не связано с generics — предсуществующая дыра
	// типобезопасности, найдена и закрыта по пути к Phase D.
	diags := typecheck_only(`
		тип А = перечисление
			ВариантА
		конец

		тип Б = перечисление
			ВариантБ
		конец

		функ принимает_а(x: А) -> Пусто
		конец

		функ старт() -> Пусто
			принимает_а(Б.ВариантБ)
		конец
	`)
	expect_diagnostic(t, diags, "Type Error: ожидался 'А', получен 'Б'")
}

// Стадия 22: реализация Сравниваемое даёт </>/<=/>= структуре напрямую —
// sugar резолвится в вызов сравнить() на этапе typecheck/compile, не новый
// рантайм-механизм (см. ROADMAP §Стадия 22).
@(test)
test_comparable_interface_gives_ord_operators :: proc(t: ^testing.T) {
	result, ok := run_code(`
		тип Точка = структура
			x: Число
		конец

		реализация Сравниваемое для Точка
			функ сравнить(это: Точка, другое: Точка) -> Число
				это.x - другое.x
			конец
		конец

		функ старт() -> Булево
			пер а = Точка(5)
			пер б = Точка(3)
			пер третья = Точка(5)

			(а < б) == ложь и (а > б) == истина и (а <= третья) == истина и (а >= б) == истина и (б >= а) == ложь
		конец
	`)
	testing.expectf(t, ok, "[Сравниваемое Ord] стек пуст")
	b, is_bool := result.(bool)
	testing.expectf(t, is_bool && b, "[Сравниваемое Ord] ожидалось true, получено %v", result)
}

// Self-фикс отдельно: сравнить() реально ЧИТАЕТ поля через параметр,
// типизированный в объявлении интерфейса КАК САМ ИНТЕРФЕЙС (другое:
// Сравниваемое) — не только typecheck проходит, а исполнение подтверждает,
// что impl получает конкретный Точка, а не интерфейсную заглушку без полей.
@(test)
test_comparable_self_type_gives_field_access :: proc(t: ^testing.T) {
	result, ok := run_code(`
		тип Точка = структура
			x: Число
			y: Число
		конец

		реализация Сравниваемое для Точка
			функ сравнить(это: Точка, другое: Точка) -> Число
				(это.x + это.y) - (другое.x + другое.y)
			конец
		конец

		функ старт() -> Число
			пер а = Точка(3, 4)
			пер б = Точка(1, 1)
			а.сравнить(б)
		конец
	`)
	testing.expectf(t, ok, "[Self-тип field access] стек пуст")
	if ok {
		n, is_num := result.(f64)
		testing.expectf(t, is_num && n == 5, "[Self-тип field access] ожидалось 5, получено %v", result)
	}
}

// Негативный кейс: структура БЕЗ реализация Сравниваемое — `<` должен
// давать понятную diagnostic (старый numeric-путь), не крэш и не
// молчаливый фоллбэк на что-то неожиданное.
@(test)
test_non_comparable_struct_less_is_error :: proc(t: ^testing.T) {
	diags := typecheck_only(`
		тип БезСравниваемое = структура
			x: Число
		конец

		функ старт() -> Булево
			пер а = БезСравниваемое(1)
			пер б = БезСравниваемое(2)
			а < б
		конец
	`)
	expect_diagnostic(t, diags, "Type Error: ожидался 'Число', получен 'БезСравниваемое'")
}

// Grilled (Стадия 22): сравнение ДВУХ РАЗНЫХ Сравниваемых типов (или
// Сравниваемого с Число) даёт ТОЧНОЕ сообщение "реализует Сравниваемое, но
// не с типом X" — не вводящее в заблуждение старое "ожидал Число"
// (структура-то как раз сравнимая, просто не с ЭТИМ операндом).
@(test)
test_comparable_mismatched_types_gives_precise_diagnostic :: proc(t: ^testing.T) {
	diags := typecheck_only(`
		тип Точка = структура
			x: Число
		конец

		тип Линия = структура
			длина: Число
		конец

		реализация Сравниваемое для Точка
			функ сравнить(это: Точка, другое: Точка) -> Число
				это.x
			конец
		конец

		реализация Сравниваемое для Линия
			функ сравнить(это: Линия, другое: Линия) -> Число
				это.длина
			конец
		конец

		функ старт() -> Булево
			пер а = Точка(1)
			пер б = Линия(2)
			а < б
		конец
	`)
	expect_diagnostic(t, diags, "Type Error: тип 'Точка' реализует Сравниваемое, но не с типом 'Линия'")
}

// Равнозначное — opt-in override: структура С impl'ом использует свой
// равно() (сравнение по одному полю), НЕ структурное сравнение всех полей.
@(test)
test_equatable_interface_overrides_structural_equality :: proc(t: ^testing.T) {
	result, ok := run_code(`
		тип ПоИдентификатору = структура
			id: Число
			данные: Число
		конец

		реализация Равнозначное для ПоИдентификатору
			функ равно(это: ПоИдентификатору, другое: ПоИдентификатору) -> Булево
				это.id == другое.id
			конец
		конец

		функ старт() -> Булево
			пер а = ПоИдентификатору(1, 100)
			пер б = ПоИдентификатору(1, 999)
			пер третья = ПоИдентификатору(2, 100)

			(а == б) == истина и (а == третья) == ложь и (а <> б) == ложь
		конец
	`)
	testing.expectf(t, ok, "[Равнозначное override] стек пуст")
	b, is_bool := result.(bool)
	testing.expectf(t, is_bool && b, "[Равнозначное override] ожидалось true, получено %v", result)
}

// Найдено при отладке Стадии 22 (не её баг, предсуществующий): вызов
// ЭКСПОРТИРОВАННОЙ generic-функции ЧЕРЕЗ АЛИАС МОДУЛЯ (либ.применить_ко_
// всем(...)) не инстанцировал T заново — infer_call_expr's Property_Expr-
// ветка использовала общий, не-инстанцированный export_type напрямую, в
// отличие от same-file вызова (infer_ident_expr, который уже инстанцирует
// через symbol_schemes). Симптом: "попытка получить поле у не-структуры" на
// результате, потому что T = ^Aggregate не резолвился корректно после
// возврата из вызова. Requires run_module_file (не run_code) — баг
// специфичен именно для МЕЖМОДУЛЬНОГО вызова, single-file inline-pipeline
// его не воспроизводит. Фикс: Module_Graph.symbol_schemes — накапливается
// в resolve_and_typecheck_all (module_loader.odin) после каждого модуля,
// раздаётся следующим через new_type_ctx, infer_call_expr инстанцирует
// схему тем же instantiate_scheme, что и same-file путь.
@(test)
test_generic_function_called_across_module_boundary_instantiates_fresh :: proc(t: ^testing.T) {
	result, ok := run_module_file("fixtures/generic_cross_module_fixture_main.ps")
	testing.expectf(t, ok, "[cross-module generic] стек пуст")
	b, is_bool := result.(bool)
	testing.expectf(t, is_bool && b, "[cross-module generic] ожидалось true, получено %v", result)
}

// Стадия 23: 4 раздельных интерфейса (Складываемое/Вычитаемое/Умножаемое/
// Делимое) — один struct реализует все 4, покрывает и Self-параметр, и
// Self-ВОЗВРАТ (сложить возвращает Вектор, не Число — в отличие от
// сравнить/равно из Стадии 22, которые всегда возвращают примитив).
@(test)
test_arithmetic_interfaces_give_operator_sugar :: proc(t: ^testing.T) {
	result, ok := run_code(`
		тип Вектор = структура
			x: Число
			y: Число
		конец

		реализация Складываемое для Вектор
			функ сложить(это: Вектор, другое: Вектор) -> Вектор
				Вектор(это.x + другое.x, это.y + другое.y)
			конец
		конец

		реализация Вычитаемое для Вектор
			функ вычесть(это: Вектор, другое: Вектор) -> Вектор
				Вектор(это.x - другое.x, это.y - другое.y)
			конец
		конец

		реализация Умножаемое для Вектор
			функ умножить(это: Вектор, другое: Вектор) -> Вектор
				Вектор(это.x * другое.x, это.y * другое.y)
			конец
		конец

		реализация Делимое для Вектор
			функ разделить(это: Вектор, другое: Вектор) -> Вектор
				Вектор(это.x / другое.x, это.y / другое.y)
			конец
		конец

		функ старт() -> Булево
			пер а = Вектор(6, 8)
			пер б = Вектор(2, 4)

			пер сумма = а + б
			пер разность = а - б
			пер произведение = а * б
			пер частное = а / б

			сумма.x == 8 и сумма.y == 12 и
				разность.x == 4 и разность.y == 4 и
				произведение.x == 12 и произведение.y == 32 и
				частное.x == 3 и частное.y == 2
		конец
	`)
	testing.expectf(t, ok, "[Арифметика sugar] стек пуст")
	b, is_bool := result.(bool)
	testing.expectf(t, is_bool && b, "[Арифметика sugar] ожидалось true, получено %v", result)
}

// Негативный кейс: структура БЕЗ реализация Складываемое — `+` должен
// падать в старый путь (Число+Число/Строка+Строка) с прежней diagnostic,
// не крэшить и не молчаливо провалиться в sugar.
@(test)
test_non_addable_struct_plus_is_error :: proc(t: ^testing.T) {
	diags := typecheck_only(`
		тип БезСкладываемого = структура
			x: Число
		конец

		функ старт() -> БезСкладываемого
			пер а = БезСкладываемого(1)
			пер б = БезСкладываемого(2)
			а + б
		конец
	`)
	expect_diagnostic(t, diags, "Type Error: оператор '+' ожидает два числа или две строки, получено 'БезСкладываемого' и 'БезСкладываемого'")
}

// Grilled (Стадия 22, тот же принцип для Стадии 23): сложение ДВУХ РАЗНЫХ
// Складываемых типов даёт ТОЧНОЕ сообщение "реализует Складываемое, но не
// с типом X" — не вводящее в заблуждение "ожидает два числа или две
// строки" (структура-то как раз складываемая, просто не с ЭТИМ операндом).
@(test)
test_addable_mismatched_types_gives_precise_diagnostic :: proc(t: ^testing.T) {
	diags := typecheck_only(`
		тип Вектор = структура
			x: Число
		конец

		тип Точка = структура
			x: Число
		конец

		реализация Складываемое для Вектор
			функ сложить(это: Вектор, другое: Вектор) -> Вектор
				это
			конец
		конец

		реализация Складываемое для Точка
			функ сложить(это: Точка, другое: Точка) -> Точка
				это
			конец
		конец

		функ старт() -> Вектор
			пер а = Вектор(1)
			пер б = Точка(2)
			а + б
		конец
	`)
	expect_diagnostic(t, diags, "Type Error: тип 'Вектор' реализует Складываемое, но не с типом 'Точка'")
}

// Минус/умножить/делить используют ТОТ ЖЕ infer_arithmetic_op, что и
// Складываемое — по одному smoke-тесту на каждый, чтобы подтвердить
// правильную привязку iface_sym/method_name (не перепутаны местами).
@(test)
test_subtractable_wrong_method_not_confused_with_addable :: proc(t: ^testing.T) {
	diags := typecheck_only(`
		тип БезВычитаемого = структура
			x: Число
		конец

		функ старт() -> БезВычитаемого
			пер а = БезВычитаемого(1)
			пер б = БезВычитаемого(2)
			а - б
		конец
	`)
	expect_diagnostic(t, diags, "Type Error: ожидался 'Число', получен 'БезВычитаемого'")
}

// Стадия 23 (Печатаемое): struct с реализация Печатаемое — печать() зовёт
// .вСтроку() (Print_Value codegen: push fn, компиляция receiver'а, .Call 1,
// РЕЗУЛЬТАТ передаётся в реальный builtin через Call_Builtin), а не
// structural dump.
@(test)
test_printable_interface_used_by_print :: proc(t: ^testing.T) {
	_, ok, output := run_code_capture_stdout(`
		импорт ввод_вывод
		импорт строки

		тип Точка = структура
			x: Число
			y: Число
		конец

		реализация Печатаемое для Точка
			функ вСтроку(это: Точка) -> Строка
				"Точка(" + строки.из_числа(это.x) + ", " + строки.из_числа(это.y) + ")"
			конец
		конец

		функ старт() -> Число
			ввод_вывод.печать(Точка(3, 4))
			0
		конец
	`)
	testing.expectf(t, ok, "[Печатаемое: печать] стек пуст")
	testing.expectf(t, output == "Точка(3, 4)", "[Печатаемое: печать] ожидалось 'Точка(3, 4)', получено %q", output)
}

// Негативный/дефолтный кейс: struct БЕЗ реализация Печатаемое — печать()
// падает в structural dump (value_to_display_string, vm.odin) — позиционный
// дамп полей БЕЗ имени типа (рантайм не хранит RTTI для Aggregate_Value).
@(test)
test_non_printable_struct_falls_back_to_structural_dump :: proc(t: ^testing.T) {
	_, ok, output := run_code_capture_stdout(`
		импорт ввод_вывод

		тип Точка = структура
			x: Число
			y: Число
		конец

		функ старт() -> Число
			ввод_вывод.печать(Точка(3, 4))
			0
		конец
	`)
	testing.expectf(t, ok, "[Печатаемое: fallback] стек пуст")
	testing.expectf(t, output == "(3, 4)", "[Печатаемое: fallback] ожидалось '(3, 4)', получено %q", output)
}

// value_to_display_string покрывает Число/Булево/Массив/Соответствие/
// Опция/Результат — smoke-тест на каждый, чтобы формат не сломался молча.
@(test)
test_value_to_display_string_covers_primitives_and_collections :: proc(t: ^testing.T) {
	_, ok, output := run_code_capture_stdout(`
		импорт ввод_вывод

		функ старт() -> Число
			ввод_вывод.печать(истина)
			ввод_вывод.печать(42)
			ввод_вывод.печать(массив(1, 2, 3))
			0
		конец
	`)
	testing.expectf(t, ok, "[value_to_display_string] стек пуст")
	testing.expectf(
		t,
		output == "истина42[1, 2, 3]",
		"[value_to_display_string] ожидалось 'истина42[1, 2, 3]', получено %q",
		output,
	)
}

// Стадия 23 (Копируемое): .клонировать() — обычный прямой вызов метода
// (НЕ operator sugar, в отличие от Сравниваемое/Равнозначное/Арифметики)
// — работает через уже существующий generic interface-dispatch (Стадия
// 6) без единой строчки нового кода в type_cheker.odin/compiler.odin.
// Мутация через клон НЕ видна в оригинале — структуры reference
// semantics по умолчанию (b = a аліасит), клонировать() даёт настоящую
// независимую копию через Build_Aggregate (новая куча-аллокация).
@(test)
test_copyable_clone_gives_independent_copy :: proc(t: ^testing.T) {
	result, ok := run_code(`
		тип Точка = структура
			x: Число
			y: Число
		конец

		реализация Копируемое для Точка
			функ клонировать(это: Точка) -> Точка
				Точка(это.x, это.y)
			конец
		конец

		функ старт() -> Число
			пер a = Точка(1, 2)
			пер b = a.клонировать()
			b.x = 99
			a.x
		конец
	`)
	testing.expectf(t, ok, "[Копируемое: независимая копия] стек пуст")
	n, is_num := result.(f64)
	testing.expectf(t, is_num && n == 1, "[Копируемое: независимая копия] ожидалось 1, получено %v", result)
}

// Глубокая копия НЕ auto-derive (как и у всех прочих интерфейсов, тело
// метода пишется руками) — чтобы клон вложенной структуры тоже был
// независимым, тело обязано САМО рекурсивно звать .клонировать() на
// вложенном поле, не просто скопировать его как есть.
@(test)
test_copyable_nested_struct_requires_recursive_clone_call :: proc(t: ^testing.T) {
	result, ok := run_code(`
		тип Точка = структура
			x: Число
			y: Число
		конец

		реализация Копируемое для Точка
			функ клонировать(это: Точка) -> Точка
				Точка(это.x, это.y)
			конец
		конец

		тип Отрезок = структура
			начало: Точка
			конец_: Точка
		конец

		реализация Копируемое для Отрезок
			функ клонировать(это: Отрезок) -> Отрезок
				Отрезок(это.начало.клонировать(), это.конец_.клонировать())
			конец
		конец

		функ старт() -> Число
			пер a = Отрезок(Точка(1, 2), Точка(3, 4))
			пер b = a.клонировать()
			b.начало.x = 99
			a.начало.x
		конец
	`)
	testing.expectf(t, ok, "[Копируемое: вложенная структура] стек пуст")
	n, is_num := result.(f64)
	testing.expectf(t, is_num && n == 1, "[Копируемое: вложенная структура] ожидалось 1, получено %v", result)
}

// Стадия 28 (generic-интерфейсы, prerequisite Итерируемого): T в методе
// интерфейса — независимый параметр, не Self (Self-фикс Стадии 22/23 тут
// не участвует). Базовый случай: одна реализация, T конкретизирован
// (Опция(Число)) — подтверждает, что resolve_type_node видит T через
// ctx.current_type_params так же, как поле generic-структуры.
@(test)
test_generic_interface_single_impl_concrete_element_type :: proc(t: ^testing.T) {
	result, ok := run_code(`
		тип Итератор[T] = интерфейс
			функ следующий() -> Опция(T)
		конец

		тип СчётчикДо3 = структура
			значение: Число
		конец

		реализация Итератор для СчётчикДо3
			функ следующий(это: СчётчикДо3) -> Опция(Число)
				если это.значение < 3 тогда
					Опция.Есть(это.значение)
				иначе
					Опция.Нет()
				конец
			конец
		конец

		функ старт() -> Число
			пер с = СчётчикДо3(1)
			выбор с.следующий()
				Есть(x) -> x
				Нет -> -1
			конец
		конец
	`)
	testing.expectf(t, ok, "[generic-интерфейс: одна реализация] стек пуст")
	n, is_num := result.(f64)
	testing.expectf(t, is_num && n == 1, "[generic-интерфейс: одна реализация] ожидалось 1, получено %v", result)
}

// Ключевой regression-тест: T НЕ должен "цементироваться" первым же impl'ом
// для всех последующих. Без свежей InferVar на T при каждой проверке
// контракта (см. ПРОХОД 3, type_cheker.odin) второй impl с другим T либо
// молча взял бы T первого, либо упал бы с ложной ошибкой несовпадения.
@(test)
test_generic_interface_two_impls_do_not_share_element_type :: proc(t: ^testing.T) {
	result, ok := run_code(`
		тип Итератор[T] = интерфейс
			функ следующий() -> Опция(T)
		конец

		тип СчётчикЧисел = структура
			значение: Число
		конец

		реализация Итератор для СчётчикЧисел
			функ следующий(это: СчётчикЧисел) -> Опция(Число)
				Опция.Есть(это.значение)
			конец
		конец

		тип СчётчикСтрок = структура
			значение: Строка
		конец

		реализация Итератор для СчётчикСтрок
			функ следующий(это: СчётчикСтрок) -> Опция(Строка)
				Опция.Есть(это.значение)
			конец
		конец

		функ старт() -> Строка
			пер а = СчётчикЧисел(42)
			пер б = СчётчикСтрок("привет")
			выбор а.следующий()
				Есть(_) -> 0
				Нет -> 0
			конец
			выбор б.следующий()
				Есть(s) -> s
				Нет -> "?"
			конец
		конец
	`)
	testing.expectf(t, ok, "[generic-интерфейс: два impl, разные T] стек пуст")
	testing.expectf(
		t,
		value_str_eq(result, "привет"),
		"[generic-интерфейс: два impl, разные T] ожидалось 'привет', получено %v",
		result,
	)
}

// Негативный кейс: impl нарушает форму контракта (возвращает Строка
// напрямую вместо Опция(T)) — unify_types (заменил types_are_equal в
// interface_method_types_match для Стадии 28) должен ловить структурное
// несовпадение kind (Enum vs String) так же строго, как раньше
// types_are_equal ловил конкретные типы.
@(test)
test_generic_interface_wrong_return_shape_is_error :: proc(t: ^testing.T) {
	diags := typecheck_only(`
		тип Итератор[T] = интерфейс
			функ следующий() -> Опция(T)
		конец

		тип Сломанный = структура
			значение: Число
		конец

		реализация Итератор для Сломанный
			функ следующий(это: Сломанный) -> Строка
				"не Опция"
			конец
		конец

		функ старт() -> Число
			0
		конец
	`)
	expect_diagnostic(t, diags, "Type Error: метод 'следующий' структуры 'Сломанный' не совпадает с контрактом интерфейса 'Итератор'")
}

// Стадия 23 (Итерируемое): iterator protocol — для-in на структуре с
// реализация Итерируемое зовёт .следующий() повторно, пока не придёт
// Нет (Iterator_Protocol codegen, compiler.odin). Мутация состояния
// (это.текущее = ...) внутри следующий() видна на следующей итерации —
// это: Т immutable БИНДИНГ (Стадия 27), но поле через это.поле = ...
// мутируемо (reference semantics), контейнер сам себе итератор.
@(test)
test_iterable_interface_drives_for_in_loop :: proc(t: ^testing.T) {
	result, ok := run_code(`
		тип СчётчикДо = структура
			текущее: Число
			предел: Число
		конец

		реализация Итерируемое для СчётчикДо
			функ следующий(это: СчётчикДо) -> Опция(Число)
				если это.текущее >= это.предел тогда
					Опция.Нет()
				иначе
					это.текущее = это.текущее + 1
					Опция.Есть(это.текущее)
				конец
			конец
		конец

		функ старт() -> Число
			пер сч = СчётчикДо(0, 5)
			пер сумма = 0
			для x в сч цикл
				сумма = сумма + x
			конец
			сумма
		конец
	`)
	testing.expectf(t, ok, "[Итерируемое: for-in] стек пуст")
	n, is_num := result.(f64)
	testing.expectf(t, is_num && n == 15, "[Итерируемое: for-in] ожидалось 15 (1+2+3+4+5), получено %v", result)
}

// прервать/продолжить внутри iterator-protocol for-in работают через тот
// же Loop_Context, что fast-path и While_Expr — regression на то, что
// compile_for_in_stmt корректно push/pop'ит ctx.loops.
@(test)
test_iterable_interface_break_and_continue :: proc(t: ^testing.T) {
	result, ok := run_code(`
		тип СчётчикДо = структура
			текущее: Число
			предел: Число
		конец

		реализация Итерируемое для СчётчикДо
			функ следующий(это: СчётчикДо) -> Опция(Число)
				если это.текущее >= это.предел тогда
					Опция.Нет()
				иначе
					это.текущее = это.текущее + 1
					Опция.Есть(это.текущее)
				конец
			конец
		конец

		функ старт() -> Число
			пер сч = СчётчикДо(0, 10)
			пер сумма = 0
			для x в сч цикл
				если x == 4 тогда
					продолжить
				конец
				если x == 7 тогда
					прервать
				конец
				сумма = сумма + x
			конец
			сумма
		конец
	`)
	testing.expectf(t, ok, "[Итерируемое: break/continue] стек пуст")
	n, is_num := result.(f64)
	// 1+2+3+5+6 = 17 (4 пропущен через продолжить, 7 обрывает цикл через прервать)
	testing.expectf(t, is_num && n == 17, "[Итерируемое: break/continue] ожидалось 17, получено %v", result)
}

// Негативный кейс: struct БЕЗ реализация Итерируемое даёт понятную
// diagnostic, не крэш.
@(test)
test_non_iterable_struct_for_in_is_error :: proc(t: ^testing.T) {
	diags := typecheck_only(`
		тип НеИтерируемое = структура
			x: Число
		конец

		функ старт() -> Число
			пер н = НеИтерируемое(1)
			для x в н цикл
				x
			конец
			0
		конец
	`)
	expect_diagnostic(t, diags, "Type Error: тип 'НеИтерируемое' не поддерживает 'для x в' (нужен Массив или тип, реализующий Итерируемое)")
}

// T интерфейса Итерируемое может быть туплом — "для (a, b, c) в ..."
// деструктурирует значение Есть(...) тем же способом, что fast-path уже
// делает для Массив((К,З)). Найдено пользовательским вопросом ("что если
// вернуть не число, а тупл из 3 значений?") — изначальная реализация
// искусственно запрещала len(names) > 1 для Iterator_Protocol, хотя T
// как тупл уже типизировался бы корректно (unify_types не ограничивает
// T каким-либо конкретным kind).
@(test)
test_iterable_tuple_element_type_destructures :: proc(t: ^testing.T) {
	result, ok := run_code(`
		тип Тройки = структура
			n: Число
		конец

		реализация Итерируемое для Тройки
			функ следующий(это: Тройки) -> Опция((Число, Число, Число))
				если это.n >= 2 тогда
					Опция.Нет()
				иначе
					это.n = это.n + 1
					Опция.Есть((это.n, это.n * 10, это.n * 100))
				конец
			конец
		конец

		функ старт() -> Число
			пер т = Тройки(0)
			пер сумма = 0
			для (a, b, c) в т цикл
				сумма = сумма + a + b + c
			конец
			сумма
		конец
	`)
	testing.expectf(t, ok, "[Итерируемое: tuple-деструктуризация] стек пуст")
	n, is_num := result.(f64)
	// (1+10+100) + (2+20+200) = 111 + 222 = 333
	testing.expectf(t, is_num && n == 333, "[Итерируемое: tuple-деструктуризация] ожидалось 333, получено %v", result)
}

// T интерфейса Итерируемое может быть ЛЮБЫМ типом, включая struct —
// unify_types (Стадия 28) не ограничивает kind T, только связывает его с
// тем, что фактически вернул impl. Проверено пользовательским вопросом
// ("а если структура/adt?") аналогично tuple-кейсу выше.
@(test)
test_iterable_struct_element_type :: proc(t: ^testing.T) {
	result, ok := run_code(`
		тип Точка = структура
			x: Число
			y: Число
		конец

		тип ГенераторТочек = структура
			n: Число
		конец

		реализация Итерируемое для ГенераторТочек
			функ следующий(это: ГенераторТочек) -> Опция(Точка)
				если это.n >= 3 тогда
					Опция.Нет()
				иначе
					это.n = это.n + 1
					Опция.Есть(Точка(это.n, это.n * 2))
				конец
			конец
		конец

		функ старт() -> Число
			пер г = ГенераторТочек(0)
			пер сумма = 0
			для p в г цикл
				сумма = сумма + p.x + p.y
			конец
			сумма
		конец
	`)
	testing.expectf(t, ok, "[Итерируемое: struct-элемент] стек пуст")
	n, is_num := result.(f64)
	// (1+2) + (2+4) + (3+6) = 3+6+9 = 18
	testing.expectf(t, is_num && n == 18, "[Итерируемое: struct-элемент] ожидалось 18, получено %v", result)
}

// T тоже может быть пользовательским ADT (перечислением) — значение из
// Есть(x) деструктурируется внутри тела обычным `выбор`, никакого
// спецкейса не нужно (x — просто обычное значение типа Событие).
@(test)
test_iterable_adt_element_type :: proc(t: ^testing.T) {
	result, ok := run_code(`
		тип Событие = перечисление
			Начало
			Данные(Число)
			Конец
		конец

		тип ПотокСобытий = структура
			n: Число
		конец

		реализация Итерируемое для ПотокСобытий
			функ следующий(это: ПотокСобытий) -> Опция(Событие)
				если это.n == 0 тогда
					это.n = 1
					Опция.Есть(Событие.Начало)
				иначе
					если это.n == 1 тогда
						это.n = 2
						Опция.Есть(Событие.Данные(42))
					иначе
						Опция.Нет()
					конец
				конец
			конец
		конец

		функ старт() -> Число
			пер поток = ПотокСобытий(0)
			пер счётчик = 0
			для e в поток цикл
				выбор e
					Начало -> счётчик = счётчик + 1
					Данные(v) -> счётчик = счётчик + v
					Конец -> счётчик = счётчик + 100
				конец
			конец
			счётчик
		конец
	`)
	testing.expectf(t, ok, "[Итерируемое: ADT-элемент] стек пуст")
	n, is_num := result.(f64)
	testing.expectf(t, is_num && n == 43, "[Итерируемое: ADT-элемент] ожидалось 43 (1+42), получено %v", result)
}

// Стадия 25: ключевой мотивирующий пример из ROADMAP §Стадия 25 —
// Сравниваемое для generic-enum'а Опция(T) (прелюдия, не пользовательский
// тип). Опция.Нет() — нулевой-payload вариант, T не выводится из самого
// значения — вскрыл отдельный баг: sugar-проверка "тот же ли тип"
// использовала == (указатель) вместо unify_types, ложно отвергая
// сравнение с ещё-не-связанным T. Исправлено вместе с этой стадией
// (infer_arithmetic_sugar/Equal-ветка тоже используют unify_types теперь).
@(test)
test_option_implements_comparable_including_nullary_variant :: proc(t: ^testing.T) {
	result, ok := run_code(`
		реализация Сравниваемое для Опция
			функ сравнить(это: Опция, другое: Опция) -> Число
				выбор это
					Есть(x) ->
						выбор другое
							Есть(y) -> x - y
							Нет -> 1
						конец
					Нет ->
						выбор другое
							Есть(_) -> -1
							Нет -> 0
						конец
				конец
			конец
		конец

		функ старт() -> Булево
			(Опция.Есть(5) < Опция.Есть(10)) и (Опция.Нет() < Опция.Есть(1))
		конец
	`)
	testing.expectf(t, ok, "[Стадия 25: Опция реализует Сравниваемое] стек пуст")
	b, is_bool := result.(bool)
	testing.expectf(t, is_bool && b, "[Стадия 25: Опция реализует Сравниваемое] ожидалось true, получено %v", result)
}

// Bounded traits: `функ f[T: Сравниваемое](...)` — мономорфизация.
// Один и тот же generic-тело вызывается с Число (fallback на нативный
// хардкод `<`/`>`, см. primitive_satisfies_interface — Число НЕ
// регистрирует implemented_interfaces) И со структурой с явной
// `реализация Сравниваемое` (настоящий sugar-путь) — оба должны
// компилироваться в РАЗНЫЕ Compiled_Function под разными ключами
// (core/monomorphize.odin) и давать корректный результат независимо.
@(test)
test_bounded_generic_max_works_with_primitive_and_struct :: proc(t: ^testing.T) {
	result, ok := run_code(`
		тип Точка = структура
			x: Число
		конец

		реализация Сравниваемое для Точка
			функ сравнить(это: Точка, другое: Точка) -> Число
				это.x - другое.x
			конец
		конец

		функ max[T: Сравниваемое](a: T, b: T) -> T
			если a > b тогда a иначе b конец
		конец

		функ старт() -> Булево
			пер число_результат = max(3.0, 7.0)
			пер п1 = Точка(1)
			пер п2 = Точка(2)
			пер структ_результат = max(п1, п2)
			число_результат == 7.0 и структ_результат.x == 2
		конец
	`)
	testing.expectf(t, ok, "[bounded traits: max] стек пуст")
	b, is_bool := result.(bool)
	testing.expectf(t, is_bool && b, "[bounded traits: max] ожидалось true, получено %v", result)
}

// Негативный кейс: вызов bounded generic-функции с типом, НЕ реализующим
// требуемый интерфейс, — Type Error на call site, не крэш компилятора.
@(test)
test_bounded_generic_call_without_impl_is_error :: proc(t: ^testing.T) {
	diags := typecheck_only(`
		тип БезСравниваемое = структура
			x: Число
		конец

		функ f[T: Сравниваемое](a: T) -> T
			a
		конец

		функ старт() -> БезСравниваемое
			пер б = БезСравниваемое(1)
			f(б)
		конец
	`)
	expect_diagnostic(t, diags, "Type Error: тип 'БезСравниваемое' не реализует 'Сравниваемое', требуется для type-параметра 'T' функции 'f'")
}

// Multi-bound через `+`: тип реализует ТОЛЬКО один из двух требуемых
// интерфейсов — Type Error, называющий конкретно недостающий.
@(test)
test_bounded_generic_multi_bound_missing_one_interface_is_error :: proc(t: ^testing.T) {
	diags := typecheck_only(`
		тип Точка = структура
			x: Число
		конец

		реализация Сравниваемое для Точка
			функ сравнить(это: Точка, другое: Точка) -> Число
				это.x - другое.x
			конец
		конец

		функ f[T: Сравниваемое + Печатаемое](a: T) -> T
			a
		конец

		функ старт() -> Точка
			пер п = Точка(1)
			f(п)
		конец
	`)
	expect_diagnostic(t, diags, "Type Error: тип 'Точка' не реализует 'Печатаемое', требуется для type-параметра 'T' функции 'f'")
}

// Рекурсивный generic с bound — вызов f(a, b, depth-1) внутри ТЕЛА самой
// f[T: Сравниваемое] обязан работать: абстрактный typecheck тела САМОЙ
// f не может вывести конкретный T для этого внутреннего вызова (T ещё
// decl-param InferVar) — ctx.in_abstract_generic_body должен это молча
// пропустить (не diagnostic), а мономорфизация клона (T уже конкретен)
// разрешить рекурсивный вызов нормально.
@(test)
test_bounded_generic_recursive_call_works :: proc(t: ^testing.T) {
	result, ok := run_code(`
		функ maxr[T: Сравниваемое](a: T, b: T, глубина: Целое) -> T
			если глубина == 0 тогда
				если a > b тогда a иначе b конец
			иначе
				maxr(a, b, глубина - 1)
			конец
		конец

		функ старт() -> Число
			maxr(3.0, 9.0, 2)
		конец
	`)
	testing.expectf(t, ok, "[bounded traits: рекурсия] стек пуст")
	if ok {
		n, is_num := result.(f64)
		testing.expectf(t, is_num && n == 9, "[bounded traits: рекурсия] ожидалось 9, получено %v", result)
	}
}

// Bounded traits: произвольный МЕТОД пользовательского интерфейса (не
// один из 5 built-in операторных — Сравниваемое/Складываемое/Вычитаемое/
// Умножаемое/Делимое) через generic T. Раньше вызов a.метод() внутри
// f[T: МойИнтерфейс] падал в type_cheker.odin с "попытка получить поле у
// не-структуры" — obj_type.kind == .InferVar не имел своей ветки в
// Property_Expr-диспетчеризации, только 5 built-in интерфейсов
// проверялись напрямую в infer_binary_expr/infer_arithmetic_op.
@(test)
test_bounded_generic_custom_interface_method_call :: proc(t: ^testing.T) {
	result, ok := run_code(`
		тип МойИнтерфейс = интерфейс
			функ значение() -> Целое
		конец

		тип Точка = структура
			x: Целое
		конец

		реализация МойИнтерфейс для Точка
			функ значение(это: Точка) -> Целое
				это.x
			конец
		конец

		функ вызвать[T: МойИнтерфейс](a: T) -> Целое
			a.значение()
		конец

		функ старт() -> Целое
			пер п = Точка(5)
			вызвать(п)
		конец
	`)
	testing.expectf(t, ok, "[bounded traits: свой метод] стек пуст")
	if ok {
		n, is_num := result.(f64)
		testing.expectf(t, is_num && n == 5, "[bounded traits: свой метод] ожидалось 5, получено %v", result)
	}
}

// Тот же произвольный интерфейсный метод через bounded generic, но САМА
// generic-функция объявлена в ДРУГОМ модуле (module.f(...) вместо f(...))
// — упражняет весь цепочка cross-module мономорфизации: Module_Graph.
// decl_type_params/module_resolvers (см. resolver.odin/module_loader.
// odin), generic_call_callee_sym (см. Type_Ctx, monomorphize.odin) и
// monomorphize_one, использующий decl_res (резолвер МОДУЛЯ ОБЪЯВЛЕНИЯ
// f), а не res (резолвер вызывающего модуля), для resolve_function_body/
// comp.res/comp.locals клона.
@(test)
test_bounded_generic_interface_cross_module :: proc(t: ^testing.T) {
	result, ok := run_module_file("fixtures/bounded_generic_iface_fixture_main.ps")
	testing.expectf(t, ok, "[bounded traits: cross-module] стек пуст")
	if ok {
		n, is_num := result.(f64)
		testing.expectf(t, is_num && n == 42, "[bounded traits: cross-module] ожидалось 42, получено %v", result)
	}
}

#+build !js
package core

import "core:math/rand"
import "core:strings"
import "core:testing"

// Property-based fuzz-тест фронтенда (лексер → парсер → резолвер →
// тайпчекер): единственное свойство, которое проверяется — ОТСУТСТВИЕ
// паники на ЛЮБОМ входе, включая заведомо повреждённые мутациями
// программы. Компилятор/VM (compile_program/run_scheduler) сюда
// НЕ входят — они гарантированно безопасны только ПОСЛЕ чистого прохода
// тайпчекера (см. main.odin/pipeline.odin — гейт "compile ТОЛЬКО если 0
// diagnostics"), фаззить их отдельно от гейта означало бы фаззить другое
// свойство (что сам гейт не пропускает плохой AST), не то, что здесь
// заявлено.
//
// check_source (core/pipeline.odin) — готовый lexer+parser+resolver+
// typechecker прогон, копящий diagnostics вместо паники на каждой
// стадии (accumulate-not-panic, см. ARCHITECTURE.md) — ровно то же, что
// использует LSP при live-typing. Фаззинг подтверждает этот инвариант
// эмпирически на входах, которые ни один e2e-тест руками не напишет.

// Затравки — заведомо валидные программы, покрывающие разные грамматики
// (функции/структуры/enum+match), чтобы мутации давали "почти валидный,
// но повреждённый" код чаще, чем чистый случайный byte soup (который
// почти всегда даёт тривиальный "неожиданный символ" на первом же токене
// и не проверяет ничего глубже лексера).
FUZZ_SEEDS := []string {
	`функ старт() -> Число
пер x = 1 + 2 * 3
если x > 0 тогда
	возврат x
конец
0
конец`,
	`тип Точка = структура
x: Число
y: Число
конец
реализация Точка
функ длина(это: Точка) -> Число
	это.x + это.y
конец
конец
функ старт() -> Число
пер p = Точка(1, 2)
p.длина()
конец`,
	`перечисление Опция = Есть(Число) | Нет
функ старт() -> Число
пер o = Опция.Есть(5)
выбор o
	Опция.Есть(n): n
	Опция.Нет: 0
конец
конец`,
	`импорт ввод_вывод
функ старт() -> Пусто
пер имя = "мир"
ввод_вывод.печать("привет, \(имя)!")
конец`,
}

// Токены/фрагменты, вставляемые/подменяющие куски затравки — смесь
// валидных panos-конструкций и потенциально проблемных символов (кавычки,
// скобки, обратный слэш интерполяции), чтобы мутация иногда ломала
// баланс скобок/кавычек — именно те места, где accumulate-not-panic
// восстановление легче всего сломать по недосмотру.
FUZZ_FRAGMENTS := []string {
	"пер", "конст", "функ", "тип", "структура", "перечисление", "выбор",
	"если", "тогда", "иначе", "конец", "пока", "цикл", "для", "в",
	"возврат", "прервать", "продолжить", "импорт", "экспорт", "запусти",
	"(", ")", "[", "]", ",", ":", "->", "=", "==", "<>", "+", "-", "*",
	"/", ".", "?", "\"", "\\(", "\n", "  ", "",
}

// Разбивает затравку на "слова" по пробелам/переводам строк (грубая, но
// достаточная для фаззинга единица мутации — не нужна точная лексическая
// граница, худшее, что может случиться — мутация внутри идентификатора,
// такой же валидный fuzz-кейс, как и граница токена).
fuzz_split_words :: proc(s: string) -> []string {
	return strings.fields(s, context.temp_allocator)
}

// Одна случайная точечная мутация: вставка/удаление/замена ОДНОГО
// случайного "слова" в случайной позиции.
fuzz_mutate_once :: proc(words: []string) -> []string {
	if len(words) == 0 do return words
	idx := rand.int_max(len(words))
	frag := FUZZ_FRAGMENTS[rand.int_max(len(FUZZ_FRAGMENTS))]
	result := make([dynamic]string, 0, len(words) + 1, context.temp_allocator)
	for w, i in words {
		if i == idx {
			switch rand.int_max(3) {
			case 0: // вставка перед словом
				append(&result, frag)
				append(&result, w)
			case 1: // удаление слова
			case 2: // замена слова
				append(&result, frag)
			}
			continue
		}
		append(&result, w)
	}
	return result[:]
}

@(test)
test_fuzz_frontend_never_panics :: proc(t: ^testing.T) {
	// Фиксированный seed — воспроизводимый прогон (не flaky CI на "повезло/
	// не повезло" с рандомным seed'ом).
	rand.reset(42)

	ITERATIONS :: 500
	MAX_MUTATIONS :: 6

	for i in 0 ..< ITERATIONS {
		seed := FUZZ_SEEDS[rand.int_max(len(FUZZ_SEEDS))]
		words := fuzz_split_words(seed)
		mutations := rand.int_max(MAX_MUTATIONS) + 1
		for m in 0 ..< mutations {
			words = fuzz_mutate_once(words)
		}
		src := strings.join(words, " ", context.temp_allocator)

		// Сам факт того, что это выполняется без паники, — единственная
		// проверка. check_source копит diagnostics на каждой стадии
		// (лексер/парсер/резолвер/тайпчекер) вместо паники — если
		// какая-то мутация находит дыру в этом инварианте, тест упадёт
		// панику САМОГО check_source, а не через testing.expect.
		result := check_source(src)
		delete(result.res_ctx.diagnostics)
		delete(result.tc_ctx.diagnostics)
	}

	testing.expect(
		t,
		true,
		"fuzz: 500 мутированных программ прошли через lexer/parser/resolver/typechecker без паники",
	)
}

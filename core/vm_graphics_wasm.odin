#+build js
package core

import "core:fmt"

// WASM-заглушка: браузер не может открыть нативное raylib-окно — точный
// прецедент vm_io_wasm.odin's call_builtin_io. Паникует понятным
// сообщением на любое имя "графика::*", которое native-вариант
// (vm_graphics_native.odin) реально обработал бы.
call_builtin_graphics :: proc(vm: ^VM, name: string, args: []Value) -> (result: Value, ok: bool, handled: bool) {
	switch name {
	case "графика::инициализировать_окно",
	     "графика::окно_должно_закрыться",
	     "графика::закрыть_окно",
	     "графика::начать_рисование",
	     "графика::закончить_рисование",
	     "графика::очистить_фон",
	     "графика::нарисовать_прямоугольник",
	     "графика::нарисовать_круг",
	     "графика::клавиша_нажата",
	     "графика::время_кадра",
	     "графика::задать_fps",
	     "графика::клавиша_вверх",
	     "графика::клавиша_вниз",
	     "графика::клавиша_влево",
	     "графика::клавиша_вправо",
	     "графика::клавиша_пробел",
	     "графика::клавиша_escape":
		fmt.panicf("Runtime Panic: '%s' недоступно в браузере (WASM-демо не может открыть нативное окно)", name)
	}
	return
}

// Демо динамического FFI (Стадии 47-49): вызов libc напрямую из panos,
// без host-кода на Odin-стороне — `внешний` грузит библиотеку и
// резолвит символ в рантайме (core:dynlib + libffi).
импорт ввод_вывод

внешний "libc" функ getpid() -> Целое(32)
внешний "libc" функ abs(x: Целое(32)) -> Целое(32)
внешний "libc" функ strlen(s: КСтрока) -> Целое(64)
внешний "libc" функ strdup(s: КСтрока) -> КСтрока
внешний "libc" функ malloc(размер: Целое(64)) -> Указатель(Целое) свой
внешний "libc" функ getenv(имя: КСтрока) -> Указатель(Целое)

функ старт() -> Пусто
    // Целое(N) — примитивные числа.
    ввод_вывод.печать(getpid())
    ввод_вывод.печать(abs(0 - 42))

    // КСтрока — panos Строка <-> C char*, копия в обе стороны.
    ввод_вывод.печать(strlen("привет, мир"))
    ввод_вывод.печать(strdup("копия через libc и обратно"))

    // Указатель(T) — опаковый handle, свой освобождается сам (GC).
    пер буфер = malloc(64)

    // Указатель(T) без владения — panos никогда его не освободит.
    пер путь = getenv("PATH")
конец

// Стадия 4 (FFI-A): демо на модуле `графика` (статические биндинги
// поверх vendor:raylib, core/vm_graphics_native.odin) — доказывает, что
// panos может звать внешнюю C-библиотеку и рисовать окно. Классический
// pong: игрок слева (стрелки вверх/вниз), простой ИИ справа (следит за
// мячом с ограниченной скоростью), счёт печатается в консоль при
// пропущенном мяче.
//
// `конст` (Стадия 27) — только ЛОКАЛЬНОЕ связывание (иммутабельность
// биндинга внутри функции), не глобальная константа модуля — в panos
// нет объявлений уровня модуля для значений. Именованные "константы"
// ниже — обычные нуль-арные функции (нет замыканий, значит и мутируемого
// глобального состояния через них не завести — безопасно).
импорт графика
импорт ввод_вывод
импорт строки

функ ширина_окна() -> Число
    800.0
конец

функ высота_окна() -> Число
    450.0
конец

функ ширина_весла() -> Число
    15.0
конец

функ высота_весла() -> Число
    90.0
конец

функ радиус_мяча() -> Число
    8.0
конец

функ скорость_весла() -> Число
    300.0
конец

функ скорость_ии() -> Число
    220.0
конец

тип Весло = структура
    x: Число
    y: Число
конец

тип Мяч = структура
    x: Число
    y: Число
    vx: Число
    vy: Число
конец

функ зажать(значение: Число, минимум: Число, максимум: Число) -> Число
    если значение < минимум тогда
        возврат минимум
    конец
    если значение > максимум тогда
        возврат максимум
    конец
    возврат значение
конец

функ обновить_игрока(игрок: Весло, дт: Число) -> Пусто
    если графика.клавиша_нажата(графика.клавиша_вверх()) тогда
        игрок.y = игрок.y - скорость_весла() * дт
    конец
    если графика.клавиша_нажата(графика.клавиша_вниз()) тогда
        игрок.y = игрок.y + скорость_весла() * дт
    конец
    игрок.y = зажать(игрок.y, 0.0, высота_окна() - высота_весла())
конец

функ обновить_ии(ии: Весло, мяч: Мяч, дт: Число) -> Пусто
    пер центр_ии: Число = ии.y + высота_весла() / 2.0
    если центр_ии < мяч.y - 10.0 тогда
        ии.y = ии.y + скорость_ии() * дт
    конец
    если центр_ии > мяч.y + 10.0 тогда
        ии.y = ии.y - скорость_ии() * дт
    конец
    ии.y = зажать(ии.y, 0.0, высота_окна() - высота_весла())
конец

функ весло_задевает_мяч(весло: Весло, мяч: Мяч) -> Булево
    (мяч.x + радиус_мяча() > весло.x) и
        (мяч.x - радиус_мяча() < весло.x + ширина_весла()) и
        (мяч.y + радиус_мяча() > весло.y) и
        (мяч.y - радиус_мяча() < весло.y + высота_весла())
конец

функ сбросить_мяч(мяч: Мяч, в_сторону_игрока: Булево) -> Пусто
    мяч.x = ширина_окна() / 2.0
    мяч.y = высота_окна() / 2.0
    если в_сторону_игрока тогда
        мяч.vx = -220.0
    иначе
        мяч.vx = 220.0
    конец
    мяч.vy = 160.0
конец

функ обновить_мяч(мяч: Мяч, игрок: Весло, ии: Весло, дт: Число, счёт_игрока: Целое, счёт_ии: Целое) -> (Целое, Целое)
    мяч.x = мяч.x + мяч.vx * дт
    мяч.y = мяч.y + мяч.vy * дт

    если мяч.y - радиус_мяча() < 0.0 тогда
        мяч.y = радиус_мяча()
        мяч.vy = 0.0 - мяч.vy
    конец
    если мяч.y + радиус_мяча() > высота_окна() тогда
        мяч.y = высота_окна() - радиус_мяча()
        мяч.vy = 0.0 - мяч.vy
    конец

    если (мяч.vx < 0.0) и весло_задевает_мяч(игрок, мяч) тогда
        мяч.vx = 0.0 - мяч.vx
        мяч.x = игрок.x + ширина_весла() + радиус_мяча()
    конец
    если (мяч.vx > 0.0) и весло_задевает_мяч(ии, мяч) тогда
        мяч.vx = 0.0 - мяч.vx
        мяч.x = ии.x - радиус_мяча()
    конец

    пер новый_счёт_игрока: Целое = счёт_игрока
    пер новый_счёт_ии: Целое = счёт_ии
    если мяч.x < 0.0 тогда
        новый_счёт_ии = счёт_ии + 1
        сбросить_мяч(мяч, ложь)
    конец
    если мяч.x > ширина_окна() тогда
        новый_счёт_игрока = счёт_игрока + 1
        сбросить_мяч(мяч, истина)
    конец

    (новый_счёт_игрока, новый_счёт_ии)
конец

функ нарисовать_весло(весло: Весло) -> Пусто
    графика.нарисовать_прямоугольник((весло.x, весло.y), (ширина_весла(), высота_весла()), (255.0, 255.0, 255.0, 255.0))
конец

функ старт() -> Пусто
    графика.инициализировать_окно(800, 450, "panos + raylib: pong")
    графика.задать_fps(60)

    пер игрок = Весло(30.0, высота_окна() / 2.0 - высота_весла() / 2.0)
    пер ии = Весло(ширина_окна() - 30.0 - ширина_весла(), высота_окна() / 2.0 - высота_весла() / 2.0)
    пер мяч = Мяч(ширина_окна() / 2.0, высота_окна() / 2.0, 220.0, 160.0)

    пер счёт_игрока: Целое = 0
    пер счёт_ии: Целое = 0

    пока графика.окно_должно_закрыться() == ложь цикл
        пер дт = графика.время_кадра()

        обновить_игрока(игрок, дт)
        обновить_ии(ии, мяч, дт)
        пер (новый_счёт_игрока, новый_счёт_ии) = обновить_мяч(мяч, игрок, ии, дт, счёт_игрока, счёт_ии)
        если новый_счёт_игрока <> счёт_игрока или новый_счёт_ии <> счёт_ии тогда
            ввод_вывод.печать("счёт: игрок " + строки.из_целого(новый_счёт_игрока) + " — ии " + строки.из_целого(новый_счёт_ии) + "\n")
        конец
        счёт_игрока = новый_счёт_игрока
        счёт_ии = новый_счёт_ии

        графика.начать_рисование()
        графика.очистить_фон((20.0, 20.0, 20.0, 255.0))
        нарисовать_весло(игрок)
        нарисовать_весло(ии)
        графика.нарисовать_круг((мяч.x, мяч.y), радиус_мяча(), (255.0, 255.0, 255.0, 255.0))
        графика.закончить_рисование()
    конец

    графика.закрыть_окно()
конец

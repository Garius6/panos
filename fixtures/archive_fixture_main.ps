импорт архив

функ найти(записи: Массив(архив.Запись), имя: Строка) -> Опция(Строка)
	пер i: Целое = 0
	пока i < записи.длина() цикл
		если записи[i].имя == имя тогда
			возврат Опция.Есть(записи[i].содержимое)
		конец
		i = i + 1
	конец
	Опция.Нет
конец

функ старт() -> Булево
	пер исходные: Массив(архив.Запись) = массив(
		архив.Запись("привет.txt", "Привет, мир!", ложь),
		архив.Запись("папка/вложенный.txt", "вложенное содержимое", ложь)
	)

	пер собранный = архив.собрать(исходные)
	пер записи = архив.разобрать(собранный)

	если записи.длина() <> 2 тогда
		возврат ложь
	конец

	пер первый = найти(записи, "привет.txt").получить("")
	пер второй = найти(записи, "папка/вложенный.txt").получить("")

	первый == "Привет, мир!" и второй == "вложенное содержимое"
конец

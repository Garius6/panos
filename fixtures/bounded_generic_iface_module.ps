// Вспомогательный модуль для test_bounded_generic_interface_cross_module
// (core/e2e_types_interfaces_test.odin) — bounded generic-функция,
// экспортированная отсюда, вызывается из fixture_main.ps с типом,
// объявленным (и implement-нутым) уже ТАМ, за границей модуля.

экспорт тип Печать = интерфейс
	функ значение() -> Целое
конец

экспорт функ удвоить[T: Печать](a: T) -> Целое
	a.значение() * 2
конец

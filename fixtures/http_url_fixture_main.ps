импорт "сеть/http" как хттп

функ пустая_query_карта() -> Соответствие(Строка, Строка)
	пер м: Соответствие(Строка, Строка) = соответствие()
	возврат м
конец

функ проверить_адреса() -> Булево
	пер а1 = хттп.разобрать_адрес("http://example.com/путь").ожидать("а1")
	пер провал1 = а1.хост <> "example.com" или а1.порт <> 80 или а1.путь <> "/путь"

	пер а2 = хттп.разобрать_адрес("http://localhost:9000").ожидать("а2")
	пер провал2 = а2.хост <> "localhost" или а2.порт <> 9000 или а2.путь <> "/"

	пер а3 = хттп.разобрать_адрес("https://example.com/")
	пер провал3 = а3.успех()

	не (провал1 или провал2 или провал3)
конец

функ проверить_query() -> Булево
	пер параметры: Соответствие(Строка, Строка) = соответствие(
		"a" = "1",
	)
	пер провал1 = хттп.построить_query(параметры) <> "?a=1"
	пер провал2 = хттп.построить_query(пустая_query_карта()) <> ""

	не (провал1 или провал2)
конец

функ проверить_статусы() -> Булево
	пер ок = хттп.Ответ(204, пустая_query_карта(), "")
	пер редирект = хттп.Ответ(302, пустая_query_карта(), "")
	пер клиент = хттп.Ответ(404, пустая_query_карта(), "")
	пер сервер = хттп.Ответ(503, пустая_query_карта(), "")

	пер провал1 = ок.успех() == ложь
	пер провал2 = редирект.редирект() == ложь
	пер провал3 = клиент.ошибка_клиента() == ложь
	пер провал4 = сервер.ошибка_сервера() == ложь

	не (провал1 или провал2 или провал3 или провал4)
конец

// native-клиент (external/odin-http) хранит имена заголовков ответа в
// нижнем регистре — .заголовок() должен находить их независимо от
// регистра, которым вызывающий код написал имя (см. std/сеть/http.ps).
функ проверить_регистр_заголовков() -> Булево
	пер заголовки: Соответствие(Строка, Строка) = соответствие(
		"location" = "/следующая-страница",
	)
	пер ответ = хттп.Ответ(302, заголовки, "")

	пер провал1 = ответ.заголовок("Location").получить("") <> "/следующая-страница"
	пер провал2 = ответ.заголовок("LOCATION").получить("") <> "/следующая-страница"
	пер провал3 = ответ.заголовок("location").получить("") <> "/следующая-страница"

	не (провал1 или провал2 или провал3)
конец

функ старт() -> Булево
	проверить_адреса() и проверить_query() и проверить_статусы() и проверить_регистр_заголовков()
конец

импорт математика

функ старт() -> Булево
	пер квадрат = математика.квадрат(6)
	пер минимум = математика.мин(3, 7)
	пер максимум = математика.макс(3, 7)
	пер модуль = математика.абс(0 - 5)
	пер степень = математика.степень(2, 10)
	пер обратная_степень = математика.степень(2, -2)
	пер корень = математика.квадратный_корень(144)
	квадрат == 36 и минимум == 3 и максимум == 7 и модуль == 5 и степень == 1024 и обратная_степень == 0.25 и корень == 12
конец

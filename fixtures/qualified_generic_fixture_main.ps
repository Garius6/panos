импорт "./qualified_generic_fixture_lib" как либ

функ построить_коробку() -> либ.Коробка(Число)
	либ.Коробка(42)
конец

функ распаковать(к: либ.Коробка(Число)) -> Число
	к.значение
конец

функ построить_пару() -> либ.Пара(Строка, Число)
	либ.Пара("привет", 7)
конец

функ старт() -> Булево
	пер к = построить_коробку()
	пер извлечённое = распаковать(к)
	пер п = построить_пару()

	извлечённое == 42 и п.первый == "привет" и п.второй == 7
конец

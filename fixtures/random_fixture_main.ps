импорт математика

функ старт() -> Булево
	пер а = математика.новый_генератор_с_seed(42)
	пер б = математика.новый_генератор_с_seed(42)
	пер детерминизм = а.диапазон(1, 1000) == б.диапазон(1, 1000)

	пер г = математика.новый_генератор_с_seed(42)
	пер первый = г.следующее()
	пер второй = г.следующее()
	пер продвигается = первый <> второй

	пер границы_диапазона = истина
	пер бросающий = математика.новый_генератор_с_seed(7)
	для сч = 0 по 199 цикл
		пер бросок = бросающий.диапазон(1, 6)
		если бросок < 1 или бросок > 6 тогда
			границы_диапазона = ложь
		конец
	конец

	пер границы_дроби = истина
	пер дробящий = математика.новый_генератор_с_seed(99)
	для сч = 0 по 199 цикл
		пер д = дробящий.дробь()
		если д < 0 или д >= 1 тогда
			границы_дроби = ложь
		конец
	конец

	пер видели_истину = ложь
	пер видели_ложь = ложь
	пер монетка = математика.новый_генератор_с_seed(1)
	для сч = 0 по 49 цикл
		если монетка.булево() тогда
			видели_истину = истина
		иначе
			видели_ложь = истина
		конец
	конец
	пер оба_исхода = видели_истину и видели_ложь

	пер к = математика.новый_генератор_с_seed(1)
	пер л = математика.новый_генератор_с_seed(2)
	пер seed_к_до = к.seed
	л.следующее()
	пер независимость = к.seed == seed_к_до

	// Не проверяем, что два новый_генератор(), вызванных подряд, дают
	// РАЗНЫЙ seed — время.сейчас_мс() миллисекундного разрешения, два
	// вызова в одном тике программы иногда попадают в одну и ту же мс не
	// по вине фичи (см. std/математика.ps). Проверяем только, что вызов
	// вообще работает и возвращает валидный Генератор.
	пер авто = математика.новый_генератор()
	пер авто_валиден = авто.seed <> 0

	детерминизм и продвигается и границы_диапазона и границы_дроби и оба_исхода и независимость и авто_валиден
конец

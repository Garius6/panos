// Стадия 45: позитив — `запусти spawn_qualified_module.эхо()` даёт
// типобезопасный Процесс(spawn_qualified_module.Команда). наблюдать() +
// получить_сигнал() тут же, чтобы видимо (через панику "старт()")
// подтвердить, что сообщение реально дошло с ПРАВИЛЬНЫМ payload'ом —
// не просто "не упало".
импорт spawn_qualified_module

функ старт() -> Пусто
    пер h = запусти spawn_qualified_module.эхо()
    наблюдать(h)
    отправить(h, spawn_qualified_module.Команда.Пинг("привет"))
    пер (id, причина) = получить_сигнал()
    выбор причина
        Нет -> паника("эхо завершилось штатно (неожиданно)")
        Есть(текст) -> паника(текст)
    конец
конец

// Стадия 45: динамическое добавление ребёнка. Супервизор стартует БЕЗ
// падающих задач — старт() спавнит его напрямую (qualified запусти),
// получает типобезопасный Процесс(супервизор.СобытиеСупервизора) и ШЛЁТ
// ДобавитьЗадачу(...) уже во время работы супервизора. Добавленный
// ребёнок падает, супервизор его перезапускает до лимита, затем
// паникует — доказывает, что динамически добавленный ребёнок реально
// под наблюдением (не осиротевший).
импорт супервизор
импорт ввод_вывод

тип Задача = перечисление
    Выполнить
конец

функ падающий_рабочий() -> Пусто
    выбор получить()
        Задача.Выполнить -> паника("динамический рабочий сломался")
    конец
конец

функ старт_рабочего() -> Процесс(Задача)
    запусти падающий_рабочий()
конец

функ ретранслятор_рабочего(proc: Процесс(Задача), супервизор_h: Процесс(супервизор.СобытиеСупервизора)) -> Пусто
    наблюдать(proc)
    пер (id, причина) = получить_сигнал()
    отправить(супервизор_h, супервизор.СобытиеСупервизора.Сигнал(id, причина))
конец

тип ПадающаяЗадача = структура
    последний: Опция(Процесс(Задача))
конец

реализация супервизор.ДочерняяЗадача для ПадающаяЗадача
    функ запустить(это: ПадающаяЗадача, супервизор_h: Процесс(супервизор.СобытиеСупервизора)) -> Целое
        пер proc = старт_рабочего()
        запусти ретранслятор_рабочего(proc, супервизор_h)
        отправить(proc, Задача.Выполнить)
        это.последний = Опция.Есть(proc)
        proc.номер()
    конец
    функ имя(это: ПадающаяЗадача) -> Строка
        "динамический-рабочий"
    конец
    функ остановить(это: ПадающаяЗадача) -> Пусто
        если это.последний.есть() тогда
            убить(это.последний.значение())
        конец
    конец
конец

функ старт() -> Пусто
    пер задачи: Массив(супервизор.ДочерняяЗадача) = массив()
    пер супервизор_h = запусти супервизор.супервизировать(задачи, супервизор.Стратегия.ОдинЗаОдного, 1, 60000.0)
    наблюдать(супервизор_h)

    отправить(супервизор_h, супервизор.СобытиеСупервизора.ДобавитьЗадачу(ПадающаяЗадача(Опция.Нет())))

    пер (id, причина) = получить_сигнал()
    выбор причина
        Нет -> ввод_вывод.печать("супервизор завершился штатно (неожиданно)")
        Есть(текст) -> паника(текст)
    конец
конец

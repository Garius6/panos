// Стадия 45: динамическое удаление ребёнка. Супервизор стартует с
// "тихой" (никогда не падает) задачей на индексе 0 — старт() шлёт
// УбратьЗадачу(0), супервизор её останавливает и tombstone'ит слот.
// Затем добавляется падающая задача (индекс 1) — если бы tombstone/
// индексация были сломаны, это привело бы к перепутанным индексам или
// к тому, что супервизор считал бы удалённую задачу всё ещё активной.
// Итоговая паника (лимит перезапусков падающей) с ОЖИДАЕМЫМ текстом —
// доказательство, что удаление не мешает дальнейшей работе супервизора.
импорт супервизор
импорт ввод_вывод

тип Задача = перечисление
    Выполнить
конец

функ тихий_рабочий() -> Пусто
    выбор получить()
        Задача.Выполнить -> 0
    конец
конец

функ падающий_рабочий() -> Пусто
    выбор получить()
        Задача.Выполнить -> паника("удаление: рабочий сломался")
    конец
конец

функ старт_тихого() -> Процесс(Задача)
    запусти тихий_рабочий()
конец

функ старт_падающего() -> Процесс(Задача)
    запусти падающий_рабочий()
конец

функ ретранслятор_рабочего(proc: Процесс(Задача), супервизор_h: Процесс(супервизор.СобытиеСупервизора)) -> Пусто
    наблюдать(proc)
    пер (id, причина) = получить_сигнал()
    отправить(супервизор_h, супервизор.СобытиеСупервизора.Сигнал(id, причина))
конец

тип ТихаяЗадача = структура
    последний: Опция(Процесс(Задача))
конец

реализация супервизор.ДочерняяЗадача для ТихаяЗадача
    функ запустить(это: ТихаяЗадача, супервизор_h: Процесс(супервизор.СобытиеСупервизора)) -> Целое
        пер proc = старт_тихого()
        запусти ретранслятор_рабочего(proc, супервизор_h)
        это.последний = Опция.Есть(proc)
        proc.номер()
    конец
    функ имя(это: ТихаяЗадача) -> Строка
        "тихая-удаляемая"
    конец
    функ остановить(это: ТихаяЗадача) -> Пусто
        если это.последний.есть() тогда
            убить(это.последний.значение())
        конец
    конец
конец

тип ПадающаяЗадача = структура
    последний: Опция(Процесс(Задача))
конец

реализация супервизор.ДочерняяЗадача для ПадающаяЗадача
    функ запустить(это: ПадающаяЗадача, супервизор_h: Процесс(супервизор.СобытиеСупервизора)) -> Целое
        пер proc = старт_падающего()
        запусти ретранслятор_рабочего(proc, супервизор_h)
        отправить(proc, Задача.Выполнить)
        это.последний = Опция.Есть(proc)
        proc.номер()
    конец
    функ имя(это: ПадающаяЗадача) -> Строка
        "падающая-после-удаления"
    конец
    функ остановить(это: ПадающаяЗадача) -> Пусто
        если это.последний.есть() тогда
            убить(это.последний.значение())
        конец
    конец
конец

функ старт() -> Пусто
    пер задачи: Массив(супервизор.ДочерняяЗадача) = массив(ТихаяЗадача(Опция.Нет()))
    пер супервизор_h = запусти супервизор.супервизировать(задачи, супервизор.Стратегия.ОдинЗаОдного, 1)
    наблюдать(супервизор_h)

    отправить(супервизор_h, супервизор.СобытиеСупервизора.УбратьЗадачу(0))
    отправить(супервизор_h, супервизор.СобытиеСупервизора.ДобавитьЗадачу(ПадающаяЗадача(Опция.Нет())))

    пер (id, причина) = получить_сигнал()
    выбор причина
        Нет -> ввод_вывод.печать("супервизор завершился штатно (неожиданно)")
        Есть(текст) -> паника(текст)
    конец
конец

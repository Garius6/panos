импорт супервизор

тип Задача = перечисление
    Выполнить
конец

функ падающий_рабочий() -> Пусто
    выбор получить()
        Задача.Выполнить -> паника("рабочий сломался")
    конец
конец

функ старт_рабочего() -> Процесс(Задача)
    запусти падающий_рабочий()
конец

// Стадия 45: наблюдать(proc) переехал сюда — наблюдать() регистрирует
// ТЕКУЩИЙ процесс как наблюдателя, значит наблюдателем должен быть ИМЕННО
// этот relay (не супервизор напрямую), иначе сигнал о крахе придёт не в
// mailbox супервизора (получить()), а в его сигналы (получить_сигнал()),
// который супервизировать() после Стадии 45 больше не слушает. Bare-ident
// запусти, монотипный — не generic, T ребёнка (Задача) известен статически.
функ ретранслятор_рабочего(proc: Процесс(Задача), супервизор_h: Процесс(супервизор.СобытиеСупервизора)) -> Пусто
    наблюдать(proc)
    пер (id, причина) = получить_сигнал()
    отправить(супервизор_h, супервизор.СобытиеСупервизора.Сигнал(id, причина))
конец

тип ПадающаяЗадача = структура
    последний: Опция(Процесс(Задача))
конец

реализация супервизор.ДочерняяЗадача для ПадающаяЗадача
    функ запустить(это: ПадающаяЗадача, супервизор_h: Процесс(супервизор.СобытиеСупервизора)) -> Целое
        пер proc = старт_рабочего()
        запусти ретранслятор_рабочего(proc, супервизор_h)
        отправить(proc, Задача.Выполнить)
        это.последний = Опция.Есть(proc)
        proc.номер()
    конец
    функ имя(это: ПадающаяЗадача) -> Строка
        "падающий-рабочий"
    конец
    функ остановить(это: ПадающаяЗадача) -> Пусто
        если это.последний.есть() тогда
            убить(это.последний.значение())
        конец
    конец
конец

функ старт() -> Пусто
    пер задачи: Массив(супервизор.ДочерняяЗадача) = массив(ПадающаяЗадача(Опция.Нет()))
    супервизор.супервизировать(задачи, супервизор.Стратегия.ОдинЗаОдного, 1)
конец

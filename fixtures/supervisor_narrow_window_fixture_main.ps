// Стадия 46: доказательство, что окно_мс РЕАЛЬНО консультируется (не
// просто принимается и игнорируется). Ребёнок падает РОВНО 3 раза
// (это.осталось — бюджет, декрементируется в запустить(), после
// исчерпания триггер-сообщение больше не шлётся и ребёнок просто
// молча ждёт в получить() навсегда) — макс_рестартов=2, значит СТАРАЯ
// (Стадия 45, счётчик за всю жизнь) семантика запаниковала бы на 3-м
// крахе (счётчик 2 >= 2). Окно (0.001мс) заведомо уже, чем реальное
// время одного цикла краш→relay→сигнал→рестарт (на 2+ порядка —
// эмпирически измерено, см. ROADMAP §Стадия 46), значит sliding window
// "забывает" каждый предыдущий крах до следующего — лимит НИКОГДА не
// достигается за все 3 краха. После исчерпания бюджета ребёнок больше
// не падает, супервизор/relay/старт() блокируются НАВСЕГДА в ожидании
// событий, которых больше не будет — детерминированный дедлок
// планировщика (НЕ паника лимита рестартов, и НЕ тысячи циклов, как в
// первой, отброшенной версии этого теста — ровно 3 краха, быстро).
импорт супервизор

тип Задача = перечисление
    Выполнить
конец

функ падающий_рабочий() -> Пусто
    выбор получить()
        Задача.Выполнить -> паника("бум")
    конец
конец

функ старт_рабочего() -> Процесс(Задача)
    запусти падающий_рабочий()
конец

функ ретранслятор_рабочего(proc: Процесс(Задача), супервизор_h: Процесс(супервизор.СобытиеСупервизора)) -> Пусто
    наблюдать(proc)
    пер (id, причина) = получить_сигнал()
    отправить(супервизор_h, супервизор.СобытиеСупервизора.Сигнал(id, причина))
конец

тип ПадающаяЗадача = структура
    последний: Опция(Процесс(Задача))
    осталось: Целое
конец

реализация супервизор.ДочерняяЗадача для ПадающаяЗадача
    функ запустить(это: ПадающаяЗадача, супервизор_h: Процесс(супервизор.СобытиеСупервизора)) -> Целое
        пер proc = старт_рабочего()
        запусти ретранслятор_рабочего(proc, супервизор_h)
        если это.осталось > 0 тогда
            это.осталось = это.осталось - 1
            отправить(proc, Задача.Выполнить)
        конец
        это.последний = Опция.Есть(proc)
        proc.номер()
    конец
    функ имя(это: ПадающаяЗадача) -> Строка
        "падающая"
    конец
    функ остановить(это: ПадающаяЗадача) -> Пусто
        если это.последний.есть() тогда
            убить(это.последний.значение())
        конец
    конец
конец

функ старт() -> Пусто
    пер задачи: Массив(супервизор.ДочерняяЗадача) = массив(ПадающаяЗадача(Опция.Нет(), 3))
    супервизор.супервизировать(задачи, супервизор.Стратегия.ОдинЗаОдного, 2, 0.001)
конец

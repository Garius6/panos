импорт супервизор

тип Задача = перечисление
    Выполнить
конец

функ тихий_рабочий() -> Пусто
    выбор получить()
        Задача.Выполнить -> 0
    конец
конец

функ падающий_рабочий() -> Пусто
    выбор получить()
        Задача.Выполнить -> паника("бум")
    конец
конец

функ старт_тихого() -> Процесс(Задача)
    пер proc: Процесс(Задача) = запусти тихий_рабочий()
    наблюдать(proc)
    proc
конец

функ старт_падающего() -> Процесс(Задача)
    пер proc: Процесс(Задача) = запусти падающий_рабочий()
    наблюдать(proc)
    отправить(proc, Задача.Выполнить)
    proc
конец

тип ТихаяЗадача = структура
    последний: Опция(Процесс(Задача))
конец

реализация супервизор.ДочерняяЗадача для ТихаяЗадача
    функ запустить(это: ТихаяЗадача) -> Целое
        пер proc = старт_тихого()
        это.последний = Опция.Есть(proc)
        proc.номер()
    конец
    функ имя(это: ТихаяЗадача) -> Строка
        "тихая"
    конец
    функ остановить(это: ТихаяЗадача) -> Пусто
        если это.последний.есть() тогда
            убить(это.последний.значение())
        конец
    конец
конец

тип ПадающаяЗадача = структура
    последний: Опция(Процесс(Задача))
конец

реализация супервизор.ДочерняяЗадача для ПадающаяЗадача
    функ запустить(это: ПадающаяЗадача) -> Целое
        пер proc = старт_падающего()
        это.последний = Опция.Есть(proc)
        proc.номер()
    конец
    функ имя(это: ПадающаяЗадача) -> Строка
        "падающая"
    конец
    функ остановить(это: ПадающаяЗадача) -> Пусто
        если это.последний.есть() тогда
            убить(это.последний.значение())
        конец
    конец
конец

// ВсеЗаОдного: краш "падающей" рестартует ВСЮ группу (в т.ч. "тихую",
// которая никогда не падала) — Стадия 43: "тихая" теперь ПО-НАСТОЯЩЕМУ
// останавливается через остановить()/убить() перед повторным запустить(),
// не просто осиротевает.
функ старт() -> Пусто
    пер задачи: Массив(супервизор.ДочерняяЗадача) = массив(ТихаяЗадача(Опция.Нет()), ПадающаяЗадача(Опция.Нет()))
    супервизор.супервизировать(задачи, супервизор.Стратегия.ВсеЗаОдного, 1)
конец

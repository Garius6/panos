импорт супервизор

тип Задача = перечисление
    Выполнить
конец

функ тихий_рабочий() -> Пусто
    выбор получить()
        Задача.Выполнить -> 0
    конец
конец

функ падающий_рабочий() -> Пусто
    выбор получить()
        Задача.Выполнить -> паника("бум")
    конец
конец

функ старт_тихого() -> Процесс(Задача)
    запусти тихий_рабочий()
конец

функ старт_падающего() -> Процесс(Задача)
    запусти падающий_рабочий()
конец

// Стадия 45: наблюдать(proc) переехал сюда — см. пометку в
// supervisor_fixture_main.ps. Один shared relay годится для обоих типов
// задач в этом файле, т.к. у обоих T ребёнка один и тот же (Задача).
функ ретранслятор_рабочего(proc: Процесс(Задача), супервизор_h: Процесс(супервизор.СобытиеСупервизора)) -> Пусто
    наблюдать(proc)
    пер (id, причина) = получить_сигнал()
    отправить(супервизор_h, супервизор.СобытиеСупервизора.Сигнал(id, причина))
конец

тип ТихаяЗадача = структура
    последний: Опция(Процесс(Задача))
конец

реализация супервизор.ДочерняяЗадача для ТихаяЗадача
    функ запустить(это: ТихаяЗадача, супервизор_h: Процесс(супервизор.СобытиеСупервизора)) -> Целое
        пер proc = старт_тихого()
        запусти ретранслятор_рабочего(proc, супервизор_h)
        это.последний = Опция.Есть(proc)
        proc.номер()
    конец
    функ имя(это: ТихаяЗадача) -> Строка
        "тихая"
    конец
    функ остановить(это: ТихаяЗадача) -> Пусто
        если это.последний.есть() тогда
            убить(это.последний.значение())
        конец
    конец
конец

тип ПадающаяЗадача = структура
    последний: Опция(Процесс(Задача))
конец

реализация супервизор.ДочерняяЗадача для ПадающаяЗадача
    функ запустить(это: ПадающаяЗадача, супервизор_h: Процесс(супервизор.СобытиеСупервизора)) -> Целое
        пер proc = старт_падающего()
        запусти ретранслятор_рабочего(proc, супервизор_h)
        отправить(proc, Задача.Выполнить)
        это.последний = Опция.Есть(proc)
        proc.номер()
    конец
    функ имя(это: ПадающаяЗадача) -> Строка
        "падающая"
    конец
    функ остановить(это: ПадающаяЗадача) -> Пусто
        если это.последний.есть() тогда
            убить(это.последний.значение())
        конец
    конец
конец

// ОстальныеЗаОдним: краш "падающей" (индекс 1) рестартует её и "тихую2"
// (индекс 2, объявлена ПОСЛЕ), но НЕ первую "тихую" (индекс 0, объявлена
// ДО упавшей) — лимит общий на супервизор. Стадия 43: "тихую2" реально
// останавливает через остановить()/убить(), первая "тихая" не трогается
// вовсе (её остановить() не вызывается).
функ старт() -> Пусто
    пер задачи: Массив(супервизор.ДочерняяЗадача) = массив(ТихаяЗадача(Опция.Нет()), ПадающаяЗадача(Опция.Нет()), ТихаяЗадача(Опция.Нет()))
    супервизор.супервизировать(задачи, супервизор.Стратегия.ОстальныеЗаОдним, 1, 60000.0)
конец

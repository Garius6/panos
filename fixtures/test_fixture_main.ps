импорт "тест" как т

функ падающая_операция() -> Пусто
	паника("ожидаемый сбой")
конец

функ старт() -> Целое
	пер отчёт = т.новый_отчёт()
	т.проверить(отчёт, 1 + 1 == 2, "математика сломана")
	т.равны(отчёт, 2 + 2, 4, "2+2 должно быть 4")
	т.равны(отчёт, "а" + "б", "аб", "конкатенация сломана")
	т.равны(отчёт, истина, не ложь, "булева логика сломана")
	т.не_равны(отчёт, 1, 2, "1 не должно равняться 2")

	пер процесс = запусти падающая_операция()
	наблюдать(процесс)
	пер (_, причина) = получить_сигнал()
	т.ожидать_панику(отчёт, причина, "падающая_операция должна паниковать")

	отчёт.провалено
конец

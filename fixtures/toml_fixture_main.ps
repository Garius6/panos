импорт "кодирование/toml" как toml

тип Сервер = структура
	хост: Строка
	порт: Целое
конец

реализация toml.ИзTOML для Сервер
	функ заполнить_из_toml(это: Сервер, значение: toml.Значение) -> Опция(Ошибка)
		это.хост = значение.поле("хост").значение().как_строку().получить("")
		это.порт = значение.поле("порт").значение().как_целое().получить(0)
		Опция.Нет()
	конец
конец

реализация toml.ВTOML для Сервер
	функ в_toml(это: Сервер) -> toml.Значение
		пер т: Соответствие(Строка, toml.Значение) = соответствие()
		т["хост"] = toml.Значение.Строка(это.хост)
		т["порт"] = toml.Значение.Целое(это.порт)
		toml.Значение.Таблица(т)
	конец
конец

функ старт() -> Булево
	пер текст = "имя = \"panos\"\nверсия = 7\nплавающее = 2.5\nстабильный = true\nтеги = [\"lang\", \"ru\"]\n\n[мета]\nа = 1\n\n[[работники]]\nимя = \"воркер1\"\n\n[[работники]]\nимя = \"воркер2\"\n"
	пер разобрано = toml.разобрать(текст)
	если разобрано.ошибка() тогда
		возврат ложь
	конец
	пер значение = разобрано.получить(toml.Значение.Булево(ложь))

	пер имя = значение.поле("имя").значение().как_строку().получить("")
	пер версия = значение.поле("версия").значение().как_целое().получить(0)
	пер плавающее = значение.поле("плавающее").значение().как_число().получить(0.0)
	пер стабильный = значение.поле("стабильный").значение().как_булево().получить(ложь)
	пер первый_тег = значение.поле("теги").значение().элемент(0).значение().как_строку().получить("")
	пер мета_а = значение.поле("мета").значение().поле("а").значение().как_целое().получить(0)
	пер работники = значение.поле("работники").значение()
	пер второй_воркер = работники.элемент(1).значение().поле("имя").значение().как_строку().получить("")

	пер round_trip = toml.сериализовать(значение)
	пер снова = toml.разобрать(round_trip)

	пер незакрытый = toml.разобрать("х = ")

	пер сервер = Сервер("", 0)
	пер ошибка_опц = toml.разобрать_в(сервер, "хост = \"localhost\"\nпорт = 9090\n")
	пер сервер_текст = toml.сериализовать_из(сервер)
	пер сервер_снова = toml.разобрать(сервер_текст)

	имя == "panos" и версия == 7 и плавающее == 2.5 и стабильный и первый_тег == "lang" и мета_а == 1 и второй_воркер == "воркер2" и снова.успех() и незакрытый.ошибка() и (не ошибка_опц.есть()) и сервер.хост == "localhost" и сервер.порт == 9090 и сервер_снова.успех()
конец

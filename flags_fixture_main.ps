импорт "флаги" как флаги

функ старт() -> Булево
	пер конфиг = флаги.новая_конфигурация()
	конфиг.добавить_флаг(флаги.Флаг("подробно", флаги.ТипФлага.тБулево))
	конфиг.добавить_флаг(флаги.Флаг("имя", флаги.ТипФлага.тСтрока))
	конфиг.добавить_флаг(флаги.Флаг("число", флаги.ТипФлага.тЧисло))

	пер аргументы = массив("позиционный", "-подробно", "-имя=panos", "-число", "42")
	пер результат = конфиг.распарсить_флаги(аргументы)

	пер подробно = результат.получить("подробно", флаги.ЗначениеФлага.фБулево(ложь))
	пер имя = результат.получить("имя", флаги.ЗначениеФлага.фСтрока(""))
	пер число = результат.получить("число", флаги.ЗначениеФлага.фЧисло(0))

	подробно.вСтроку() == "Булево(истина)" и имя.вСтроку() == "Строка(panos)" и число.вСтроку() == "Число(42)"
конец

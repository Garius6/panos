импорт "сеть/http" как хттп

функ старт() -> Булево
	пер а1 = хттп.разобрать_адрес("http://example.com/путь").ожидать("а1")
	пер провал1 = а1.хост <> "example.com" или а1.порт <> 80 или а1.путь <> "/путь"

	пер а2 = хттп.разобрать_адрес("http://localhost:9000").ожидать("а2")
	пер провал2 = а2.хост <> "localhost" или а2.порт <> 9000 или а2.путь <> "/"

	пер а3 = хттп.разобрать_адрес("https://example.com/")
	пер провал3 = а3.успех()

	не (провал1 или провал2 или провал3)
конец

импорт "кодирование/json" как json

функ старт() -> Булево
	пер текст = "{\"имя\": \"panos\", \"версия\": 7, \"стабильный\": true, \"теги\": [\"lang\", \"ru\"], \"мета\": null, \"вложено\": {\"a\": [1, -2.5, 3e2], \"b\": \"кавычка \\\" и перенос \\n строки\"}}"
	пер разобрано = json.разобрать(текст)
	если разобрано.ошибка() тогда
		возврат ложь
	конец
	пер значение = разобрано.получить(json.Значение.Ноль)

	пер имя = значение.поле("имя").значение().как_строку().получить("")
	пер версия = значение.поле("версия").значение().как_число().получить(0)
	пер стабильный = значение.поле("стабильный").значение().как_булево().получить(ложь)
	пер первый_тег = значение.поле("теги").значение().элемент(0).значение().как_строку().получить("")
	пер вложено = значение.поле("вложено").значение()
	пер a = вложено.поле("a").значение()
	пер третий = a.элемент(2).значение().как_число().получить(0)
	пер b = вложено.поле("b").значение().как_строку().получить("")

	пер round_trip = json.сериализовать(значение)
	пер снова = json.разобрать(round_trip)

	пер незакрытый = json.разобрать("[1, 2")

	имя == "panos" и версия == 7 и стабильный и первый_тег == "lang" и третий == 300 и b == "кавычка \" и перенос \n строки" и снова.успех() и незакрытый.ошибка()
конец

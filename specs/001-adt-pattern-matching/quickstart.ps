// Смоук-программа для US1..US3: объявление ADT, конструкторы,
// выражение `выбор` с биндерами и (косвенно) исчерпывающая проверка.

тип Фигура = перечисление
    Точка
    Круг(Число)
    Прямоугольник(Число, Число)
конец

функ площадь(ф: Фигура) -> Число
    возврат выбор ф
        Точка -> 0
        Круг(р) -> р * р * 314 / 100
        Прямоугольник(ш, в) -> ш * в
    конец
конец

функ старт() -> Число
    // Три разных варианта пропускаем через одну функцию.
    пер a = площадь(Точка)
    пер b = площадь(Круг(3))
    пер c = площадь(Прямоугольник(4, 5))
    возврат a + b + c
конец

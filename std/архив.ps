// tar (ustar/POSIX-совместимый минимум) — чистый panos поверх байтовых
// примитивов строки.байт/длина_байт/срез_байт/из_байтов (см. AGENTS.md/
// core/vm.odin) и core-модуля сжатие (gzip, обёртка над core:compress/gzip
// в Odin — DEFLATE/Хаффман на panos не реализуем, см. обсуждение).
//
// Формат заголовка (512 байт): name[100] mode[8] uid[8] gid[8] size[12]
// mtime[12] chksum[8] typeflag[1] linkname[100] magic[6] version[2]
// uname[32] gname[32] devmajor[8] devminor[8] prefix[155] pad[12].
// Числовые поля — ASCII-октал с завершающим null-байтом (кроме chksum:
// 6 октал-цифр + null + пробел). Архив заканчивается ДВУМЯ нулевыми
// 512-байтными блоками.
//
// Покрыто: обычные файлы и каталоги, только v7/ustar-подмножество полей,
// нужных для чтения/записи содержимого. НЕ покрыто: symlink/hardlink/
// devices, GNU-расширения длинных имён (>100 байт), PAX-заголовки.

импорт строки
импорт сжатие

экспорт тип Запись = структура
	имя:         Строка
	содержимое:  Строка
	каталог:     Булево
конец

функ это_нулевой_блок(поле: Строка) -> Булево
	пер i: Целое = 0
	пер всего = строки.длина_байт(поле)
	пока i < всего цикл
		если строки.байт(поле, i) <> 0 тогда
			возврат ложь
		конец
		i = i + 1
	конец
	истина
конец

функ обрезать_по_нулю(поле: Строка) -> Строка
	пер i: Целое = 0
	пер всего = строки.длина_байт(поле)
	пока i < всего цикл
		если строки.байт(поле, i) == 0 тогда
			прервать
		конец
		i = i + 1
	конец
	строки.срез_байт(поле, 0, i)
конец

// Парсит ведущий пробег ASCII-октал-цифр ('0'..'7', байты 48..55),
// останавливается на первом нечисловом байте (null/пробел/что угодно).
функ октал_в_число(поле: Строка) -> Целое
	пер значение: Целое = 0
	пер i: Целое = 0
	пер всего = строки.длина_байт(поле)
	пока i < всего цикл
		пер b = строки.байт(поле, i)
		если b < 48 или b > 55 тогда
			прервать
		конец
		значение = значение * 8 + (b - 48)
		i = i + 1
	конец
	значение
конец

функ нулевой_блок(n: Целое) -> Строка
	пер байты: Массив(Целое) = массив()
	пер i: Целое = 0
	пока i < n цикл
		байты.добавить(0)
		i = i + 1
	конец
	строки.из_байтов(байты)
конец

функ заполнить_справа(текст: Строка, ширина: Целое) -> Строка
	пер длина_текста = строки.длина_байт(текст)
	если длина_текста >= ширина тогда
		возврат строки.срез_байт(текст, 0, ширина)
	конец
	текст + нулевой_блок(ширина - длина_текста)
конец

// Целое -> ASCII-октал строка длиной РОВНО `ширина` байт (ведущие нули +
// завершающий null-байт).
функ число_в_октал(значение: Целое, ширина: Целое) -> Строка
	пер цифры: Массив(Целое) = массив()
	пер v = значение
	если v == 0 тогда
		цифры.добавить(48)
	конец
	пока v > 0 цикл
		цифры.добавить(48 + (v % 8))
		v = v / 8
	конец
	пер перевёрнуто: Массив(Целое) = массив()
	пер j: Целое = цифры.длина() - 1
	пока j >= 0 цикл
		перевёрнуто.добавить(цифры[j])
		j = j - 1
	конец
	пер нужно_нулей = (ширина - 1) - перевёрнуто.длина()
	пер результат: Массив(Целое) = массив()
	пер k: Целое = 0
	пока k < нужно_нулей цикл
		результат.добавить(48)
		k = k + 1
	конец
	пер m: Целое = 0
	пока m < перевёрнуто.длина() цикл
		результат.добавить(перевёрнуто[m])
		m = m + 1
	конец
	результат.добавить(0)
	строки.из_байтов(результат)
конец

функ сумма_байт(s: Строка) -> Целое
	пер сумма: Целое = 0
	пер i: Целое = 0
	пер всего = строки.длина_байт(s)
	пока i < всего цикл
		сумма = сумма + строки.байт(s, i)
		i = i + 1
	конец
	сумма
конец

функ выровнять_до_512(n: Целое) -> Целое
	пер остаток = n % 512
	если остаток == 0 тогда
		возврат n
	конец
	n + (512 - остаток)
конец

// Разбирает сырые (уже распакованные, если архив был .tar.gz) байты tar в
// список записей. Останавливается на первом полностью нулевом 512-байтном
// блоке (конец архива) — второй завершающий блок не проверяется, он не
// нужен для извлечения содержимого.
экспорт функ разобрать(данные: Строка) -> Массив(Запись)
	пер записи: Массив(Запись) = массив()
	пер смещение: Целое = 0
	пер всего = строки.длина_байт(данные)
	пока смещение + 512 <= всего цикл
		пер имя_поле = строки.срез_байт(данные, смещение, смещение + 100)
		если это_нулевой_блок(имя_поле) тогда
			прервать
		конец
		пер имя = обрезать_по_нулю(имя_поле)
		пер размер_поле = строки.срез_байт(данные, смещение + 124, смещение + 136)
		пер размер = октал_в_число(размер_поле)
		пер тип_байт = строки.байт(данные, смещение + 156)
		пер каталог = тип_байт == 53 // '5'

		пер начало_содержимого = смещение + 512
		пер содержимое = строки.срез_байт(данные, начало_содержимого, начало_содержимого + размер)

		записи.добавить(Запись(имя, содержимое, каталог))

		смещение = начало_содержимого + выровнять_до_512(размер)
	конец
	записи
конец

функ собрать_запись(запись: Запись) -> Строка
	пер имя = заполнить_справа(запись.имя, 100)
	пер режим_число: Целое = 420
	если запись.каталог тогда
		режим_число = 493
	конец
	пер режим = число_в_октал(режим_число, 8)
	пер uid = число_в_октал(0, 8)
	пер gid = число_в_октал(0, 8)
	пер размер_байт = строки.длина_байт(запись.содержимое)
	пер размер = число_в_октал(размер_байт, 12)
	пер mtime = число_в_октал(0, 12)
	пер тип_флаг = если запись.каталог тогда строки.из_байтов(массив(53)) иначе строки.из_байтов(массив(48)) конец
	пер linkname = нулевой_блок(100)
	пер magic = "ustar" + строки.из_байтов(массив(0))
	пер version = строки.из_байтов(массив(48, 48))
	пер uname = нулевой_блок(32)
	пер gname = нулевой_блок(32)
	пер devmajor = число_в_октал(0, 8)
	пер devminor = число_в_октал(0, 8)
	пер prefix = нулевой_блок(155)
	пер pad = нулевой_блок(12)

	пер до_чексуммы = имя + режим + uid + gid + размер + mtime
	пер после_чексуммы = тип_флаг + linkname + magic + version + uname + gname + devmajor + devminor + prefix + pad

	пер плейсхолдер = строки.из_байтов(массив(32, 32, 32, 32, 32, 32, 32, 32))
	пер сумма = сумма_байт(до_чексуммы + плейсхолдер + после_чексуммы)
	пер чексумма = число_в_октал(сумма, 7) + строки.из_байтов(массив(32))

	пер заголовок = до_чексуммы + чексумма + после_чексуммы
	пер содержимое_дополнено = запись.содержимое + нулевой_блок(выровнять_до_512(размер_байт) - размер_байт)

	заголовок + содержимое_дополнено
конец

// Собирает валидный (совместимый с GNU/BSD tar) архив из списка записей.
// Сжатие — отдельная забота (в этой сессии добавлено только чтение gzip,
// см. std/архив.ps шапку), результат этой функции — сырые tar-байты.
экспорт функ собрать(записи: Массив(Запись)) -> Строка
	пер результат = ""
	пер i: Целое = 0
	пока i < записи.длина() цикл
		результат = результат + собрать_запись(записи[i])
		i = i + 1
	конец
	результат + нулевой_блок(1024)
конец

// Удобство: сжатие.разжать_gzip + разобрать одним вызовом для .tar.gz.
экспорт функ разобрать_tar_gz(данные: Строка) -> Результат(Массив(Запись), Ошибка)
	выбор сжатие.разжать_gzip(данные)
		Результат.Успех(распаковано) -> Результат.Успех(разобрать(распаковано))
		Результат.Неудача(ош) -> Результат.Неудача(ош)
	конец
конец

импорт строки

// JSON: разбор + сериализация. Тот же архитектурный паттерн, что
// std/кодирование/toml.ps (Токенизатор -> Токен -> рекурсивный Парсер,
// Результат-based ошибки), но с полноценными escape-последовательностями
// в строках (TOML-версия их не разбирает) и сериализацией в обратную
// сторону (у toml.ps её нет). Числа — всегда Число (f64), большие целые
// теряют точность, как и везде в panos.

/// Один лексический токен JSON (тип + сырое значение).
экспорт тип Токен = структура
	тип_: Строка
	значение: Строка
конец

тип Токенизатор = структура
	текст: Строка
	поз: Целое
	длина: Целое
конец

функ новый_токенизатор(содержимое: Строка) -> Токенизатор
	Токенизатор(содержимое, 0, длина(содержимое))
конец

реализация Токенизатор
	функ прочитать_строку(это: Токенизатор) -> Токен
		это.поз = это.поз + 1
		пер результат = ""
		пока это.поз < это.длина и это.текст[это.поз] <> "\"" цикл
			пер символ = это.текст[это.поз]
			если символ == "\\" тогда
				это.поз = это.поз + 1
				если это.поз == это.длина тогда
					паника("json: незакрытая escape-последовательность")
				конец
				пер следующий = это.текст[это.поз]
				пер добавка = следующий
				если следующий == "n" тогда
					добавка = "\n"
				конец
				если следующий == "t" тогда
					добавка = "\t"
				конец
				если следующий == "r" тогда
					добавка = "\r"
				конец
				результат = результат + добавка
				это.поз = это.поз + 1
			иначе
				результат = результат + символ
				это.поз = это.поз + 1
			конец
		конец
		если это.поз == это.длина тогда
			паника("json: незакрытая строка")
		конец
		это.поз = это.поз + 1
		Токен("СТРОКА", результат)
	конец

	функ прочитать_число(это: Токенизатор) -> Токен
		пер начало = это.поз
		если это.поз < это.длина и это.текст[это.поз] == "-" тогда
			это.поз = это.поз + 1
		конец
		пока это.поз < это.длина и строки.это_цифра(это.текст[это.поз]) цикл
			это.поз = это.поз + 1
		конец
		если это.поз < это.длина и это.текст[это.поз] == "." тогда
			это.поз = это.поз + 1
			пока это.поз < это.длина и строки.это_цифра(это.текст[это.поз]) цикл
				это.поз = это.поз + 1
			конец
		конец
		если это.поз < это.длина и (это.текст[это.поз] == "e" или это.текст[это.поз] == "E") тогда
			это.поз = это.поз + 1
			если это.поз < это.длина и (это.текст[это.поз] == "+" или это.текст[это.поз] == "-") тогда
				это.поз = это.поз + 1
			конец
			пока это.поз < это.длина и строки.это_цифра(это.текст[это.поз]) цикл
				это.поз = это.поз + 1
			конец
		конец
		Токен("ЧИСЛО", строки.срез(это.текст, начало, это.поз))
	конец

	функ прочитать_ключевое_слово(это: Токенизатор) -> Токен
		пер начало = это.поз
		пока это.поз < это.длина и строки.это_буква(это.текст[это.поз]) цикл
			это.поз = это.поз + 1
		конец
		пер значение = строки.срез(это.текст, начало, это.поз)
		если значение == "true" тогда
			возврат Токен("БУЛЕВО", "true")
		конец
		если значение == "false" тогда
			возврат Токен("БУЛЕВО", "false")
		конец
		если значение == "null" тогда
			возврат Токен("НОЛЬ", "null")
		конец
		паника("json: неизвестное ключевое слово '" + значение + "'")
	конец

	функ следующий_токен(это: Токенизатор) -> Токен
		пока это.поз < это.длина цикл
			пер символ = это.текст[это.поз]
			если символ == " " или символ == "\t" или символ == "\r" или символ == "\n" тогда
				это.поз = это.поз + 1
				продолжить
			конец

			если символ == "{" тогда
				это.поз = это.поз + 1
				возврат Токен("ЛЕВАЯ_ФИГУРНАЯ", "{")
			конец
			если символ == "}" тогда
				это.поз = это.поз + 1
				возврат Токен("ПРАВАЯ_ФИГУРНАЯ", "}")
			конец
			если символ == "[" тогда
				это.поз = это.поз + 1
				возврат Токен("ЛЕВАЯ_СКОБКА", "[")
			конец
			если символ == "]" тогда
				это.поз = это.поз + 1
				возврат Токен("ПРАВАЯ_СКОБКА", "]")
			конец
			если символ == ":" тогда
				это.поз = это.поз + 1
				возврат Токен("ДВОЕТОЧИЕ", ":")
			конец
			если символ == "," тогда
				это.поз = это.поз + 1
				возврат Токен("ЗАПЯТАЯ", ",")
			конец
			если символ == "\"" тогда
				возврат это.прочитать_строку()
			конец
			если строки.это_буква(символ) тогда
				возврат это.прочитать_ключевое_слово()
			конец
			если строки.это_цифра(символ) или символ == "-" тогда
				возврат это.прочитать_число()
			конец

			паника("json: неизвестный символ '" + символ + "'")
		конец
		Токен("КОНЕЦ", "")
	конец
конец

/// Разобранное JSON-значение (null/булево/число/строка/список/объект).
экспорт тип Значение = перечисление
	Ноль
	Булево(Булево)
	Число(Число)
	Строка(Строка)
	Список(Массив(Значение))
	Объект(Соответствие(Строка, Значение))
конец

реализация Значение
	функ как_строку(это: Значение) -> Опция(Строка)
		выбор это
			Строка(с) -> Опция.Есть(с)
			_ -> Опция.Нет()
		конец
	конец

	функ как_число(это: Значение) -> Опция(Число)
		выбор это
			Число(ч) -> Опция.Есть(ч)
			_ -> Опция.Нет()
		конец
	конец

	функ как_булево(это: Значение) -> Опция(Булево)
		выбор это
			Булево(б) -> Опция.Есть(б)
			_ -> Опция.Нет()
		конец
	конец

	// Опция(Значение) — отсутствие ключа и "ключ есть, но значение не
	// Объект" иначе неразличимы, а вызывающему обычно всё равно, что из
	// двух произошло (тот же выбор, что toml.ps's .поле).
	функ поле(это: Значение, ключ: Строка) -> Опция(Значение)
		выбор это
			Объект(о) ->
				если о.есть(ключ) тогда
					Опция.Есть(о.получить(ключ, Значение.Ноль))
				иначе
					Опция.Нет()
				конец
			_ -> Опция.Нет()
		конец
	конец

	функ элемент(это: Значение, индекс: Целое) -> Опция(Значение)
		выбор это
			Список(с) ->
				если с.есть(индекс) тогда
					Опция.Есть(с.получить(индекс, Значение.Ноль))
				иначе
					Опция.Нет()
				конец
			_ -> Опция.Нет()
		конец
	конец
конец

тип Парсер = структура
	т:     Токенизатор
	токен: Токен
конец

функ новый_парсер(текст: Строка) -> Парсер
	пер т = новый_токенизатор(текст)
	пер начальный = т.следующий_токен()
	Парсер(т, начальный)
конец

реализация Парсер
	функ шаг(это: Парсер) -> Пусто
		это.токен = это.т.следующий_токен()
	конец

	функ разобрать_значение(это: Парсер) -> Результат(Значение, Ошибка)
		если это.токен.тип_ == "СТРОКА" тогда
			пер знач = это.токен.значение
			это.шаг()
			возврат Результат.Успех(Значение.Строка(знач))
		конец

		если это.токен.тип_ == "ЧИСЛО" тогда
			пер текст = это.токен.значение
			это.шаг()
			возврат выбор строки.в_число(текст)
				Результат.Успех(ч) -> Результат.Успех(Значение.Число(ч))
				Результат.Неудача(ош) -> Результат.Неудача(ош)
			конец
		конец

		если это.токен.тип_ == "БУЛЕВО" тогда
			пер булево_знач = это.токен.значение == "true"
			это.шаг()
			возврат Результат.Успех(Значение.Булево(булево_знач))
		конец

		если это.токен.тип_ == "НОЛЬ" тогда
			это.шаг()
			возврат Результат.Успех(Значение.Ноль)
		конец

		если это.токен.тип_ == "ЛЕВАЯ_СКОБКА" тогда
			это.шаг()
			пер элементы: Массив(Значение) = массив()
			если это.токен.тип_ <> "ПРАВАЯ_СКОБКА" тогда
				пока истина цикл
					пер элемент_результат = это.разобрать_значение()
					если элемент_результат.ошибка() тогда
						возврат элемент_результат
					конец
					элементы.добавить(элемент_результат.получить(Значение.Ноль))

					если это.токен.тип_ == "ЗАПЯТАЯ" тогда
						это.шаг()
					иначе
						прервать
					конец
				конец
			конец
			если это.токен.тип_ <> "ПРАВАЯ_СКОБКА" тогда
				возврат Результат.Неудача(Ошибка("json", "ожидалась ']'"))
			конец
			это.шаг()
			возврат Результат.Успех(Значение.Список(элементы))
		конец

		если это.токен.тип_ == "ЛЕВАЯ_ФИГУРНАЯ" тогда
			это.шаг()
			пер поля: Соответствие(Строка, Значение) = соответствие()
			если это.токен.тип_ <> "ПРАВАЯ_ФИГУРНАЯ" тогда
				пока истина цикл
					если это.токен.тип_ <> "СТРОКА" тогда
						возврат Результат.Неудача(Ошибка("json", "ожидался ключ-строка"))
					конец
					пер ключ = это.токен.значение
					это.шаг()
					если это.токен.тип_ <> "ДВОЕТОЧИЕ" тогда
						возврат Результат.Неудача(Ошибка("json", "ожидалось ':' после ключа"))
					конец
					это.шаг()
					пер значение_результат = это.разобрать_значение()
					если значение_результат.ошибка() тогда
						возврат значение_результат
					конец
					поля[ключ] = значение_результат.получить(Значение.Ноль)

					если это.токен.тип_ == "ЗАПЯТАЯ" тогда
						это.шаг()
					иначе
						прервать
					конец
				конец
			конец
			если это.токен.тип_ <> "ПРАВАЯ_ФИГУРНАЯ" тогда
				возврат Результат.Неудача(Ошибка("json", "ожидалась '}'"))
			конец
			это.шаг()
			возврат Результат.Успех(Значение.Объект(поля))
		конец

		возврат Результат.Неудача(Ошибка("json", "ожидалось значение, получено: " + это.токен.значение))
	конец
конец

/// Разбирает JSON-текст в дерево Значение.
экспорт функ разобрать(текст: Строка) -> Результат(Значение, Ошибка)
	пер п = новый_парсер(текст)
	пер результат = п.разобрать_значение()
	если результат.ошибка() тогда
		возврат результат
	конец
	если п.токен.тип_ <> "КОНЕЦ" тогда
		возврат Результат.Неудача(Ошибка("json", "лишние данные после значения"))
	конец
	результат
конец

функ экранировать(текст: Строка) -> Строка
	пер результат = ""
	пер i: Целое = 0
	пер n = длина(текст)
	пока i < n цикл
		пер символ = текст[i]
		пер добавка = символ
		если символ == "\"" тогда
			добавка = "\\\""
		конец
		если символ == "\\" тогда
			добавка = "\\\\"
		конец
		если символ == "\n" тогда
			добавка = "\\n"
		конец
		если символ == "\t" тогда
			добавка = "\\t"
		конец
		если символ == "\r" тогда
			добавка = "\\r"
		конец
		результат = результат + добавка
		i = i + 1
	конец
	результат
конец

/// Сериализует дерево Значение обратно в JSON-текст.
экспорт функ сериализовать(значение: Значение) -> Строка
	выбор значение
		Ноль -> "null"
		Булево(б) ->
			если б тогда
				"true"
			иначе
				"false"
			конец
		Число(ч) -> строки.из_числа(ч)
		Строка(с) -> "\"" + экранировать(с) + "\""
		Список(элементы) -> сериализовать_список(элементы)
		Объект(поля) -> сериализовать_объект(поля)
	конец
конец

функ сериализовать_список(элементы: Массив(Значение)) -> Строка
	пер результат = "["
	пер i: Целое = 0
	пер n = элементы.длина()
	пока i < n цикл
		результат = результат + сериализовать(элементы.получить(i, Значение.Ноль))
		если i < n - 1 тогда
			результат = результат + ","
		конец
		i = i + 1
	конец
	результат + "]"
конец

функ сериализовать_объект(поля: Соответствие(Строка, Значение)) -> Строка
	пер записи = поля.записи()
	пер результат = "{"
	пер i: Целое = 0
	пер n = записи.длина()
	пока i < n цикл
		пер запись = записи.получить(i, ("", Значение.Ноль))
		результат = результат + "\"" + экранировать(запись.0) + "\":" + сериализовать(запись.1)
		если i < n - 1 тогда
			результат = результат + ","
		конец
		i = i + 1
	конец
	результат + "}"
конец

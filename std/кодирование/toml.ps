импорт строки

экспорт тип Токен = структура
	тип_: Строка
	значение: Строка
конец

тип Токенизатор = структура
	текст: Строка
	поз: Целое
	длина: Целое
конец

функ новый_токенизатор(содержимое: Строка) -> Токенизатор
	пер т = Токенизатор(содержимое, 0, длина(содержимое))
	возврат т
конец

реализация Токен
	функ вСтроку(это: Токен) -> Строка
		это.тип_ + ": " + это.значение
	конец
конец

реализация Токенизатор

	функ прочитать_число(это: Токенизатор) -> Токен
		пер начало = это.поз
		если это.текст[это.поз] == "-" тогда
			это.поз = это.поз + 1
		конец

		пока это.поз < это.длина и строки.это_цифра(это.текст[это.поз]) цикл
			это.поз = это.поз + 1
		конец

		пер значение = строки.срез(это.текст, начало, это.поз)

		возврат Токен("ЧИСЛО", значение)
	конец

	функ прочитать_строку(это: Токенизатор) -> Токен
		это.поз = это.поз + 1
		пер начало = это.поз
		пока это.поз < это.длина и это.текст[это.поз] <> "\"" цикл
			это.поз = это.поз + 1
		конец

		если это.поз > это.длина или это.поз == это.длина тогда
			паника("Незакрытая строка")
		конец

		пер значение = строки.срез(это.текст, начало, это.поз)

		это.поз = это.поз + 1
		возврат Токен("СТРОКА", значение)
	конец

	функ прочитать_ключ_или_булево(это: Токенизатор) -> Токен
		пер начало = это.поз
		пока это.поз < это.длина и (строки.цифра_или_буква(это.текст[это.поз]) или это.текст[это.поз] == "-") цикл
			это.поз = это.поз + 1
		конец

		пер значение = строки.срез(это.текст, начало, это.поз)

		если значение == "true" тогда
			возврат Токен("БУЛЕВО", "true")
		конец
		если значение == "false" тогда
			возврат Токен("БУЛЕВО", "false")
		конец
		возврат Токен("КЛЮЧ", значение)
	конец

	функ следующий_токен(это: Токенизатор) -> Токен
		пока это.поз < это.длина цикл
			пер символ = это.текст[это.поз]
			если символ == " " или символ == "\t" или символ == "\r" тогда
				это.поз = это.поз + 1
				продолжить
			конец

			если символ == "#" тогда
				пока это.поз < это.длина и это.текст[это.поз] <> "\n" цикл
					это.поз = это.поз + 1
				конец
				продолжить
			конец

			если символ == "\n" тогда
				это.поз = это.поз + 1
				возврат Токен("НОВАЯ_СТРОКА", "\n")
			конец

			если символ == "=" тогда
				это.поз = это.поз + 1
				возврат Токен("РАВНО", "=")
			конец

			если символ == "[" тогда
				это.поз = это.поз + 1
				возврат Токен("ЛЕВАЯ_СКОБКА", "[")
			конец

			если символ == "]" тогда
				это.поз = это.поз + 1
				возврат Токен("ПРАВАЯ_СКОБКА", "]")
			конец

			если символ == "," тогда
				это.поз = это.поз + 1
				возврат Токен("ЗАПЯТАЯ", ",")
			конец

			если символ == "\"" тогда
				возврат это.прочитать_строку()
			конец

			если строки.это_буква(символ) или символ == "_" тогда
				возврат это.прочитать_ключ_или_булево()
			конец

			если строки.это_цифра(символ) или символ == "-" тогда
				возврат это.прочитать_число()
			конец

			паника("Неизвестный символ")
		конец

		возврат Токен("КОНЕЦ", "")
	конец
конец

// --- ДЕРЕВО ЗНАЧЕНИЙ И ПАРСЕР ---
//
// Поддержано: [секции] (только плоские, "a.b" как имя одной секции не
// разбирается отдельно), ключ = значение, строки/числа/булевы, массивы
// скаляров и вложенных массивов В ОДНУ СТРОКУ (многострочные массивы,
// инлайн-таблицы `{ }` и точечные ключи не поддержаны — сознательное
// ограничение объёма, не полный TOML).

экспорт тип Значение = перечисление
	Строка(Строка)
	Число(Число)
	Булево(Булево)
	Список(Массив(Значение))
	Таблица(Соответствие(Строка, Значение))
конец

реализация Значение
	функ как_строку(это: Значение) -> Опция(Строка)
		выбор это
			Строка(с) -> Опция.Есть(с)
			_ -> Опция.Нет()
		конец
	конец

	функ как_число(это: Значение) -> Опция(Число)
		выбор это
			Число(ч) -> Опция.Есть(ч)
			_ -> Опция.Нет()
		конец
	конец

	функ как_булево(это: Значение) -> Опция(Булево)
		выбор это
			Булево(б) -> Опция.Есть(б)
			_ -> Опция.Нет()
		конец
	конец

	// Опция(Значение), а не сам элемент — отсутствие ключа/выход за
	// границы и "ключ есть, но значение не Таблица/Список" неразличимы
	// иначе, а вызывающему обычно всё равно, что из двух произошло.
	функ поле(это: Значение, ключ: Строка) -> Опция(Значение)
		выбор это
			Таблица(т) ->
				если т.есть(ключ) тогда
					Опция.Есть(т.получить(ключ, Значение.Число(0)))
				иначе
					Опция.Нет()
				конец
			_ -> Опция.Нет()
		конец
	конец

	функ элемент(это: Значение, индекс: Целое) -> Опция(Значение)
		выбор это
			Список(с) ->
				если с.есть(индекс) тогда
					Опция.Есть(с.получить(индекс, Значение.Число(0)))
				иначе
					Опция.Нет()
				конец
			_ -> Опция.Нет()
		конец
	конец
конец

тип Парсер = структура
	т:     Токенизатор
	токен: Токен
конец

функ новый_парсер(текст: Строка) -> Парсер
	пер т = новый_токенизатор(текст)
	пер начальный = т.следующий_токен()
	возврат Парсер(т, начальный)
конец

реализация Парсер
	функ шаг(это: Парсер) -> Пусто
		это.токен = это.т.следующий_токен()
	конец

	// Скаляр или '[' массив (рекурсивно — элементы массива тоже проходят
	// через разобрать_значение, так что Список(Список(...)) работает).
	функ разобрать_значение(это: Парсер) -> Результат(Значение, Ошибка)
		если это.токен.тип_ == "СТРОКА" тогда
			пер знач = это.токен.значение
			это.шаг()
			возврат Результат.Успех(Значение.Строка(знач))
		конец

		если это.токен.тип_ == "ЧИСЛО" тогда
			пер текст = это.токен.значение
			это.шаг()
			возврат выбор строки.в_число(текст)
				Результат.Успех(ч) -> Результат.Успех(Значение.Число(ч))
				Результат.Неудача(ош) -> Результат.Неудача(ош)
			конец
		конец

		если это.токен.тип_ == "БУЛЕВО" тогда
			пер булево_знач = это.токен.значение == "true"
			это.шаг()
			возврат Результат.Успех(Значение.Булево(булево_знач))
		конец

		если это.токен.тип_ == "ЛЕВАЯ_СКОБКА" тогда
			это.шаг()
			пер элементы: Массив(Значение) = массив()
			если это.токен.тип_ <> "ПРАВАЯ_СКОБКА" тогда
				пока истина цикл
					пер элемент_результат = это.разобрать_значение()
					если элемент_результат.ошибка() тогда
						возврат элемент_результат
					конец
					элементы.добавить(элемент_результат.получить(Значение.Число(0)))

					если это.токен.тип_ == "ЗАПЯТАЯ" тогда
						это.шаг()
						если это.токен.тип_ == "ПРАВАЯ_СКОБКА" тогда
							прервать
						конец
					иначе
						прервать
					конец
				конец
			конец
			если это.токен.тип_ <> "ПРАВАЯ_СКОБКА" тогда
				возврат Результат.Неудача(Ошибка("toml", "ожидалась ']' в конце массива"))
			конец
			это.шаг()
			возврат Результат.Успех(Значение.Список(элементы))
		конец

		возврат Результат.Неудача(Ошибка("toml", "ожидалось значение, получено: " + это.токен.значение))
	конец
конец

экспорт функ разобрать(текст: Строка) -> Результат(Значение, Ошибка)
	пер п = новый_парсер(текст)
	пер корень: Соответствие(Строка, Значение) = соответствие()
	пер текущая = корень

	пока п.токен.тип_ <> "КОНЕЦ" цикл
		если п.токен.тип_ == "НОВАЯ_СТРОКА" тогда
			п.шаг()
			продолжить
		конец

		если п.токен.тип_ == "ЛЕВАЯ_СКОБКА" тогда
			п.шаг()
			если п.токен.тип_ <> "КЛЮЧ" тогда
				возврат Результат.Неудача(Ошибка("toml", "ожидалось имя секции после '['"))
			конец
			пер имя_секции = п.токен.значение
			п.шаг()
			если п.токен.тип_ <> "ПРАВАЯ_СКОБКА" тогда
				возврат Результат.Неудача(Ошибка("toml", "ожидалась ']' после имени секции"))
			конец
			п.шаг()

			пер новая: Соответствие(Строка, Значение) = соответствие()
			корень[имя_секции] = Значение.Таблица(новая)
			текущая = новая
			продолжить
		конец

		если п.токен.тип_ == "КЛЮЧ" тогда
			пер ключ = п.токен.значение
			п.шаг()
			если п.токен.тип_ <> "РАВНО" тогда
				возврат Результат.Неудача(Ошибка("toml", "ожидался '=' после ключа '" + ключ + "'"))
			конец
			п.шаг()

			пер результат_значения = п.разобрать_значение()
			если результат_значения.ошибка() тогда
				возврат результат_значения
			конец
			текущая[ключ] = результат_значения.получить(Значение.Число(0))
			продолжить
		конец

		возврат Результат.Неудача(Ошибка("toml", "неожиданный токен: " + п.токен.значение))
	конец

	возврат Результат.Успех(Значение.Таблица(корень))
конец

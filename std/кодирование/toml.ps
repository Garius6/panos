// TOML v1.0.0 (близко к полному покрытию, hand-written, без внешних/
// нативных TOML-библиотек — весь разбор и сериализация на чистом panos
// поверх строки.байт/из_байтов, см. AGENTS.md).
//
// Поддержано: базовые/литеральные строки (в т.ч. многострочные """.../
// '''...''' с обрезкой ведущего перевода строки и line-continuation "\<нс>"
// у многострочных базовых), полный набор escape-последовательностей
// (\n \t \r \b \f \" \\ \uXXXX \UXXXXXXXX), целые (десятичные со знаком,
// 0x/0o/0b без знака) и дробные (экспонента, inf/nan и их ±варианты) числа
// с '_'-разделителями, булевы, дата-время (хранится как сырой текст —
// структурного типа даты в языке нет), точечные ключи (a.b.c = 1),
// вложенные секции [a.b.c], массивы таблиц [[a.b]], инлайн-таблицы
// { x = 1, y = 2 }, многострочные массивы, кавычечные ключи.
//
// Сознательно НЕ поддержано (ниша, не стоит объёма для hand-written
// парсера): дата-время с пробелом вместо 'T' между датой и временем
// (это два токена вместо одного — используйте 'T'), bare-ключи,
// начинающиеся с цифры (только [A-Za-zА-Яа-я_], без ведущей цифры).

импорт строки

// ==================== ТОКЕНИЗАТОР ====================

экспорт тип Токен = структура
	тип_: Строка
	значение: Строка
конец

реализация Токен
	функ вСтроку(это: Токен) -> Строка
		это.тип_ + ": " + это.значение
	конец
конец

тип Токенизатор = структура
	текст: Строка
	поз: Целое
	длина: Целое
конец

функ новый_токенизатор(содержимое: Строка) -> Токенизатор
	Токенизатор(содержимое, 0, длина(содержимое))
конец

функ это_ключ_старт(с: Строка) -> Булево
	строки.это_буква(с) или с == "_"
конец

функ это_ключ_продолжение(с: Строка) -> Булево
	строки.цифра_или_буква(с) или с == "_" или с == "-"
конец

функ это_число_старт(с: Строка) -> Булево
	строки.это_цифра(с) или с == "+" или с == "-"
конец

функ это_число_продолжение(с: Строка) -> Булево
	строки.цифра_или_буква(с) или с == "_" или с == "+" или с == "-" или с == "." или с == ":"
конец

функ это_шестн_цифра(с: Строка) -> Булево
	строки.это_цифра(с) или с == "a" или с == "A" или с == "b" или с == "B" или с == "c" или с == "C" или с == "d" или с == "D" или с == "e" или с == "E" или с == "f" или с == "F"
конец

// Значение шестнадцатеричной ЦИФРЫ (десятичные цифры тоже покрыты,
// используется и для обычных целых, и для 0x/\u-эскейпов).
функ значение_цифры(с: Строка) -> Целое
	если с == "0" тогда возврат 0 конец
	если с == "1" тогда возврат 1 конец
	если с == "2" тогда возврат 2 конец
	если с == "3" тогда возврат 3 конец
	если с == "4" тогда возврат 4 конец
	если с == "5" тогда возврат 5 конец
	если с == "6" тогда возврат 6 конец
	если с == "7" тогда возврат 7 конец
	если с == "8" тогда возврат 8 конец
	если с == "9" тогда возврат 9 конец
	если с == "a" или с == "A" тогда возврат 10 конец
	если с == "b" или с == "B" тогда возврат 11 конец
	если с == "c" или с == "C" тогда возврат 12 конец
	если с == "d" или с == "D" тогда возврат 13 конец
	если с == "e" или с == "E" тогда возврат 14 конец
	если с == "f" или с == "F" тогда возврат 15 конец
	0
конец

функ цифра_в_hex(n: Целое) -> Строка
	если n == 0 тогда возврат "0" конец
	если n == 1 тогда возврат "1" конец
	если n == 2 тогда возврат "2" конец
	если n == 3 тогда возврат "3" конец
	если n == 4 тогда возврат "4" конец
	если n == 5 тогда возврат "5" конец
	если n == 6 тогда возврат "6" конец
	если n == 7 тогда возврат "7" конец
	если n == 8 тогда возврат "8" конец
	если n == 9 тогда возврат "9" конец
	если n == 10 тогда возврат "a" конец
	если n == 11 тогда возврат "b" конец
	если n == 12 тогда возврат "c" конец
	если n == 13 тогда возврат "d" конец
	если n == 14 тогда возврат "e" конец
	"f"
конец

// Юникод-кодовая точка (Целое) -> UTF-8 байты -> Строка. Чистая
// арифметика (/, %, +) без битовых операторов (их в языке нет) —
// работает, потому что диапазоны байт-компонентов не пересекаются:
// 128 + (v % 64) арифметически равно 0x80 | (v & 0x3F).
функ кодовая_точка_в_utf8(cp: Целое) -> Строка
	если cp <= 127 тогда
		возврат строки.из_байтов(массив(cp))
	конец
	если cp <= 2047 тогда
		возврат строки.из_байтов(массив(192 + cp / 64, 128 + cp % 64))
	конец
	если cp <= 65535 тогда
		возврат строки.из_байтов(массив(224 + cp / 4096, 128 + (cp / 64) % 64, 128 + cp % 64))
	конец
	строки.из_байтов(массив(240 + cp / 262144, 128 + (cp / 4096) % 64, 128 + (cp / 64) % 64, 128 + cp % 64))
конец

реализация Токенизатор
	функ символ_на(это: Токенизатор, смещение: Целое) -> Строка
		пер idx = это.поз + смещение
		если idx < 0 или idx >= это.длина тогда
			возврат ""
		конец
		строки.срез(это.текст, idx, idx + 1)
	конец

	функ пропустить_пробелы_и_переводы(это: Токенизатор) -> Пусто
		пока это.поз < это.длина и (это.текст[это.поз] == " " или это.текст[это.поз] == "\t" или это.текст[это.поз] == "\r" или это.текст[это.поз] == "\n") цикл
			это.поз = это.поз + 1
		конец
	конец

	функ прочитать_ключ(это: Токенизатор) -> Токен
		пер начало = это.поз
		это.поз = это.поз + 1
		пока это.поз < это.длина и это_ключ_продолжение(это.текст[это.поз]) цикл
			это.поз = это.поз + 1
		конец
		Токен("КЛЮЧ", строки.срез(это.текст, начало, это.поз))
	конец

	функ прочитать_число_или_дату(это: Токенизатор) -> Токен
		пер начало = это.поз
		это.поз = это.поз + 1
		пока это.поз < это.длина и это_число_продолжение(это.текст[это.поз]) цикл
			это.поз = это.поз + 1
		конец
		Токен("ЧИСЛО", строки.срез(это.текст, начало, это.поз))
	конец

	функ прочитать_юникод_escape(это: Токенизатор, кол_во: Целое) -> Строка
		пер кодовая_точка: Целое = 0
		пер i: Целое = 0
		пока i < кол_во цикл
			если это.поз >= это.длина или не это_шестн_цифра(это.текст[это.поз]) тогда
				паника("panos: некорректный \\u/\\U escape в TOML-строке")
			конец
			кодовая_точка = кодовая_точка * 16 + значение_цифры(это.текст[это.поз])
			это.поз = это.поз + 1
			i = i + 1
		конец
		кодовая_точка_в_utf8(кодовая_точка)
	конец

	// это.поз указывает на символ СРАЗУ ПОСЛЕ '\\'.
	функ прочитать_escape(это: Токенизатор) -> Строка
		если это.поз >= это.длина тогда
			паника("panos: неожиданный конец строки после '\\' в TOML")
		конец
		пер с = это.текст[это.поз]
		если с == "n" тогда
			это.поз = это.поз + 1
			возврат "\n"
		конец
		если с == "t" тогда
			это.поз = это.поз + 1
			возврат "\t"
		конец
		если с == "r" тогда
			это.поз = это.поз + 1
			возврат "\r"
		конец
		если с == "\"" тогда
			это.поз = это.поз + 1
			возврат "\""
		конец
		если с == "\\" тогда
			это.поз = это.поз + 1
			возврат "\\"
		конец
		если с == "b" тогда
			это.поз = это.поз + 1
			возврат строки.из_байтов(массив(8))
		конец
		если с == "f" тогда
			это.поз = это.поз + 1
			возврат строки.из_байтов(массив(12))
		конец
		если с == "u" тогда
			это.поз = это.поз + 1
			возврат это.прочитать_юникод_escape(4)
		конец
		если с == "U" тогда
			это.поз = это.поз + 1
			возврат это.прочитать_юникод_escape(8)
		конец
		паника("panos: неизвестная escape-последовательность '\\" + с + "' в TOML-строке")
	конец

	функ прочитать_однострочную(это: Токенизатор, литеральная: Булево) -> Токен
		пер кавычка = если литеральная тогда "'" иначе "\"" конец
		это.поз = это.поз + 1
		пер результат = ""
		пока истина цикл
			если это.поз >= это.длина тогда
				паника("panos: незакрытая строка TOML")
			конец
			пер с = это.текст[это.поз]
			если с == кавычка тогда
				прервать
			конец
			если с == "\n" тогда
				паника("panos: перевод строки внутри однострочной строки TOML")
			конец
			если (не литеральная) и с == "\\" тогда
				это.поз = это.поз + 1
				результат = результат + это.прочитать_escape()
			иначе
				результат = результат + с
				это.поз = это.поз + 1
			конец
		конец
		это.поз = это.поз + 1
		Токен("СТРОКА", результат)
	конец

	функ прочитать_многострочную(это: Токенизатор, литеральная: Булево) -> Токен
		пер кавычка = если литеральная тогда "'" иначе "\"" конец
		это.поз = это.поз + 3
		если это.поз < это.длина и это.текст[это.поз] == "\n" тогда
			это.поз = это.поз + 1
		конец
		пер результат = ""
		пока истина цикл
			если это.поз >= это.длина тогда
				паника("panos: незакрытая многострочная строка TOML")
			конец
			если это.символ_на(0) == кавычка и это.символ_на(1) == кавычка и это.символ_на(2) == кавычка тогда
				прервать
			конец
			пер с = это.текст[это.поз]
			если (не литеральная) и с == "\\" и это.символ_на(1) == "\n" тогда
				это.поз = это.поз + 2
				это.пропустить_пробелы_и_переводы()
			иначе
				если (не литеральная) и с == "\\" тогда
					это.поз = это.поз + 1
					результат = результат + это.прочитать_escape()
				иначе
					результат = результат + с
					это.поз = это.поз + 1
				конец
			конец
		конец
		это.поз = это.поз + 3
		Токен("СТРОКА", результат)
	конец

	функ следующий_токен(это: Токенизатор) -> Токен
		пока это.поз < это.длина цикл
			пер символ = это.текст[это.поз]
			если символ == " " или символ == "\t" или символ == "\r" тогда
				это.поз = это.поз + 1
				продолжить
			конец

			если символ == "#" тогда
				пока это.поз < это.длина и это.текст[это.поз] <> "\n" цикл
					это.поз = это.поз + 1
				конец
				продолжить
			конец

			если символ == "\n" тогда
				это.поз = это.поз + 1
				возврат Токен("НОВАЯ_СТРОКА", "\n")
			конец

			если символ == "=" тогда
				это.поз = это.поз + 1
				возврат Токен("РАВНО", "=")
			конец

			если символ == "." тогда
				это.поз = это.поз + 1
				возврат Токен("ТОЧКА", ".")
			конец

			если символ == "," тогда
				это.поз = это.поз + 1
				возврат Токен("ЗАПЯТАЯ", ",")
			конец

			если символ == "[" тогда
				это.поз = это.поз + 1
				возврат Токен("ЛЕВАЯ_СКОБКА", "[")
			конец

			если символ == "]" тогда
				это.поз = это.поз + 1
				возврат Токен("ПРАВАЯ_СКОБКА", "]")
			конец

			если символ == "{" тогда
				это.поз = это.поз + 1
				возврат Токен("ФИГ_ЛЕВАЯ", "{")
			конец

			если символ == "}" тогда
				это.поз = это.поз + 1
				возврат Токен("ФИГ_ПРАВАЯ", "}")
			конец

			если символ == "\"" тогда
				если это.символ_на(1) == "\"" и это.символ_на(2) == "\"" тогда
					возврат это.прочитать_многострочную(ложь)
				конец
				возврат это.прочитать_однострочную(ложь)
			конец

			если символ == "'" тогда
				если это.символ_на(1) == "'" и это.символ_на(2) == "'" тогда
					возврат это.прочитать_многострочную(истина)
				конец
				возврат это.прочитать_однострочную(истина)
			конец

			если это_ключ_старт(символ) тогда
				возврат это.прочитать_ключ()
			конец

			если это_число_старт(символ) тогда
				возврат это.прочитать_число_или_дату()
			конец

			паника("panos: неожиданный символ в TOML: '" + символ + "'")
		конец

		возврат Токен("КОНЕЦ", "")
	конец
конец

// ==================== ЗНАЧЕНИЕ ====================

экспорт тип Значение = перечисление
	Строка(Строка)
	Целое(Целое)
	Число(Число)
	Булево(Булево)
	Время(Строка)
	Список(Массив(Значение))
	Таблица(Соответствие(Строка, Значение))
конец

реализация Значение
	функ как_строку(это: Значение) -> Опция(Строка)
		выбор это
			Строка(с) -> Опция.Есть(с)
			_ -> Опция.Нет()
		конец
	конец

	функ как_целое(это: Значение) -> Опция(Целое)
		выбор это
			Целое(ц) -> Опция.Есть(ц)
			_ -> Опция.Нет()
		конец
	конец

	// Число ИЛИ Целое (расширенное до Число через строковый круговой путь —
	// прямой коэрсии Целое->Число в языке всё ещё нет, см. std/математика.ps).
	функ как_число(это: Значение) -> Опция(Число)
		выбор это
			Число(ч) -> Опция.Есть(ч)
			Целое(ц) -> Опция.Есть(строки.в_число(строки.из_целого(ц)).получить(0.0))
			_ -> Опция.Нет()
		конец
	конец

	функ как_булево(это: Значение) -> Опция(Булево)
		выбор это
			Булево(б) -> Опция.Есть(б)
			_ -> Опция.Нет()
		конец
	конец

	// Сырой текст дата-время литерала (без разбора на компоненты).
	функ как_время(это: Значение) -> Опция(Строка)
		выбор это
			Время(т) -> Опция.Есть(т)
			_ -> Опция.Нет()
		конец
	конец

	// Опция(Значение), а не сам элемент — отсутствие ключа/выход за
	// границы и "ключ есть, но значение не Таблица/Список" неразличимы
	// иначе, а вызывающему обычно всё равно, что из двух произошло.
	функ поле(это: Значение, ключ: Строка) -> Опция(Значение)
		выбор это
			Таблица(т) ->
				если т.есть(ключ) тогда
					Опция.Есть(т.получить(ключ, Значение.Булево(ложь)))
				иначе
					Опция.Нет()
				конец
			_ -> Опция.Нет()
		конец
	конец

	функ элемент(это: Значение, индекс: Целое) -> Опция(Значение)
		выбор это
			Список(с) ->
				если с.есть(индекс) тогда
					Опция.Есть(с.получить(индекс, Значение.Булево(ложь)))
				иначе
					Опция.Нет()
				конец
			_ -> Опция.Нет()
		конец
	конец
конец

// ==================== РАЗБОР ЧИСЕЛ/ДАТ ====================

функ убрать_подчёркивания(текст: Строка) -> Строка
	пер результат = ""
	пер i: Целое = 0
	пер n = длина(текст)
	пока i < n цикл
		пер с = текст[i]
		если с <> "_" тогда
			результат = результат + с
		конец
		i = i + 1
	конец
	результат
конец

// Эвристика без разбора компонентов: дата/время содержит ':' (время)
// либо '-' НЕ на позиции 0 (дата-разделители; позиция 0 — это знак
// числа, а не разделитель).
функ это_дата_или_время(текст: Строка) -> Булево
	если строки.содержит(текст, ":") тогда
		возврат истина
	конец
	пер n = длина(текст)
	пер i: Целое = 1
	пока i < n цикл
		если текст[i] == "-" тогда
			возврат истина
		конец
		i = i + 1
	конец
	ложь
конец

функ разобрать_целое_со_знаком(текст: Строка) -> Целое
	пер отрицательное = ложь
	пер тело = текст
	если длина(тело) > 0 и (тело[0] == "-" или тело[0] == "+") тогда
		отрицательное = тело[0] == "-"
		тело = строки.срез(тело, 1, длина(тело))
	конец
	пер значение: Целое = 0
	пер i: Целое = 0
	пер n = длина(тело)
	пока i < n цикл
		значение = значение * 10 + значение_цифры(тело[i])
		i = i + 1
	конец
	если отрицательное тогда
		возврат 0 - значение
	конец
	значение
конец

функ разобрать_целое_в_основании(тело: Строка, основание: Целое) -> Целое
	пер значение: Целое = 0
	пер i: Целое = 0
	пер n = длина(тело)
	пока i < n цикл
		значение = значение * основание + значение_цифры(тело[i])
		i = i + 1
	конец
	значение
конец

функ разобрать_число_с_плавающей(текст: Строка) -> Результат(Значение, Ошибка)
	выбор строки.в_число(текст)
		Результат.Успех(ч) -> Результат.Успех(Значение.Число(ч))
		Результат.Неудача(ош) -> Результат.Неудача(ош)
	конец
конец

экспорт функ классифицировать_число(текст: Строка) -> Результат(Значение, Ошибка)
	если это_дата_или_время(текст) тогда
		возврат Результат.Успех(Значение.Время(текст))
	конец

	если строки.начинается_с(текст, "0x") или строки.начинается_с(текст, "0X") тогда
		возврат Результат.Успех(Значение.Целое(разобрать_целое_в_основании(убрать_подчёркивания(строки.срез(текст, 2, длина(текст))), 16)))
	конец
	если строки.начинается_с(текст, "0o") или строки.начинается_с(текст, "0O") тогда
		возврат Результат.Успех(Значение.Целое(разобрать_целое_в_основании(убрать_подчёркивания(строки.срез(текст, 2, длина(текст))), 8)))
	конец
	если строки.начинается_с(текст, "0b") или строки.начинается_с(текст, "0B") тогда
		возврат Результат.Успех(Значение.Целое(разобрать_целое_в_основании(убрать_подчёркивания(строки.срез(текст, 2, длина(текст))), 2)))
	конец

	если текст == "nan" или текст == "+nan" или текст == "-nan" тогда
		возврат Результат.Успех(Значение.Число(0.0 / 0.0))
	конец
	если текст == "inf" или текст == "+inf" тогда
		возврат Результат.Успех(Значение.Число(1.0 / 0.0))
	конец
	если текст == "-inf" тогда
		возврат Результат.Успех(Значение.Число(0.0 - 1.0 / 0.0))
	конец

	если строки.содержит(текст, ".") или строки.содержит(текст, "e") или строки.содержит(текст, "E") тогда
		возврат разобрать_число_с_плавающей(убрать_подчёркивания(текст))
	конец

	возврат Результат.Успех(Значение.Целое(разобрать_целое_со_знаком(убрать_подчёркивания(текст))))
конец

// ==================== ПАРСЕР ====================

тип Парсер = структура
	т:     Токенизатор
	токен: Токен
конец

функ новый_парсер(текст: Строка) -> Парсер
	пер т = новый_токенизатор(текст)
	пер начальный = т.следующий_токен()
	Парсер(т, начальный)
конец

реализация Парсер
	функ шаг(это: Парсер) -> Пусто
		это.токен = это.т.следующий_токен()
	конец

	функ пропустить_переводы(это: Парсер) -> Пусто
		пока это.токен.тип_ == "НОВАЯ_СТРОКА" цикл
			это.шаг()
		конец
	конец

	// Ключ ИЛИ точечный путь ключа: a / a.b.c / "a b".c / ...
	функ разобрать_путь_ключа(это: Парсер) -> Результат(Массив(Строка), Ошибка)
		пер сегменты: Массив(Строка) = массив()
		пока истина цикл
			если это.токен.тип_ <> "КЛЮЧ" и это.токен.тип_ <> "СТРОКА" тогда
				возврат Результат.Неудача(Ошибка("toml", "ожидался ключ, получено: '" + это.токен.значение + "'"))
			конец
			сегменты.добавить(это.токен.значение)
			это.шаг()
			если это.токен.тип_ == "ТОЧКА" тогда
				это.шаг()
			иначе
				прервать
			конец
		конец
		возврат Результат.Успех(сегменты)
	конец

	функ разобрать_массив(это: Парсер) -> Результат(Значение, Ошибка)
		это.шаг()
		это.пропустить_переводы()
		пер элементы: Массив(Значение) = массив()
		если это.токен.тип_ <> "ПРАВАЯ_СКОБКА" тогда
			пока истина цикл
				пер рез = это.разобрать_значение()
				если рез.ошибка() тогда
					возврат рез
				конец
				элементы.добавить(рез.получить(Значение.Булево(ложь)))
				это.пропустить_переводы()
				если это.токен.тип_ == "ЗАПЯТАЯ" тогда
					это.шаг()
					это.пропустить_переводы()
					если это.токен.тип_ == "ПРАВАЯ_СКОБКА" тогда
						прервать
					конец
				иначе
					прервать
				конец
			конец
		конец
		если это.токен.тип_ <> "ПРАВАЯ_СКОБКА" тогда
			возврат Результат.Неудача(Ошибка("toml", "ожидалась ']' в конце массива"))
		конец
		это.шаг()
		возврат Результат.Успех(Значение.Список(элементы))
	конец

	функ разобрать_инлайн_таблицу(это: Парсер) -> Результат(Значение, Ошибка)
		это.шаг()
		пер таблица: Соответствие(Строка, Значение) = соответствие()
		это.пропустить_переводы()
		если это.токен.тип_ <> "ФИГ_ПРАВАЯ" тогда
			пока истина цикл
				пер путь_рез = это.разобрать_путь_ключа()
				если путь_рез.ошибка() тогда
					возврат путь_рез.заменить_значение(Значение.Булево(ложь))
				конец
				пер путь = путь_рез.получить(массив())

				если это.токен.тип_ <> "РАВНО" тогда
					возврат Результат.Неудача(Ошибка("toml", "ожидался '=' в инлайн-таблице"))
				конец
				это.шаг()

				пер знач_рез = это.разобрать_значение()
				если знач_рез.ошибка() тогда
					возврат знач_рез
				конец
				пер знач = знач_рез.получить(Значение.Булево(ложь))

				пер ошибка_опц = вставить_по_пути(таблица, путь, знач)
				если ошибка_опц.есть() тогда
					возврат Результат.Неудача(ошибка_опц.значение())
				конец

				это.пропустить_переводы()
				если это.токен.тип_ == "ЗАПЯТАЯ" тогда
					это.шаг()
					это.пропустить_переводы()
					если это.токен.тип_ == "ФИГ_ПРАВАЯ" тогда
						прервать
					конец
				иначе
					прервать
				конец
			конец
		конец
		если это.токен.тип_ <> "ФИГ_ПРАВАЯ" тогда
			возврат Результат.Неудача(Ошибка("toml", "ожидалась '}' в конце инлайн-таблицы"))
		конец
		это.шаг()
		возврат Результат.Успех(Значение.Таблица(таблица))
	конец

	функ разобрать_значение(это: Парсер) -> Результат(Значение, Ошибка)
		если это.токен.тип_ == "СТРОКА" тогда
			пер знач = это.токен.значение
			это.шаг()
			возврат Результат.Успех(Значение.Строка(знач))
		конец

		если это.токен.тип_ == "ЧИСЛО" тогда
			пер текст = это.токен.значение
			это.шаг()
			возврат классифицировать_число(текст)
		конец

		если это.токен.тип_ == "КЛЮЧ" тогда
			пер текст = это.токен.значение
			если текст == "true" тогда
				это.шаг()
				возврат Результат.Успех(Значение.Булево(истина))
			конец
			если текст == "false" тогда
				это.шаг()
				возврат Результат.Успех(Значение.Булево(ложь))
			конец
			если текст == "inf" тогда
				это.шаг()
				возврат Результат.Успех(Значение.Число(1.0 / 0.0))
			конец
			если текст == "nan" тогда
				это.шаг()
				возврат Результат.Успех(Значение.Число(0.0 / 0.0))
			конец
			возврат Результат.Неудача(Ошибка("toml", "неожиданное слово в значении: '" + текст + "'"))
		конец

		если это.токен.тип_ == "ЛЕВАЯ_СКОБКА" тогда
			возврат это.разобрать_массив()
		конец

		если это.токен.тип_ == "ФИГ_ЛЕВАЯ" тогда
			возврат это.разобрать_инлайн_таблицу()
		конец

		возврат Результат.Неудача(Ошибка("toml", "ожидалось значение, получено: '" + это.токен.значение + "'"))
	конец
конец

// ==================== НАВИГАЦИЯ ПО ТАБЛИЦАМ ====================

// Идёт по пути сегментов от `таблица`, создавая вложенные Таблица() там,
// где сегмента ещё нет; ошибка — если путь упирается в НЕ-таблицу.
функ найти_или_создать_вложенную(таблица: Соответствие(Строка, Значение), путь: Массив(Строка)) -> Результат(Соответствие(Строка, Значение), Ошибка)
	пер текущая = таблица
	пер i: Целое = 0
	пер n = путь.длина()
	пока i < n цикл
		пер сегмент = путь.получить(i, "")
		если текущая.есть(сегмент) тогда
			пер существующее = текущая.получить(сегмент, Значение.Булево(ложь))
			пер это_табл = выбор существующее
				Таблица(_) -> истина
				_ -> ложь
			конец
			если не это_табл тогда
				возврат Результат.Неудача(Ошибка("toml", "ключ '" + сегмент + "' уже занят не-таблицей"))
			конец
			пер вложенная = выбор существующее
				Таблица(t) -> t
				_ -> паника("panos: внутренняя ошибка TOML: ожидалась таблица")
			конец
			текущая = вложенная
		иначе
			пер новая: Соответствие(Строка, Значение) = соответствие()
			текущая[сегмент] = Значение.Таблица(новая)
			текущая = новая
		конец
		i = i + 1
	конец
	возврат Результат.Успех(текущая)
конец

// Вставляет `значение` по (возможно точечному) пути ключей в `таблица`,
// создавая промежуточные вложенные таблицы для всех сегментов, кроме
// последнего. Опция(Ошибка), а не Результат(Пусто,...) — избегает лишней
// generic-инстанциации Результата ради Пусто-успеха.
функ вставить_по_пути(таблица: Соответствие(Строка, Значение), путь: Массив(Строка), значение: Значение) -> Опция(Ошибка)
	пер n = путь.длина()
	если n == 0 тогда
		возврат Опция.Есть(Ошибка("toml", "пустой путь ключа"))
	конец
	если n == 1 тогда
		таблица[путь.получить(0, "")] = значение
		возврат Опция.Нет()
	конец
	пер префикс: Массив(Строка) = массив()
	пер i: Целое = 0
	пока i < n - 1 цикл
		префикс.добавить(путь.получить(i, ""))
		i = i + 1
	конец
	пер результат_табл = найти_или_создать_вложенную(таблица, префикс)
	если результат_табл.ошибка() тогда
		возврат Опция.Есть(результат_табл.причина())
	конец
	пер вложенная = результат_табл.получить(таблица)
	вложенная[путь.получить(n - 1, "")] = значение
	возврат Опция.Нет()
конец

// Спускается по всем сегментам, кроме последнего, как обычная вложенная
// таблица; последний сегмент — имя массива таблиц: создаёт его при
// необходимости и добавляет туда новую пустую таблицу, которую и
// возвращает (чтобы последующие key=value ушли именно в неё).
функ войти_в_массив_таблиц(корень: Соответствие(Строка, Значение), путь: Массив(Строка)) -> Результат(Соответствие(Строка, Значение), Ошибка)
	пер n = путь.длина()
	если n == 0 тогда
		возврат Результат.Неудача(Ошибка("toml", "пустое имя массива таблиц"))
	конец
	пер префикс: Массив(Строка) = массив()
	пер i: Целое = 0
	пока i < n - 1 цикл
		префикс.добавить(путь.получить(i, ""))
		i = i + 1
	конец
	пер результат_табл = найти_или_создать_вложенную(корень, префикс)
	если результат_табл.ошибка() тогда
		возврат результат_табл
	конец
	пер родитель = результат_табл.получить(корень)
	пер последний_ключ = путь.получить(n - 1, "")

	если родитель.есть(последний_ключ) тогда
		пер существующее = родитель.получить(последний_ключ, Значение.Булево(ложь))
		пер это_список = выбор существующее
			Список(_) -> истина
			_ -> ложь
		конец
		если не это_список тогда
			возврат Результат.Неудача(Ошибка("toml", "ключ '" + последний_ключ + "' уже занят не-массивом"))
		конец
	иначе
		пер пустой: Массив(Значение) = массив()
		родитель[последний_ключ] = Значение.Список(пустой)
	конец

	пер список_знач = родитель.получить(последний_ключ, Значение.Булево(ложь))
	пер новая_таблица: Соответствие(Строка, Значение) = соответствие()
	выбор список_знач
		Список(эл) -> эл.добавить(Значение.Таблица(новая_таблица))
		_ -> паника("panos: внутренняя ошибка TOML: ожидался список таблиц")
	конец
	возврат Результат.Успех(новая_таблица)
конец

// ==================== ВЕРХНИЙ УРОВЕНЬ РАЗБОРА ====================

экспорт функ разобрать(текст: Строка) -> Результат(Значение, Ошибка)
	пер п = новый_парсер(текст)
	пер корень: Соответствие(Строка, Значение) = соответствие()
	пер текущая = корень

	п.пропустить_переводы()

	пока п.токен.тип_ <> "КОНЕЦ" цикл
		если п.токен.тип_ == "ЛЕВАЯ_СКОБКА" тогда
			п.шаг()
			если п.токен.тип_ == "ЛЕВАЯ_СКОБКА" тогда
				п.шаг()
				пер путь_рез = п.разобрать_путь_ключа()
				если путь_рез.ошибка() тогда
					возврат путь_рез.заменить_значение(Значение.Булево(ложь))
				конец
				пер путь = путь_рез.получить(массив())
				если п.токен.тип_ <> "ПРАВАЯ_СКОБКА" тогда
					возврат Результат.Неудача(Ошибка("toml", "ожидалась ']' после имени массива таблиц"))
				конец
				п.шаг()
				если п.токен.тип_ <> "ПРАВАЯ_СКОБКА" тогда
					возврат Результат.Неудача(Ошибка("toml", "ожидалась ']]' после имени массива таблиц"))
				конец
				п.шаг()

				пер результат_табл = войти_в_массив_таблиц(корень, путь)
				если результат_табл.ошибка() тогда
					возврат результат_табл.заменить_значение(Значение.Булево(ложь))
				конец
				текущая = результат_табл.получить(корень)
			иначе
				пер путь_рез = п.разобрать_путь_ключа()
				если путь_рез.ошибка() тогда
					возврат путь_рез.заменить_значение(Значение.Булево(ложь))
				конец
				пер путь = путь_рез.получить(массив())
				если п.токен.тип_ <> "ПРАВАЯ_СКОБКА" тогда
					возврат Результат.Неудача(Ошибка("toml", "ожидалась ']' после имени секции"))
				конец
				п.шаг()

				пер результат_табл = найти_или_создать_вложенную(корень, путь)
				если результат_табл.ошибка() тогда
					возврат результат_табл.заменить_значение(Значение.Булево(ложь))
				конец
				текущая = результат_табл.получить(корень)
			конец
			п.пропустить_переводы()
			продолжить
		конец

		если п.токен.тип_ == "КЛЮЧ" или п.токен.тип_ == "СТРОКА" тогда
			пер путь_рез = п.разобрать_путь_ключа()
			если путь_рез.ошибка() тогда
				возврат путь_рез.заменить_значение(Значение.Булево(ложь))
			конец
			пер путь = путь_рез.получить(массив())

			если п.токен.тип_ <> "РАВНО" тогда
				возврат Результат.Неудача(Ошибка("toml", "ожидался '=' после ключа"))
			конец
			п.шаг()

			пер знач_рез = п.разобрать_значение()
			если знач_рез.ошибка() тогда
				возврат знач_рез
			конец
			пер знач = знач_рез.получить(Значение.Булево(ложь))

			пер ошибка_опц = вставить_по_пути(текущая, путь, знач)
			если ошибка_опц.есть() тогда
				возврат Результат.Неудача(ошибка_опц.значение())
			конец

			п.пропустить_переводы()
			продолжить
		конец

		возврат Результат.Неудача(Ошибка("toml", "неожиданный токен: '" + п.токен.значение + "'"))
	конец

	возврат Результат.Успех(Значение.Таблица(корень))
конец

// ==================== СЕРИАЛИЗАЦИЯ ====================

функ плюс_бесконечность() -> Число
	1.0 / 0.0
конец

функ минус_бесконечность() -> Число
	0.0 - 1.0 / 0.0
конец

// строки.из_числа теряет '.' у целых по значению float (3.0 -> "3") —
// в TOML это меняет тип при чтении обратно, так что дописываем ".0",
// когда в естественном представлении нет ни точки, ни экспоненты.
функ число_в_toml(ч: Число) -> Строка
	если ч <> ч тогда
		возврат "nan"
	конец
	если ч == плюс_бесконечность() тогда
		возврат "inf"
	конец
	если ч == минус_бесконечность() тогда
		возврат "-inf"
	конец
	пер текст = строки.из_числа(ч)
	если строки.содержит(текст, ".") или строки.содержит(текст, "e") или строки.содержит(текст, "E") тогда
		возврат текст
	конец
	текст + ".0"
конец

функ экранировать(текст: Строка) -> Строка
	пер результат = ""
	пер i: Целое = 0
	пер n = длина(текст)
	пока i < n цикл
		пер символ = текст[i]
		пер добавка = символ
		если символ == "\"" тогда
			добавка = "\\\""
		конец
		если символ == "\\" тогда
			добавка = "\\\\"
		конец
		если символ == "\n" тогда
			добавка = "\\n"
		конец
		если символ == "\t" тогда
			добавка = "\\t"
		конец
		если символ == "\r" тогда
			добавка = "\\r"
		конец
		если символ <> "\"" и символ <> "\\" и символ <> "\n" и символ <> "\t" и символ <> "\r" и строки.байт(символ, 0) < 32 тогда
			пер код = строки.байт(символ, 0)
			добавка = "\\u00" + цифра_в_hex(код / 16) + цифра_в_hex(код % 16)
		конец
		результат = результат + добавка
		i = i + 1
	конец
	результат
конец

функ ключ_безопасен(ключ: Строка) -> Булево
	если длина(ключ) == 0 тогда
		возврат ложь
	конец
	пер i: Целое = 0
	пер n = длина(ключ)
	пока i < n цикл
		пер с = ключ[i]
		если не (строки.цифра_или_буква(с) или с == "_" или с == "-") тогда
			возврат ложь
		конец
		i = i + 1
	конец
	истина
конец

функ отформатировать_ключ(ключ: Строка) -> Строка
	если ключ_безопасен(ключ) тогда
		возврат ключ
	конец
	"\"" + экранировать(ключ) + "\""
конец

функ сериализовать_значение(значение: Значение) -> Строка
	выбор значение
		Строка(с) -> "\"" + экранировать(с) + "\""
		Целое(ц) -> строки.из_целого(ц)
		Число(ч) -> число_в_toml(ч)
		Булево(б) -> если б тогда "true" иначе "false" конец
		Время(т) -> т
		Список(эл) -> сериализовать_список(эл)
		Таблица(т) -> сериализовать_инлайн_таблицу(т)
	конец
конец

функ сериализовать_список(элементы: Массив(Значение)) -> Строка
	пер результат = "["
	пер i: Целое = 0
	пер n = элементы.длина()
	пока i < n цикл
		результат = результат + сериализовать_значение(элементы.получить(i, Значение.Булево(ложь)))
		если i < n - 1 тогда
			результат = результат + ", "
		конец
		i = i + 1
	конец
	результат + "]"
конец

функ сериализовать_инлайн_таблицу(таблица: Соответствие(Строка, Значение)) -> Строка
	пер записи = таблица.записи()
	пер n = записи.длина()
	если n == 0 тогда
		возврат "{}"
	конец
	пер результат = "{ "
	пер i: Целое = 0
	пока i < n цикл
		пер запись = записи.получить(i, ("", Значение.Булево(ложь)))
		результат = результат + отформатировать_ключ(запись.0) + " = " + сериализовать_значение(запись.1)
		если i < n - 1 тогда
			результат = результат + ", "
		конец
		i = i + 1
	конец
	результат + " }"
конец

функ это_таблица(значение: Значение) -> Булево
	выбор значение
		Таблица(_) -> истина
		_ -> ложь
	конец
конец

функ это_массив_таблиц_список(элементы: Массив(Значение)) -> Булево
	пер n = элементы.длина()
	если n == 0 тогда
		возврат ложь
	конец
	пер i: Целое = 0
	пока i < n цикл
		если не это_таблица(элементы.получить(i, Значение.Булево(ложь))) тогда
			возврат ложь
		конец
		i = i + 1
	конец
	истина
конец

функ это_массив_таблиц(значение: Значение) -> Булево
	выбор значение
		Список(эл) -> это_массив_таблиц_список(эл)
		_ -> ложь
	конец
конец

функ сериализовать_массив_таблиц(элементы: Массив(Значение), путь: Строка) -> Строка
	пер результат = ""
	пер i: Целое = 0
	пер n = элементы.длина()
	пока i < n цикл
		пер т = выбор элементы.получить(i, Значение.Булево(ложь))
			Таблица(t) -> t
			_ -> паника("panos: внутренняя ошибка TOML: ожидалась таблица в массиве таблиц")
		конец
		результат = результат + "[[" + путь + "]]\n" + сериализовать_таблицу(т, путь)
		i = i + 1
	конец
	результат
конец

// Сначала все скалярные/массивные ключи текущего уровня (`key = value`),
// затем вложенные [секции] и [[массивы таблиц]] — TOML не позволяет
// перемешивать порядок: как только открыта [секция], последующие
// key=value без заголовка ушли бы уже в неё, а не в текущую таблицу.
функ сериализовать_таблицу(таблица: Соответствие(Строка, Значение), путь: Строка) -> Строка
	пер записи = таблица.записи()
	пер n = записи.длина()
	пер результат = ""

	пер i: Целое = 0
	пока i < n цикл
		пер запись = записи.получить(i, ("", Значение.Булево(ложь)))
		пер знач = запись.1
		если (не это_таблица(знач)) и (не это_массив_таблиц(знач)) тогда
			результат = результат + отформатировать_ключ(запись.0) + " = " + сериализовать_значение(знач) + "\n"
		конец
		i = i + 1
	конец

	пер j: Целое = 0
	пока j < n цикл
		пер запись = записи.получить(j, ("", Значение.Булево(ложь)))
		пер ключ = запись.0
		пер знач = запись.1
		пер новый_путь = если путь == "" тогда отформатировать_ключ(ключ) иначе путь + "." + отформатировать_ключ(ключ) конец

		если это_таблица(знач) тогда
			пер вложенная = выбор знач
				Таблица(t) -> t
				_ -> паника("panos: внутренняя ошибка TOML: ожидалась таблица")
			конец
			результат = результат + "[" + новый_путь + "]\n" + сериализовать_таблицу(вложенная, новый_путь)
		конец
		если это_массив_таблиц(знач) тогда
			пер элементы = выбор знач
				Список(эл) -> эл
				_ -> паника("panos: внутренняя ошибка TOML: ожидался список")
			конец
			результат = результат + сериализовать_массив_таблиц(элементы, новый_путь)
		конец
		j = j + 1
	конец

	результат
конец

экспорт функ сериализовать(значение: Значение) -> Строка
	выбор значение
		Таблица(т) -> сериализовать_таблицу(т, "")
		_ -> сериализовать_значение(значение)
	конец
конец

// ==================== ИНТЕРФЕЙСЫ ДЕСЕРИАЛИЗАЦИИ/СЕРИАЛИЗАЦИИ ====================
//
// В panos нет reflection/derive (нет макросов вообще) — структура не
// может "автоматически" сериализоваться просто по факту наличия полей.
// Вместо этого — обычный ручной паттерн интерфейсов (как Сравниваемое/
// Копируемое/Печатаемое в прелюдии, см. core/prelude.odin): структура
// РЕАЛИЗУЕТ ИзTOML/ВTOML один раз (тело пишете сами — маппинг
// полей<->ключей), а дальше вызывается єдинообразно через generic-
// обёртки ниже (разобрать_в/сериализовать_из), а не через громоздкую
// цепочку .поле(...).значение().как_X().получить(default) на каждом
// call site.
//
// заполнить_из_toml мутирует УЖЕ СУЩЕСТВУЮЩИЙ инстанс (это.поле = ...),
// а не строит новый — в panos нет способа сконструировать T "из ничего"
// внутри generic-кода (интерфейсные методы всегда диспетчеризуются на
// существующем это, конструкторов интерфейс не даёт), так что вызывающий
// код сам создаёт нулевой/дефолтный инстанс перед вызовом.

экспорт тип ИзTOML = интерфейс
	функ заполнить_из_toml(значение: Значение) -> Опция(Ошибка)
конец

экспорт тип ВTOML = интерфейс
	функ в_toml() -> Значение
конец

// Разбирает `текст` и заполняет им уже существующий `это` (созданный
// вызывающим кодом, обычно с нулевыми/дефолтными полями). Опция(Ошибка)
// одинаково покрывает и ошибку разбора текста, и ошибку самого маппинга
// полей (см. заполнить_из_toml конкретной структуры).
экспорт функ разобрать_в[T: ИзTOML](это: T, текст: Строка) -> Опция(Ошибка)
	пер рез = разобрать(текст)
	если рез.ошибка() тогда
		возврат Опция.Есть(рез.причина())
	конец
	это.заполнить_из_toml(рез.получить(Значение.Булево(ложь)))
конец

// Обратное: структура -> Значение (через .в_toml()) -> TOML-текст.
экспорт функ сериализовать_из[T: ВTOML](это: T) -> Строка
	сериализовать(это.в_toml())
конец

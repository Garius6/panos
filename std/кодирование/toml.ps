экспорт тип Токен = структура
	тип_: Строка;
	значение: Строка;
конец

тип Токенизатор = структура
	текст: Строка
	поз: Число
	длина: Число
конец

функция новый_токенизатор(содержимое: Строка) -> Токенизатор
	пер т = Токенизатор(содержимое, 0, длина(содержимое))
	возврат т
конец

реализация Токенизатор

	функ прочитать_число(это) -> Токен
		пер начало = это.поз
		если это.текст[это.поз] == "-" тогда
			это.поз = это.поз + 1
		конец

		пока это.поз < это.длина и строки.это_цифра(это.текст[это.поз]) цикл
			это.поз = это.поз + 1
		конец

		значение = это.текст[начало:это.поз]

        возврат Токен("ЗНАЧЕНИЕ", значение)

	конец

	функ прочитать_строку(это) -> Токен
		это.поз = это.поз + 1
		пер старт = это.поз
		пока это.поз < это.длина и это.текст[это.поз] <> """ цикл
			это.поз = это.поз + 1
		конец

		если это.поз > это.длина или это.поз == это.длина тогда
			паника("Незакрытая строка")
		конец

		пер значение = это.текст[начало:это.поз]

		это.поз = это.поз + 1
        возврат Токен('ЗНАЧЕНИЕ', значение)

	конец

	функц прочитать_ключ_или_булево(это) -> Токен
		пер начало = это.поз
		пока это.поз < это.длина и (строки.цифра_или_буква(это.текст[это.поз]) или это.текст[это.поз] == "-") цикл
			это.поз = это.поз + 1
		конец

		пер значение = это.текст[начало:это.поз]

        если значение == "true" тогда
            возврат Токен("ЗНАЧЕНИЕ", истина)
		конец
        если значение == "false" тогда
            возврат Токен("ЗНАЧЕНИЕ", ложь)
        конец
        возврат Токен('КЛЮЧ', ЗНАЧЕНИЕ)

	конец

	функ следующий_токен(это) -> Токен
		пока это.поз < это.длина цикл
			символ = это.текст[это.поз]
			если символ == " " или символ == "\t" или символ == "\r" тогда
				это.поз = это.поз + 1
				продолжить
			конец

			если символ = "#" тогда
				 пока это.поз < это.длина и это.текст[это.поз] <> "\n" цикл
					это.позиция = это.позиция + 1
				 конец
			конец

			если символ == "\n"
				это.поз = это.поз + 1
				возврат Токен("НОВАЯ_СТРОКА", "\n")
			конец

    		если символ == "=" тогда
                это.поз = это.поз + 1
                возврат Токен("РАВНО", "=")
			конец

            если символ == "["  тогда
                это.поз = это.поз + 1
                возврат Токен("ЛЕВАЯ_СКОБКА", "[")
			конец

            если символ == "]" тогдаа
                это.поз = это.поз + 1
                возврат Токен("ПРАВАЯ_СКОБКА", "]")
			конец

			если символ == "\"" тогда
                возврат это.прочитать_строку()
			конец

			если строки.это_буква(символ) или символ == "_" тогда
                возврат это.прочитать_ключ_или_булево()
			конец

			если строки.это_цифра(символ) или символ == "-" тогда
				возврат это.прочитать_число()
			конец

			паника("Неизвестный символ")

		конец
	конец
конец

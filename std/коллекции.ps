// Дженерик-комбинаторы поверх Массив — чистый panos (Стадия 7: generic
// функции), без единого native-изменения. "отсортировать" — insertion
// sort (просто, стабильно; для больших массивов производительность не
// приоритет). Компаратор-лямбда, а не встроенный `<`, — panos не
// сравнивает Строку/структуры/массивы через `<` (только Число), так что
// generic-сортировка в принципе не может опереться на язык.

экспорт функ отфильтровать[T](массив: Массив(T), предикат: функ(T) -> Булево) -> Массив(T)
	пер результат: Массив(T) = массив()
	для элемент в массив цикл
		если предикат(элемент) тогда
			результат.добавить(элемент)
		конец
	конец
	результат
конец

экспорт функ отобразить[T, U](массив: Массив(T), преобразование: функ(T) -> U) -> Массив(U)
	пер результат: Массив(U) = массив()
	для элемент в массив цикл
		результат.добавить(преобразование(элемент))
	конец
	результат
конец

экспорт функ свернуть[T, U](массив: Массив(T), начало: U, шаг: функ(U, T) -> U) -> U
	пер накопитель = начало
	для элемент в массив цикл
		накопитель = шаг(накопитель, элемент)
	конец
	накопитель
конец

экспорт функ отсортировать[T](массив: Массив(T), меньше: функ(T, T) -> Булево) -> Массив(T)
	пер результат: Массив(T) = массив()
	для элемент в массив цикл
		результат.добавить(элемент)
	конец
	пер i: Целое = 1
	пока i < результат.длина() цикл
		пер ключ = результат[i]
		пер j = i - 1
		пока j > -1 и меньше(ключ, результат[j]) цикл
			результат[j + 1] = результат[j]
			j = j - 1
		конец
		результат[j + 1] = ключ
		i = i + 1
	конец
	результат
конец

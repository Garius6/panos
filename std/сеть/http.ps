импорт строки
импорт сеть

// Простенький HTTP/1.1-клиент поверх сеть.подключиться (TCP). Поддержан
// только http:// (без TLS — core:net не даёт TLS "из коробки", https
// потребовал бы отдельной криптобиблиотеки, вне объёма). "Connection:
// close" в каждом запросе — сервер сам закрывает соединение после ответа,
// поэтому чтение тела сводится к "читать до EOF", без разбора
// Content-Length/chunked encoding на стороне клиента.

экспорт тип Адрес = структура
	хост: Строка
	порт: Число
	путь: Строка
конец

экспорт тип Ответ = структура
	статус:    Число
	заголовки: Соответствие(Строка, Строка)
	тело:      Строка
конец

реализация Ответ
	функ успех(это: Ответ) -> Булево
		это.статус > 199 и это.статус < 300
	конец

	функ редирект(это: Ответ) -> Булево
		это.статус > 299 и это.статус < 400
	конец

	функ ошибка_клиента(это: Ответ) -> Булево
		это.статус > 399 и это.статус < 500
	конец

	функ ошибка_сервера(это: Ответ) -> Булево
		это.статус > 499 и это.статус < 600
	конец

	функ заголовок(это: Ответ, имя: Строка) -> Опция(Строка)
		если это.заголовки.есть(имя) тогда
			Опция.Есть(это.заголовки.получить(имя, ""))
		иначе
			Опция.Нет()
		конец
	конец
конец

функ пустые_заголовки() -> Соответствие(Строка, Строка)
	пер м: Соответствие(Строка, Строка) = соответствие()
	возврат м
конец

// Линейный поиск подстроки — в языке нет встроенного indexOf/find,
// строки.срез — единственный примитив для работы с фрагментами строки.
// Возвращает -1, если не найдено.
функ найти(текст: Строка, образец: Строка, от: Целое) -> Целое
	пер длина_текста = длина(текст)
	пер длина_образца = длина(образец)
	если длина_образца == 0 тогда
		возврат от
	конец
	пер позиция = от
	пока позиция + длина_образца < длина_текста или позиция + длина_образца == длина_текста цикл
		если строки.срез(текст, позиция, позиция + длина_образца) == образец тогда
			возврат позиция
		конец
		позиция = позиция + 1
	конец
	возврат -1
конец

экспорт функ разобрать_адрес(текст: Строка) -> Результат(Адрес, Ошибка)
	если длина(текст) < 7 тогда
		возврат Результат.Неудача(Ошибка("http", "поддержан только http://, получено: " + текст))
	конец

	пер префикс = строки.срез(текст, 0, 7)
	если префикс <> "http://" тогда
		возврат Результат.Неудача(Ошибка("http", "поддержан только http://, получено: " + текст))
	конец
	пер остаток = строки.срез(текст, 7, длина(текст))

	пер конец_хоста = найти(остаток, "/", 0)
	пер хост_и_порт = остаток
	пер путь = "/"
	если конец_хоста <> -1 тогда
		хост_и_порт = строки.срез(остаток, 0, конец_хоста)
		путь = строки.срез(остаток, конец_хоста, длина(остаток))
	конец

	если длина(хост_и_порт) == 0 тогда
		возврат Результат.Неудача(Ошибка("http", "пустой хост в адресе: " + текст))
	конец

	пер разделитель_порта = найти(хост_и_порт, ":", 0)
	пер хост = хост_и_порт
	пер порт = 80
	если разделитель_порта <> -1 тогда
		хост = строки.срез(хост_и_порт, 0, разделитель_порта)
		пер порт_текст = строки.срез(хост_и_порт, разделитель_порта + 1, длина(хост_и_порт))
		пер порт_результат = строки.в_число(порт_текст)
		если порт_результат.ошибка() тогда
			возврат Результат.Неудача(Ошибка("http", "неверный порт в адресе: " + текст))
		конец
		порт = порт_результат.получить(80)
	конец

	возврат Результат.Успех(Адрес(хост, порт, путь))
конец

// "?a=b&c=d" с percent-encoding ключей/значений (сеть.кодировать_url).
// Пустая Соответствие -> пустая строка (не "?"). Вызывающий сам
// приклеивает результат к пути/URL перед хттп.получить(...).
экспорт функ построить_query(параметры: Соответствие(Строка, Строка)) -> Строка
	пер записи = параметры.записи()
	если длина(записи) == 0 тогда
		возврат ""
	конец

	пер результат = "?"
	пер индекс: Целое = 0
	пока индекс < длина(записи) цикл
		пер запись = записи.получить(индекс, ("", ""))
		если индекс > 0 тогда
			результат = результат + "&"
		конец
		результат = результат + сеть.кодировать_url(запись.0) + "=" + сеть.кодировать_url(запись.1)
		индекс = индекс + 1
	конец
	возврат результат
конец

функ построить_запрос(метод: Строка, адрес: Адрес, тело: Строка, доп_заголовки: Соответствие(Строка, Строка)) -> Строка
	пер база = метод + " " + адрес.путь + " HTTP/1.1\r\nHost: " + адрес.хост + "\r\nConnection: close\r\nUser-Agent: panos\r\n"

	пер записи = доп_заголовки.записи()
	пер индекс: Целое = 0
	пока индекс < длина(записи) цикл
		пер запись = записи.получить(индекс, ("", ""))
		база = база + запись.0 + ": " + запись.1 + "\r\n"
		индекс = индекс + 1
	конец

	если длина(тело) > 0 тогда
		возврат база + "Content-Length: " + строки.из_целого(длина(тело)) + "\r\n\r\n" + тело
	конец
	возврат база + "\r\n"
конец

// Разбирает "Заголовок: значение\r\n..." до конца текста (без завершающего
// \r\n\r\n — его уже отрезал вызывающий). Регистр имён заголовков не
// нормализуется — сравнение через .заголовок() чувствительно к регистру,
// как прислал сервер.
функ разобрать_заголовки(текст: Строка) -> Соответствие(Строка, Строка)
	пер результат: Соответствие(Строка, Строка) = соответствие()
	пер позиция: Целое = 0
	пер длина_текста = длина(текст)
	пока позиция < длина_текста цикл
		пер конец_строки = найти(текст, "\r\n", позиция)
		пер строка_текст = строки.срез(текст, позиция, длина_текста)
		если конец_строки <> -1 тогда
			строка_текст = строки.срез(текст, позиция, конец_строки)
			позиция = конец_строки + 2
		иначе
			позиция = длина_текста
		конец

		если длина(строка_текст) > 0 тогда
			пер разделитель = найти(строка_текст, ": ", 0)
			если разделитель <> -1 тогда
				пер ключ = строки.срез(строка_текст, 0, разделитель)
				пер значение = строки.срез(строка_текст, разделитель + 2, длина(строка_текст))
				результат[ключ] = значение
			конец
		конец
	конец
	возврат результат
конец

функ разобрать_ответ(сырой: Строка) -> Результат(Ответ, Ошибка)
	пер разделитель = найти(сырой, "\r\n\r\n", 0)
	если разделитель == -1 тогда
		возврат Результат.Неудача(Ошибка("http", "не удалось разобрать ответ: нет разделителя заголовков"))
	конец

	пер заголовочный_блок = строки.срез(сырой, 0, разделитель)
	пер тело = строки.срез(сырой, разделитель + 4, длина(сырой))

	пер конец_статуса = найти(заголовочный_блок, "\r\n", 0)
	пер статусная_строка = заголовочный_блок
	пер остальные_заголовки = ""
	если конец_статуса <> -1 тогда
		статусная_строка = строки.срез(заголовочный_блок, 0, конец_статуса)
		остальные_заголовки = строки.срез(заголовочный_блок, конец_статуса + 2, длина(заголовочный_блок))
	конец

	пер первый_пробел = найти(статусная_строка, " ", 0)
	если первый_пробел == -1 тогда
		возврат Результат.Неудача(Ошибка("http", "не удалось разобрать статусную строку: " + статусная_строка))
	конец
	пер после_версии = строки.срез(статусная_строка, первый_пробел + 1, длина(статусная_строка))
	пер второй_пробел = найти(после_версии, " ", 0)
	пер код_текст = после_версии
	если второй_пробел <> -1 тогда
		код_текст = строки.срез(после_версии, 0, второй_пробел)
	конец

	пер код_результат = строки.в_число(код_текст)
	если код_результат.ошибка() тогда
		возврат Результат.Неудача(Ошибка("http", "не удалось разобрать код статуса: " + код_текст))
	конец

	возврат Результат.Успех(Ответ(код_результат.получить(0), разобрать_заголовки(остальные_заголовки), тело))
конец

функ выполнить(метод: Строка, ссылка: Строка, тело: Строка, доп_заголовки: Соответствие(Строка, Строка)) -> Результат(Ответ, Ошибка)
	пер разобранный_адрес = разобрать_адрес(ссылка)
	если разобранный_адрес.ошибка() тогда
		возврат Результат.Неудача(разобранный_адрес.причина())
	конец
	пер адрес = разобранный_адрес.ожидать("адрес уже проверен выше")

	пер соединение_результат = сеть.подключиться(адрес.хост, адрес.порт)
	если соединение_результат.ошибка() тогда
		возврат Результат.Неудача(соединение_результат.причина())
	конец
	пер соединение = соединение_результат.ожидать("соединение уже проверено выше")

	пер запрос = построить_запрос(метод, адрес, тело, доп_заголовки)
	соединение.отправить(запрос)
	пер сырой_результат = соединение.получить()
	соединение.закрыть()

	если сырой_результат.ошибка() тогда
		возврат Результат.Неудача(сырой_результат.причина())
	конец

	возврат разобрать_ответ(сырой_результат.ожидать("тело уже проверено выше"))
конец

экспорт функ получить(ссылка: Строка) -> Результат(Ответ, Ошибка)
	возврат выполнить("GET", ссылка, "", пустые_заголовки())
конец

экспорт функ получить_с_заголовками(ссылка: Строка, заголовки: Соответствие(Строка, Строка)) -> Результат(Ответ, Ошибка)
	возврат выполнить("GET", ссылка, "", заголовки)
конец

экспорт функ отправить_пост(ссылка: Строка, тело: Строка) -> Результат(Ответ, Ошибка)
	возврат выполнить("POST", ссылка, тело, пустые_заголовки())
конец

экспорт функ отправить_пост_с_заголовками(ссылка: Строка, тело: Строка, заголовки: Соответствие(Строка, Строка)) -> Результат(Ответ, Ошибка)
	возврат выполнить("POST", ссылка, тело, заголовки)
конец

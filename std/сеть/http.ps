импорт строки
импорт сеть

// Простенький HTTP/1.1-клиент поверх сеть.подключиться (TCP). Поддержан
// только http:// (без TLS — core:net не даёт TLS "из коробки", https
// потребовал бы отдельной криптобиблиотеки, вне объёма). "Connection:
// close" в каждом запросе — сервер сам закрывает соединение после ответа,
// поэтому чтение тела сводится к "читать до EOF", без разбора
// Content-Length/chunked encoding на стороне клиента.

экспорт тип Адрес = структура
	хост: Строка
	порт: Число
	путь: Строка
конец

экспорт тип Ответ = структура
	статус: Число
	тело: Строка
конец

// Линейный поиск подстроки — в языке нет встроенного indexOf/find,
// строки.срез — единственный примитив для работы с фрагментами строки.
// Возвращает -1, если не найдено.
функ найти(текст: Строка, образец: Строка, от: Число) -> Число
	пер длина_текста = длина(текст)
	пер длина_образца = длина(образец)
	если длина_образца == 0 тогда
		возврат от
	конец
	пер позиция = от
	пока позиция + длина_образца < длина_текста или позиция + длина_образца == длина_текста цикл
		если строки.срез(текст, позиция, позиция + длина_образца) == образец тогда
			возврат позиция
		конец
		позиция = позиция + 1
	конец
	возврат -1
конец

экспорт функ разобрать_адрес(текст: Строка) -> Результат(Адрес, Ошибка)
	если длина(текст) < 7 тогда
		возврат Неудача(Ошибка("http", "поддержан только http://, получено: " + текст))
	конец

	пер префикс = строки.срез(текст, 0, 7)
	если префикс <> "http://" тогда
		возврат Неудача(Ошибка("http", "поддержан только http://, получено: " + текст))
	конец
	пер остаток = строки.срез(текст, 7, длина(текст))

	пер конец_хоста = найти(остаток, "/", 0)
	пер хост_и_порт = остаток
	пер путь = "/"
	если конец_хоста <> -1 тогда
		хост_и_порт = строки.срез(остаток, 0, конец_хоста)
		путь = строки.срез(остаток, конец_хоста, длина(остаток))
	конец

	если длина(хост_и_порт) == 0 тогда
		возврат Неудача(Ошибка("http", "пустой хост в адресе: " + текст))
	конец

	пер разделитель_порта = найти(хост_и_порт, ":", 0)
	пер хост = хост_и_порт
	пер порт = 80
	если разделитель_порта <> -1 тогда
		хост = строки.срез(хост_и_порт, 0, разделитель_порта)
		пер порт_текст = строки.срез(хост_и_порт, разделитель_порта + 1, длина(хост_и_порт))
		пер порт_результат = строки.в_число(порт_текст)
		если порт_результат.ошибка() тогда
			возврат Неудача(Ошибка("http", "неверный порт в адресе: " + текст))
		конец
		порт = порт_результат.получить(80)
	конец

	возврат Успех(Адрес(хост, порт, путь))
конец

функ построить_запрос(метод: Строка, адрес: Адрес, тело: Строка) -> Строка
	пер база = метод + " " + адрес.путь + " HTTP/1.1\r\nHost: " + адрес.хост + "\r\nConnection: close\r\nUser-Agent: panos\r\n"
	если длина(тело) > 0 тогда
		возврат база + "Content-Length: " + строки.из_числа(длина(тело)) + "\r\n\r\n" + тело
	конец
	возврат база + "\r\n"
конец

функ разобрать_ответ(сырой: Строка) -> Результат(Ответ, Ошибка)
	пер разделитель = найти(сырой, "\r\n\r\n", 0)
	если разделитель == -1 тогда
		возврат Неудача(Ошибка("http", "не удалось разобрать ответ: нет разделителя заголовков"))
	конец

	пер заголовки = строки.срез(сырой, 0, разделитель)
	пер тело = строки.срез(сырой, разделитель + 4, длина(сырой))

	пер конец_статуса = найти(заголовки, "\r\n", 0)
	пер статусная_строка = заголовки
	если конец_статуса <> -1 тогда
		статусная_строка = строки.срез(заголовки, 0, конец_статуса)
	конец

	пер первый_пробел = найти(статусная_строка, " ", 0)
	если первый_пробел == -1 тогда
		возврат Неудача(Ошибка("http", "не удалось разобрать статусную строку: " + статусная_строка))
	конец
	пер после_версии = строки.срез(статусная_строка, первый_пробел + 1, длина(статусная_строка))
	пер второй_пробел = найти(после_версии, " ", 0)
	пер код_текст = после_версии
	если второй_пробел <> -1 тогда
		код_текст = строки.срез(после_версии, 0, второй_пробел)
	конец

	пер код_результат = строки.в_число(код_текст)
	если код_результат.ошибка() тогда
		возврат Неудача(Ошибка("http", "не удалось разобрать код статуса: " + код_текст))
	конец

	возврат Успех(Ответ(код_результат.получить(0), тело))
конец

функ выполнить(метод: Строка, ссылка: Строка, тело: Строка) -> Результат(Ответ, Ошибка)
	пер разобранный_адрес = разобрать_адрес(ссылка)
	если разобранный_адрес.ошибка() тогда
		возврат Неудача(разобранный_адрес.причина())
	конец
	пер адрес = разобранный_адрес.ожидать("адрес уже проверен выше")

	пер соединение_результат = сеть.подключиться(адрес.хост, адрес.порт)
	если соединение_результат.ошибка() тогда
		возврат Неудача(соединение_результат.причина())
	конец
	пер соединение = соединение_результат.ожидать("соединение уже проверено выше")

	пер запрос = построить_запрос(метод, адрес, тело)
	соединение.отправить(запрос)
	пер сырой_результат = соединение.получить()
	соединение.закрыть()

	если сырой_результат.ошибка() тогда
		возврат Неудача(сырой_результат.причина())
	конец

	возврат разобрать_ответ(сырой_результат.ожидать("тело уже проверено выше"))
конец

экспорт функ получить(ссылка: Строка) -> Результат(Ответ, Ошибка)
	возврат выполнить("GET", ссылка, "")
конец

экспорт функ отправить_пост(ссылка: Строка, тело: Строка) -> Результат(Ответ, Ошибка)
	возврат выполнить("POST", ссылка, тело)
конец

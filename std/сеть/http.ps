импорт строки
импорт сеть
импорт "кодирование/json" как json

// HTTP(S)-клиент. До этой сессии — самодельный сокет-парсер поверх
// сеть.подключиться (только http://, "читать до EOF" без Content-Length/
// chunked, только GET/POST). Теперь — тонкая обёртка над сеть.http_запрос
// (core builtin, backed by external/odin-http + OpenSSL, см. core/
// vm_http_native.odin): настоящий https, корректный Content-Length/
// chunked, все методы. Публичный API (Ответ/запросить/отправить_пост/
// построить_query) не менялся — старый код продолжает работать.

экспорт тип Адрес = структура
	хост: Строка
	порт: Число
	путь: Строка
конец

экспорт тип Ответ = структура
	статус:    Число
	заголовки: Соответствие(Строка, Строка)
	тело:      Строка
конец

реализация Ответ
	функ успех(это: Ответ) -> Булево
		это.статус > 199 и это.статус < 300
	конец

	функ редирект(это: Ответ) -> Булево
		это.статус > 299 и это.статус < 400
	конец

	функ ошибка_клиента(это: Ответ) -> Булево
		это.статус > 399 и это.статус < 500
	конец

	функ ошибка_сервера(это: Ответ) -> Булево
		это.статус > 499 и это.статус < 600
	конец

	// Имена заголовков регистронезависимы по HTTP-спеке — native-клиент
	// (external/odin-http) хранит их в нижнем регистре внутри, поэтому
	// сравниваем по нижнему регистру, а не по тому, как вызывающий написал
	// имя (`.заголовок("Location")` и `.заголовок("location")` должны
	// работать одинаково).
	функ заголовок(это: Ответ, имя: Строка) -> Опция(Строка)
		пер искомое = строки.нижний_регистр(имя)
		если это.заголовки.есть(искомое) тогда
			Опция.Есть(это.заголовки.получить(искомое, ""))
		иначе
			Опция.Нет()
		конец
	конец
конец

// Линейный поиск подстроки — используется только разобрать_адрес ниже
// (оставлен для обратной совместимости, сам http_запрос URL не парсит
// через panos — это делает native-клиент).
функ найти(текст: Строка, образец: Строка, от: Целое) -> Целое
	пер длина_текста = длина(текст)
	пер длина_образца = длина(образец)
	если длина_образца == 0 тогда
		возврат от
	конец
	пер позиция = от
	пока позиция + длина_образца < длина_текста или позиция + длина_образца == длина_текста цикл
		если строки.срез(текст, позиция, позиция + длина_образца) == образец тогда
			возврат позиция
		конец
		позиция = позиция + 1
	конец
	возврат -1
конец

// Сохранено для обратной совместимости (разбор URL без запроса) — только
// http://, как и раньше. Сам http_запрос принимает https:// напрямую и
// парсит URL внутри native-клиента, эта функция для него не используется.
экспорт функ разобрать_адрес(текст: Строка) -> Результат(Адрес, Ошибка)
	если длина(текст) < 7 тогда
		возврат Результат.Неудача(Ошибка("http", "поддержан только http://, получено: " + текст))
	конец

	пер префикс = строки.срез(текст, 0, 7)
	если префикс <> "http://" тогда
		возврат Результат.Неудача(Ошибка("http", "поддержан только http://, получено: " + текст))
	конец
	пер остаток = строки.срез(текст, 7, длина(текст))

	пер конец_хоста = найти(остаток, "/", 0)
	пер хост_и_порт = остаток
	пер путь = "/"
	если конец_хоста <> -1 тогда
		хост_и_порт = строки.срез(остаток, 0, конец_хоста)
		путь = строки.срез(остаток, конец_хоста, длина(остаток))
	конец

	если длина(хост_и_порт) == 0 тогда
		возврат Результат.Неудача(Ошибка("http", "пустой хост в адресе: " + текст))
	конец

	пер разделитель_порта = найти(хост_и_порт, ":", 0)
	пер хост = хост_и_порт
	пер порт = 80
	если разделитель_порта <> -1 тогда
		хост = строки.срез(хост_и_порт, 0, разделитель_порта)
		пер порт_текст = строки.срез(хост_и_порт, разделитель_порта + 1, длина(хост_и_порт))
		пер порт_результат = строки.в_число(порт_текст)
		если порт_результат.ошибка() тогда
			возврат Результат.Неудача(Ошибка("http", "неверный порт в адресе: " + текст))
		конец
		порт = порт_результат.получить(80)
	конец

	возврат Результат.Успех(Адрес(хост, порт, путь))
конец

// "?a=b&c=d" с percent-encoding ключей/значений (сеть.кодировать_url).
// Пустая Соответствие -> пустая строка (не "?"). Вызывающий сам
// приклеивает результат к пути/URL перед хттп.запросить(...).
экспорт функ построить_query(параметры: Соответствие(Строка, Строка)) -> Строка
	пер записи = параметры.записи()
	если длина(записи) == 0 тогда
		возврат ""
	конец

	пер результат = "?"
	пер индекс: Целое = 0
	пока индекс < длина(записи) цикл
		пер запись = записи.получить(индекс, ("", ""))
		если индекс > 0 тогда
			результат = результат + "&"
		конец
		результат = результат + сеть.кодировать_url(запись.0) + "=" + сеть.кодировать_url(запись.1)
		индекс = индекс + 1
	конец
	возврат результат
конец

функ пары_в_соответствие(пары: Массив((Строка, Строка))) -> Соответствие(Строка, Строка)
	пер результат: Соответствие(Строка, Строка) = соответствие()
	пер i: Целое = 0
	пока i < пары.длина() цикл
		пер пара = пары[i]
		результат[пара.0] = пара.1
		i = i + 1
	конец
	результат
конец

// сеть.http_запрос возвращает статус как Целое — Ответ.статус остаётся
// Число ради обратной совместимости (старый парсер тоже возвращал
// Число), коэрсии между ними нет, поэтому конвертируем через строку.
функ статус_в_число(статус_целое: Целое) -> Число
	строки.в_число(строки.из_целого(статус_целое)).получить(0)
конец

функ выполнить(метод: Строка, ссылка: Строка, тело: Строка, доп_заголовки: Соответствие(Строка, Строка)) -> Результат(Ответ, Ошибка)
	выбор сеть.http_запрос(метод, ссылка, тело, доп_заголовки)
		Результат.Успех(данные) -> собрать_ответ(данные.0, данные.1, данные.2)
		Результат.Неудача(ош) -> Результат.Неудача(ош)
	конец
конец

функ собрать_ответ(статус_целое: Целое, пары: Массив((Строка, Строка)), тело: Строка) -> Результат(Ответ, Ошибка)
	Результат.Успех(Ответ(статус_в_число(статус_целое), пары_в_соответствие(пары), тело))
конец

экспорт функ запросить(ссылка: Строка) -> Результат(Ответ, Ошибка)
	выполнить("GET", ссылка, "", соответствие())
конец

экспорт функ получить_с_заголовками(ссылка: Строка, заголовки: Соответствие(Строка, Строка)) -> Результат(Ответ, Ошибка)
	выполнить("GET", ссылка, "", заголовки)
конец

экспорт функ запросить_head(ссылка: Строка) -> Результат(Ответ, Ошибка)
	выполнить("HEAD", ссылка, "", соответствие())
конец

экспорт функ отправить_пост(ссылка: Строка, тело: Строка) -> Результат(Ответ, Ошибка)
	выполнить("POST", ссылка, тело, соответствие())
конец

экспорт функ отправить_пост_с_заголовками(ссылка: Строка, тело: Строка, заголовки: Соответствие(Строка, Строка)) -> Результат(Ответ, Ошибка)
	выполнить("POST", ссылка, тело, заголовки)
конец

экспорт функ отправить_put(ссылка: Строка, тело: Строка) -> Результат(Ответ, Ошибка)
	выполнить("PUT", ссылка, тело, соответствие())
конец

экспорт функ отправить_put_с_заголовками(ссылка: Строка, тело: Строка, заголовки: Соответствие(Строка, Строка)) -> Результат(Ответ, Ошибка)
	выполнить("PUT", ссылка, тело, заголовки)
конец

экспорт функ отправить_patch(ссылка: Строка, тело: Строка) -> Результат(Ответ, Ошибка)
	выполнить("PATCH", ссылка, тело, соответствие())
конец

экспорт функ отправить_patch_с_заголовками(ссылка: Строка, тело: Строка, заголовки: Соответствие(Строка, Строка)) -> Результат(Ответ, Ошибка)
	выполнить("PATCH", ссылка, тело, заголовки)
конец

экспорт функ удалить(ссылка: Строка) -> Результат(Ответ, Ошибка)
	выполнить("DELETE", ссылка, "", соответствие())
конец

экспорт функ удалить_с_заголовками(ссылка: Строка, заголовки: Соответствие(Строка, Строка)) -> Результат(Ответ, Ошибка)
	выполнить("DELETE", ссылка, "", заголовки)
конец

// Content-Type: application/json + json.сериализовать(значение) одним
// вызовом.
экспорт функ отправить_json(ссылка: Строка, значение: json.Значение) -> Результат(Ответ, Ошибка)
	пер заголовки: Соответствие(Строка, Строка) = соответствие()
	заголовки["Content-Type"] = "application/json"
	выполнить("POST", ссылка, json.сериализовать(значение), заголовки)
конец

// Схема+хост ("https://example.com") без пути — Location часто приходит
// относительным ("/путь", RFC 7231 разрешает), нужно приклеить его к
// схеме+хосту ИСХОДНОГО запроса, иначе native-клиент не сможет разобрать
// голый путь как URL.
функ схема_и_хост(url: Строка) -> Строка
	пер конец_схемы = найти(url, "://", 0)
	если конец_схемы == -1 тогда
		возврат url
	конец
	пер после_схемы = конец_схемы + 3
	пер конец_хоста = найти(url, "/", после_схемы)
	если конец_хоста == -1 тогда
		возврат url
	конец
	строки.срез(url, 0, конец_хоста)
конец

функ разрешить_location(база: Строка, location: Строка) -> Строка
	если длина(location) >= 7 и строки.срез(location, 0, 7) == "http://" тогда
		возврат location
	конец
	если длина(location) >= 8 и строки.срез(location, 0, 8) == "https://" тогда
		возврат location
	конец
	схема_и_хост(база) + location
конец

// Следует за 3xx-редиректами (заголовок Location, абсолютным или
// относительным) до макс_переходов раз. Возвращает первый НЕ-редирект
// ответ, либо Ошибку при превышении лимита или отсутствии Location в
// редиректе.
экспорт функ запросить_с_редиректами(ссылка: Строка, макс_переходов: Целое) -> Результат(Ответ, Ошибка)
	пер текущая_ссылка = ссылка
	пер переходов: Целое = 0
	пока переходов < макс_переходов цикл
		пер результат = запросить(текущая_ссылка)
		если результат.ошибка() тогда
			возврат результат
		конец
		пер ответ = результат.ожидать("проверено выше")
		если не ответ.редирект() тогда
			возврат Результат.Успех(ответ)
		конец
		пер расположение = ответ.заголовок("Location")
		если расположение.пусто() тогда
			возврат Результат.Успех(ответ)
		конец
		текущая_ссылка = разрешить_location(текущая_ссылка, расположение.получить(""))
		переходов = переходов + 1
	конец
	Результат.Неудача(Ошибка("http", "превышен лимит редиректов (" + строки.из_целого(макс_переходов) + ")"))
конец

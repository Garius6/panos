// Стадия 40: минимальная one_for_one супервизия поверх монитор-примитива
// (наблюдать/получить_сигнал, Стадия 38) — чистый panos-код, без новых
// VM-примитивов (ROADMAP §Стадия 38: "supervisor — не более чем monitor
// + restart-логика в стд-либе").
//
// Гетерогенность (дети разных типов сообщения T в одном супервизоре, как
// в Erlang) достигается через интерфейс ДочерняяЗадача — каждый
// конкретный тип задачи реализует его САМ, в СВОЁМ файле (реализация
// супервизор.ДочерняяЗадача для СвойТип — cross-module реализация,
// Стадия 40).
//
// Фабрика без замыканий: у panos-лямбд нет захвата внешних локалей
// (лямбда, ссылающаяся на локал внешней функции, — Compiler Error).
// Значит запустить() у каждой конкретной задачи сам содержит буквальный
// запусти конкретный_ребёнок(...) — конфигурация "зашита" в тело метода
// при объявлении, а не передаётся заново при каждом рестарте. Тот же
// принцип, что child spec {Module, Function, Args} в Erlang.
импорт строки

экспорт тип ДочерняяЗадача = интерфейс
    // Запускает (при первом старте) или перезапускает (после краша)
    // ребёнка — внутри тела буквально запусти <функция>(...) + наблюдать
    // (proc). Возвращает proc.номер() — id для сопоставления с сигналами
    // получить_сигнал().
    функ запустить() -> Целое
    // Человекочитаемое имя — для сообщения при исчерпании лимита
    // перезапусков.
    функ имя() -> Строка
конец

// Держит задачи (одного или РАЗНЫХ типов сообщений — гетерогенность через
// интерфейс), перезапускает упавшего ребёнка (краш = Есть(причина) от
// получить_сигнал()) до макс_рестартов_на_ребёнка раз. Штатное завершение
// (Нет) — НЕ рестартует, ребёнок считается завершившим свою работу
// (transient-семантика, единственная поддержанная политика в v1).
// Исчерпание лимита — паника() супервизора (тот же "let it crash"
// принцип, что у остального языка): если сам супервизор под наблюдением
// — это тоже будет замечено вызывающим кодом.
//
// Блокирует вызывающего НАВСЕГДА (пока истина цикл) — предназначена для
// запуск через `запусти супервизор.супервизировать(...)`, не для прямого
// вызова.
экспорт функ супервизировать(задачи: Массив(ДочерняяЗадача), макс_рестартов_на_ребёнка: Целое) -> Пусто
    пер id_ов: Массив(Целое) = массив()
    пер счётчики: Массив(Целое) = массив()
    пер индекс: Целое = 0
    пока индекс < задачи.длина() цикл
        id_ов.добавить(задачи[индекс].запустить())
        счётчики.добавить(0)
        индекс = индекс + 1
    конец

    пока истина цикл
        пер (упавший_id, причина) = получить_сигнал()
        выбор причина
            Нет -> 0
            Есть(текст) -> обработать_краш(задачи, id_ов, счётчики, упавший_id, текст, макс_рестартов_на_ребёнка)
        конец
    конец
конец

// id_ов/счётчики — параллельные массивы, индекс = позиция в задачи (id
// меняется на каждый рестарт, отслеживать по нему нельзя).
функ индекс_по_id(id_ов: Массив(Целое), искомый: Целое) -> Целое
    пер i: Целое = 0
    пока i < id_ов.длина() цикл
        если id_ов[i] == искомый тогда
            возврат i
        конец
        i = i + 1
    конец
    возврат -1
конец

функ обработать_краш(задачи: Массив(ДочерняяЗадача), id_ов: Массив(Целое), счётчики: Массив(Целое), упавший_id: Целое, причина: Строка, макс_рестартов_на_ребёнка: Целое) -> Целое
    пер найденный = индекс_по_id(id_ов, упавший_id)
    если найденный < 0 тогда
        возврат 0
    конец
    если счётчики[найденный] >= макс_рестартов_на_ребёнка тогда
        паника("супервизор: '" + задачи[найденный].имя() + "' превысил лимит перезапусков (" + строки.из_целого(макс_рестартов_на_ребёнка) + "): " + причина)
    конец
    счётчики[найденный] = счётчики[найденный] + 1
    id_ов[найденный] = задачи[найденный].запустить()
    возврат 0
конец

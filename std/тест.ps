// Минимальный ассерт-фреймворк для тестов НА panos (не путать с
// core/e2e_test.odin — тот тестирует сам компилятор). Провал не роняет
// весь прогон — Отчёт копит пройдено/провалено/сообщения, панику решает
// вызывающий код сам (обычно после напечатать_сводку).
//
// Отчёт передаётся ПО ССЫЛКЕ — структуры в panos reference semantics
// (см. AGENTS.md/docs/src/language/basic-types.md), поэтому `отчёт.поле =
// ...` внутри проверить() виден вызывающему коду без явного возврата и
// переприсваивания новой копии.

импорт ввод_вывод

/// Копит результаты проверок (пройдено/провалено/сообщения провалов).
экспорт тип Отчёт = структура
	пройдено:      Целое
	провалено:     Целое
	провалившиеся: Массив(Строка)
конец

/// Создаёт пустой отчёт (0 пройдено, 0 провалено).
экспорт функ новый_отчёт() -> Отчёт
	Отчёт(0, 0, массив())
конец

/// Записывает результат проверки условия в отчёт (не паникует на провале).
экспорт функ проверить(отчёт: Отчёт, условие: Булево, сообщение: Строка) -> Пусто
	если условие тогда
		отчёт.пройдено = отчёт.пройдено + 1
	иначе
		отчёт.провалено = отчёт.провалено + 1
		отчёт.провалившиеся.добавить(сообщение)
	конец
конец

// Один generic равны[T] вместо функции на каждый тип: `==` уже работает
// структурно и рекурсивно для ЛЮБОГО T (value_equals в vm.odin проходит
// ^Aggregate_Value/^Array_Value/^Map_Value/^Variant_Value с cycle-guard,
// не только примитивы) — писать равны_числа/равны_строки/равны_булево
// отдельно было исторической случайностью, не языковым ограничением.
/// Проверяет равенство а == б.
экспорт функ равны[T](отчёт: Отчёт, а: T, б: T, сообщение: Строка) -> Пусто
	проверить(отчёт, а == б, сообщение)
конец

/// Проверяет неравенство а <> б.
экспорт функ не_равны[T](отчёт: Отчёт, а: T, б: T, сообщение: Строка) -> Пусто
	проверить(отчёт, а <> б, сообщение)
конец

// Записывает результат "код должен был запаниковать" — принимает УЖЕ
// полученную причину сигнала (Опция(Строка) от получить_сигнал()), а не
// сам вызываемый код: `запусти` в v1 требует bare-имя ТОП-LEVEL функции
// (не лямбду/параметр-функцию — см. infer_spawn_expr в type_cheker.odin,
// сознательное ограничение, "иначе не от кого взять process_message_
// types"), так что обёртка "выполнить лямбду в процессе" невозможна как
// стдlib-хелпер — spawn+monitor вызывающий код делает сам, этот хелпер
// берёт на себя только сравнение результата с ожиданием. Типовое
// использование:
//
//   функ падающая_операция() -> Пусто
//       паника("что-то пошло не так")
//   конец
//
//   функ старт() -> Пусто
//       пер отчёт = тест.новый_отчёт()
//       пер процесс = запусти падающая_операция()
//       наблюдать(процесс)
//       пер (_, причина) = получить_сигнал()
//       тест.ожидать_панику(отчёт, причина, "падающая_операция должна паниковать")
//       тест.напечатать_сводку(отчёт)
//   конец
/// Проверяет "код должен был запаниковать" по уже полученной причине сигнала.
экспорт функ ожидать_панику(отчёт: Отчёт, причина: Опция(Строка), сообщение: Строка) -> Пусто
	выбор причина
		Нет -> проверить(отчёт, ложь, сообщение)
		Есть(_) -> проверить(отчёт, истина, сообщение)
	конец
конец

// Печатает "Пройдено: N, Провалено: M" + список сообщений провалившихся
// проверок. Не паникует сама — вызывающий код решает (обычно: `если
// отчёт.провалено > 0 тогда паника("тесты провалены") конец` после вызова,
// чтобы CI увидел ненулевой код выхода, но с уже напечатанной полной
// сводкой, а не только первым провалом).
/// Печатает сводку (пройдено/провалено + список провалившихся сообщений).
экспорт функ напечатать_сводку(отчёт: Отчёт) -> Пусто
	ввод_вывод.печать("Пройдено: \(отчёт.пройдено), Провалено: \(отчёт.провалено)\n")
	пер i: Целое = 0
	пока i < отчёт.провалившиеся.длина() цикл
		ввод_вывод.печать("  ПРОВАЛ: \(отчёт.провалившиеся[i])\n")
		i = i + 1
	конец
конец

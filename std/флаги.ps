импорт строки
импорт ос

// Парсинг CLI-флагов через Соответствие + индексный цикл. Обобщённая
// версия паттерна, вручную написанного в panosiki/pan/start.ps — тот же
// подход (Конфигурация.распарсить_флаги идёт по ос.аргументы() один раз,
// поддержаны формы "-флаг=значение" и "-флаг значение"), но поиск '='
// теперь через строки.найти вместо ручного посимвольного сканирования.

/// Ожидаемый тип значения флага.
экспорт тип ТипФлага = перечисление
	тСтрока
	тЧисло
	тБулево
конец

/// Объявление одного CLI-флага (имя + тип).
экспорт тип Флаг = структура
	наименование: Строка
	тип_: ТипФлага
конец

/// Разобранное значение флага.
экспорт тип ЗначениеФлага = перечисление
	фСтрока(Строка)
	фЧисло(Число)
	фБулево(Булево)
конец

реализация ЗначениеФлага
	функ вСтроку(это: ЗначениеФлага) -> Строка
		выбор это
			фСтрока(с) -> "Строка(" + с + ")"
			фЧисло(ч) -> "Число(" + строки.из_числа(ч) + ")"
			фБулево(б) ->
				если б тогда
					"Булево(истина)"
				иначе
					"Булево(ложь)"
				конец
		конец
	конец
конец

/// Набор объявленных флагов и распарсенных значений.
экспорт тип Конфигурация = структура
	флаги: Соответствие(Строка, Флаг)
конец

/// Создаёт пустую конфигурацию без объявленных флагов.
экспорт функ новая_конфигурация() -> Конфигурация
	Конфигурация(соответствие())
конец

реализация Конфигурация
	функ добавить_флаг(это: Конфигурация, флаг: Флаг) -> Пусто
		это.флаги[флаг.наименование] = флаг
	конец

	// -флаг=значение и -флаг значение (для тБулево значение не читается —
	// присутствие флага само по себе значит "истина"). Необъявленный флаг
	// или пропущенное значение у нужного флага — паника (тот же выбор,
	// что у std/кодирование/toml.ps и std/кодирование/json.ps — ошибки
	// парсинга входа как критичный сбой, не Результат).
	функ распарсить_флаги(это: Конфигурация, аргументы: Массив(Строка)) -> Соответствие(Строка, ЗначениеФлага)
		пер результат: Соответствие(Строка, ЗначениеФлага) = соответствие()

		для сч = 0 по длина(аргументы) - 1 цикл
			пер аргумент = аргументы[сч]

			если длина(аргумент) == 0 или аргумент[0] <> "-" тогда
				продолжить
			конец

			пер без_дефиса = строки.срез(аргумент, 1, длина(аргумент))
			пер позиция_равно = строки.найти(без_дефиса, "=", 0)

			пер имя_флага = без_дефиса
			если позиция_равно <> -1 тогда
				имя_флага = строки.срез(без_дефиса, 0, позиция_равно)
			конец

			если не это.флаги.есть(имя_флага) тогда
				паника("Необъявленный флаг: " + имя_флага)
			конец

			пер флаг = это.флаги[имя_флага]

			если флаг.тип_ == ТипФлага.тБулево тогда
				результат[имя_флага] = ЗначениеФлага.фБулево(истина)
			иначе
				пер значение = если позиция_равно <> -1 тогда
					строки.срез(без_дефиса, позиция_равно + 1, длина(без_дефиса))
				иначе
					если сч == длина(аргументы) - 1 тогда
						паника("Флагу '" + имя_флага + "' нужно значение")
					конец
					сч = сч + 1
					аргументы[сч]
				конец
				если флаг.тип_ == ТипФлага.тЧисло тогда
					результат[имя_флага] = ЗначениеФлага.фЧисло(строки.в_число(значение).значение())
				иначе
					результат[имя_флага] = ЗначениеФлага.фСтрока(значение)
				конец
			конец
		конец

		результат
	конец

	// Читает ос.аргументы() напрямую — удобство для типичного случая
	// "распарсить аргументы процесса", без ручного вызова ос.аргументы()
	// в каждой программе.
	функ распарсить(это: Конфигурация) -> Соответствие(Строка, ЗначениеФлага)
		это.распарсить_флаги(ос.аргументы())
	конец
конец

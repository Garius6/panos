// 1. ИНТЕРФЕЙСЫ
// Объявление контракта поведения
тип Атакующий = интерфейс
    функ атаковать(урон: Число) -> Пусто
конец

// 2. СТРУКТУРЫ И СТРОГИЕ ТИПЫ
// Объявление структуры со вложенными дженериками и туплами
тип Игрок = структура
    имя: Строка;
    здоровье: Число;
    координаты: (Число, Число); // Тупл
конец

// 3. РЕАЛИЗАЦИЯ ИНТЕРФЕЙСОВ
// Явная реализация интерфейса для структуры (Rust-style)
реализация Атакующий для Игрок
    функ атаковать(это: Игрок, урон: Число) -> Пусто
        это.здоровье = это.здоровье - урон
    конец
конец

// 4. МЕТОДЫ СТРУКТУР
// Обычные методы (первый аргумент обязательно 'это')
реализация Игрок
    функ лечить(это: Игрок, хил: Число) -> Пусто
        это.здоровье = это.здоровье + хил
    конец
конец

// 5. ГЛАВНАЯ ФУНКЦИЯ
функ старт() -> Строка
    // Базовые типы и математика (с приоритетом операций)
    пер жив: Булево = истина
    пер базовый_урон = -5 + 10 * 2 / 4

    // Инициализация Тупла
    пер позиция = (10, 25)

    // Создание структуры (вызов конструктора)
    пер герой = Игрок("Гайдар", 100, позиция)

    // --- РАБОТА С ДАННЫМИ ---

    // Доступ и изменение элементов массива/словаря по индексу

    // Доступ к полям тупла (через точку и число)
    пер икс = герой.координаты.0
    пер игрек = позиция.1

    // --- ВЫЗОВЫ МЕТОДОВ И ПОЛИМОРФИЗМ ---

    // Прямой вызов метода структуры
    герой.лечить(20)

    // Динамическая диспетчеризация (Fat Pointer)
    // Упаковка структуры в интерфейс
    пер враг: Атакующий = герой
    // Вызов метода через интерфейс (VM сама найдет нужную функцию)
    враг.атаковать(35)

    // --- ЛЯМБДЫ (Замыкания/Анонимные функции) ---
    // Создание анонимной функции и сохранение в переменную
    пер применить_бафф = функ(стат: Число, бонус: Число)
        стат + бонус 
    конец
    // Вызов лямбды
	пер текущая_сила = 11
    пер новая_сила = применить_бафф(текущая_сила, 10)

	// Логические операции
	1 == 1

	пер альфа = "alpha"[0]

    // --- УПРАВЛЕНИЕ ПОТОКОМ (EOP) ---
    
    // Цикл While (пока ... цикл ... конец)
    пер счетчик = 0
    пока счетчик < 3 цикл
        счетчик = счетчик + 1
    конец

    // If-выражение (if возвращает значение из блока!)
    пер статус = если герой.здоровье > 0 тогда
        "Герой жив и готов к бою!"
    иначе
        "Потрачено..."
    конец

    // Возврат значения из функции
    возврат статус
конец

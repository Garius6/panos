// Демонстрационный файл Panos — показывает ВСЕ поддерживаемые языком
// конструкции.
//
// Запуск нативно:
//   odin run . -debug -vet -strict-style -vet-tabs -warnings-as-errors -- test.ps
//
// Этот же файл — исходник по умолчанию в браузерной песочнице
// (demo/index.html), поэтому здесь нет `импорт` (браузер не поддерживает
// файловый импорт stdlib-модулей, см. core/module_loader_wasm.odin) —
// всё, что нужно, либо встроено в язык, либо доступно из прелюдии
// (Опция/Результат, см. core/prelude.odin) без единого импорта.
//
// Проверки разбиты на отдельные функции по одной на фичу — так и читать
// проще, и у каждой функции свой пул констант (лимит 256 на функцию,
// см. core/compiler.odin make_constant).

// --- СТРУКТУРЫ ---

тип Игрок = структура
    имя: Строка
    здоровье: Число
    координаты: (Число, Число) // поле-тупл
конец

тип Отчет = структура
    статус: Строка
    очки: Число
конец

// --- ИНТЕРФЕЙСЫ ---

тип Атакующий = интерфейс
    функ атаковать(урон: Число) -> Число
конец

тип Печатаемый = интерфейс
    функ вСтроку() -> Строка
конец

// --- РЕАЛИЗАЦИИ И МЕТОДЫ ---

реализация Атакующий для Игрок
    функ атаковать(это: Игрок, урон: Число) -> Число
        это.здоровье - урон
    конец
конец

реализация Игрок
    функ лечить(это: Игрок, значение: Число) -> Число
        это.здоровье + значение
    конец

    функ описание(это: Игрок) -> Строка
        это.имя + " готов"
    конец
конец

// --- GENERICS: generic-структура, generic-методы, generic-функции ---

тип Коробка[T] = структура
    значение: T
конец

реализация Коробка
    // Метод на generic-структуре: T берётся из владельца.
    функ получить(это: Коробка) -> T
        это.значение
    конец

    // Метод может иметь СОБСТВЕННЫЙ type-параметр, отдельный от T
    // владельца (нужен, например, Результату для заменить_ошибку).
    функ обернуть[U](это: Коробка, x: U) -> U
        x
    конец
конец

// Generic-интерфейс: сам интерфейс не generic, но реализуется на
// generic-типе — и работает полиморфно через параметр интерфейсного типа.
реализация Печатаемый для Коробка
    функ вСтроку(это: Коробка) -> Строка
        "коробка"
    конец
конец

функ показать(x: Печатаемый) -> Строка
    x.вСтроку()
конец

тип Пара[A, B] = структура
    ключ: A
    значение: B
конец

// Top-level generic-функция: явный синтаксис функ имя[T].
функ тождество[T](x: T) -> T
    x
конец

// T выводится рекурсивно и из Массив(T) в сигнатуре тоже.
функ первый_элемент[T](xs: Массив(T)) -> T
    xs[0]
конец

// Рекурсивный generic ADT: Дерево ссылается само на себя внутри Узел.
тип Дерево[T] = перечисление
    Лист(T)
    Узел(Дерево(T), T, Дерево(T))
конец

реализация Дерево
    функ корень(это: Дерево) -> T
        выбор это
            Лист(x) -> x
            Узел(_, x, _) -> x
        конец
    конец
конец

// --- ПЕРЕЧИСЛЕНИЯ (ADT) И ВЫБОР ---

тип Фигура = перечисление
    Точка              // вариант без полей
    Круг(Число)        // вариант с одним полем
    Прямоугольник(Число, Число) // вариант с несколькими полями
конец

функ площадь(ф: Фигура) -> Число
    возврат выбор ф
        Точка -> 0
        Круг(р) -> р * р * 314 / 100
        Прямоугольник(ш, в) -> ш * в
    конец
конец

функ описание_фигуры(ф: Фигура) -> Строка
    возврат выбор ф
        Точка -> "точка"
        Круг(_) -> "круг"
        Прямоугольник(_, _) -> "прямоугольник"
    конец
конец

функ разобрать_опцию(о: Опция(Число)) -> Число
    возврат выбор о
        Опция.Есть(х) -> х
        Нет -> -1
    конец
конец

функ разобрать_результат(р: Результат(Число, Ошибка)) -> Число
    возврат выбор р
        Результат.Успех(з) -> з
        Результат.Неудача(_) -> 0
    конец
конец

// --- ФУНКЦИИ, ЯВНЫЙ RETURN, ЛЯМБДЫ ---
// Ошибка(код, сообщение) — встроенный тип (BUILTIN_CTORS, type_cheker.odin),
// не нужно объявлять свой — поля .код/.сообщение доступны сразу.

функ удвоить(значение: Число) -> Число
    возврат значение * 2
конец

функ применить(ф: функ(Число, Число) -> Число, a: Число, b: Число) -> Число
    ф(a, b)
конец

// --- ОПЦИЯ И ОПЕРАТОР ? ---

функ найти_бонус(имя: Строка) -> Опция(Число)
    Опция.Есть(7)
конец

// `?` — ранний выход: если операнд Нет/Неудача, функция сразу
// возвращает его, иначе разворачивает значение.
функ бонус_с_прибавкой(имя: Строка) -> Опция(Число)
    Опция.Есть(найти_бонус(имя)? + 1)
конец

// --- РЕЗУЛЬТАТ И ОПЕРАТОР ? ---

функ прочитать_счет(имя: Строка) -> Результат(Число, Ошибка)
    Результат.Успех(100)
конец

функ итоговый_счет(имя: Строка) -> Результат(Число, Ошибка)
    Результат.Успех(прочитать_счет(имя)? + бонус_с_прибавкой(имя).получить(0))
конец

// --- ПРОВЕРКИ, СГРУППИРОВАННЫЕ ПО ФИЧАМ ---

// Числа, сравнения, булевы значения, логические операторы и/или/не.
функ проверка_базовых_типов() -> Строка
    пер жив: Булево = истина
    пер урон = -5 + 10 * 2 / 4
    пер сравнение = 1 == 1 и 2 <> 3
    пер альтернатива = ложь или истина
    пер отрицание = не ложь
    пер строка = "pan" + "os"
    пер управляющие = "\n" + "\t" + "\r" + "\"" + "\\"
    пер буква = строка[0]

    если жив и сравнение и альтернатива и отрицание и урон < 10 и длина(управляющие) == 5 и буква == "p" тогда
        "базовые типы: ок; "
    иначе
        "базовые типы: СБОЙ; "
    конец
конец

// Туплы и структуры с полем-туплом.
функ проверка_туплов_и_структур() -> Строка
    пер позиция = (10, 25)
    пер x = позиция.0
    пер y = позиция.1
    пер герой = Игрок("Гайдар", 100, позиция)
    пер здоровье_после_лечения = герой.лечить(20)
    пер отчет = Отчет("начало", здоровье_после_лечения)

    если x < y и здоровье_после_лечения == 120 и отчет.очки == 120 тогда
        "туплы и структуры: ок; "
    иначе
        "туплы и структуры: СБОЙ; "
    конец
конец

// Интерфейс + динамическая диспетчеризация через интерфейсный тип.
функ проверка_интерфейсов() -> Строка
    пер герой = Игрок("Тень", 50, (0, 0))
    пер атакующий: Атакующий = герой
    пер здоровье_после_атаки = атакующий.атаковать(15)

    если здоровье_после_атаки == 35 тогда
        "интерфейсы: ок; "
    иначе
        "интерфейсы: СБОЙ; "
    конец
конец

// Generic-структуры, generic-методы, generic-функции, generic-интерфейс,
// рекурсивный generic ADT.
функ проверка_generics() -> Строка
    пер коробка = Коробка(42)
    пер значение_из_коробки = коробка.получить()
    пер обёрнутое = коробка.обернуть("текст")
    пер показано = показать(Коробка(5))

    пер пара = Пара(1, "текст")
    пер пара_с_типом: Пара(Число, Строка) = Пара(2, "ещё")

    пер тожд = тождество(9)
    пер первый = первый_элемент(массив(7, 8, 9))

    пер дерево = Дерево.Узел(Дерево.Лист(1), 7, Дерево.Лист(3))
    пер корень_дерева = дерево.корень()

    если значение_из_коробки == 42 и обёрнутое == "текст" и показано == "коробка" и пара.ключ == 1 и пара_с_типом.ключ == 2 и тожд == 9 и первый == 7 и корень_дерева == 7 тогда
        "generics: ок; "
    иначе
        "generics: СБОЙ; "
    конец
конец

// Пользовательский ADT (Фигура), выбор с вариантами без/с полями,
// wildcard-паттерны, разбор Опции/Результата через выбор.
функ проверка_enum_и_выбора() -> Строка
    пер круг: Фигура = Фигура.Круг(10)
    пер площадь_круга = площадь(круг)
    пер площадь_прямоугольника = площадь(Фигура.Прямоугольник(3, 4))
    пер имя_фигуры = описание_фигуры(Фигура.Прямоугольник(3, 4))
    пер разобранный_бонус = разобрать_опцию(Опция.Есть(8))
    пер разобранный_счет = разобрать_результат(Результат.Успех(15))

    если площадь_круга > 0 и площадь_прямоугольника == 12 и имя_фигуры == "прямоугольник" и разобранный_бонус == 8 и разобранный_счет == 15 тогда
        "перечисления и выбор: ок; "
    иначе
        "перечисления и выбор: СБОЙ; "
    конец
конец

// Явный return и лямбды/функции первого класса.
функ проверка_функций() -> Строка
    пер удвоенное = удвоить(21)
    пер сумма_с_бонусом = применить(функ(a, b)
        a + b
    конец, 10, 3)

    если удвоенное == 42 и сумма_с_бонусом == 13 тогда
        "функции и лямбды: ок; "
    иначе
        "функции и лямбды: СБОЙ; "
    конец
конец

// Опция: полный набор методов + оператор ?.
функ проверка_опции() -> Строка
    пер бонус = бонус_с_прибавкой("игрок")
    пер значение = бонус.значение()
    пер бонус_числом = бонус.получить(0)
    пер запасная = бонус.запас(Опция.Есть(1))
    пер заменённая = запасная.заменить_значение("бонус есть")
    пер текст = заменённая.ожидать("опция должна быть заполнена")
    пер как_результат = бонус.результат_или(Ошибка("бонус", "нет бонуса"))
    пер пустая: Опция(Число) = Опция.Нет()

    если бонус.есть() и значение == 8 и бонус_числом == 8 и запасная.есть() и текст == "бонус есть" и как_результат.успех() и пустая.пусто() тогда
        "Опция: ок; "
    иначе
        "Опция: СБОЙ; "
    конец
конец

// Результат: полный набор методов + оператор ?.
функ проверка_результата() -> Строка
    пер счет = итоговый_счет("игрок")
    пер счет_числом = счет.ожидать("счет должен быть доступен")
    пер нулевой_счет: Результат(Число, Ошибка) = Результат.Успех(0)
    пер запасной = счет.запас(нулевой_счет)
    пер строкой = запасной.заменить_значение("счет готов")
    пер с_другой_ошибкой = строкой.заменить_ошибку(Ошибка("итог", "нет итога"))
    пер текст = с_другой_ошибкой.получить("нет")
    пер опция_счета = счет.опция()
    пер опция_ошибки = счет.ошибка_опция()
    пер ошибка_по_умолчанию = счет.получить_ошибку(Ошибка("нет", "ошибки нет")).сообщение
    пер неудача: Результат(Число, Ошибка) = Результат.Неудача(Ошибка("пример", "ожидаемая ошибка"))
    пер причина = неудача.причина().сообщение
    пер причина_из_ожидания = неудача.ожидать_ошибку("должна быть ошибка").сообщение

    если счет.успех() и счет_числом > 0 и строкой.получить("нет") == "счет готов" и текст == "счет готов" и опция_счета.есть() и опция_ошибки.пусто() и ошибка_по_умолчанию == "ошибки нет" и причина == "ожидаемая ошибка" и причина_из_ожидания == "ожидаемая ошибка" тогда
        "Результат: ок; "
    иначе
        "Результат: СБОЙ; "
    конец
конец

// Массивы и соответствия (карты): литералы, индексирование, методы.
функ проверка_массивов_и_карт() -> Строка
    пер числа = массив(1, 2, 3)
    числа.добавить(4)
    числа[0] = числа[0] + 9
    пер массив_ок = числа.есть(3)
    пер сумма_массива = числа[0] + числа.получить(2, 0) + числа.длина()
    пер содержит_четыре = числа.содержит(4)

    пер цены = соответствие(
        "яблоко" = 10,
        "груша" = 20,
    )
    цены["банан"] = 5
    пер есть_банан = цены.есть("банан")
    пер цена_банана = цены.получить("банан", 0)
    цены.удалить("груша")
    пер размер_цен = цены.длина()

    если массив_ок и сумма_массива > 0 и содержит_четыре и есть_банан и цена_банана == 5 и размер_цен == 2 тогда
        "массивы и карты: ок; "
    иначе
        "массивы и карты: СБОЙ; "
    конец
конец

// Циклы: пока, для-in (по массиву и по элементам карты через .записи()),
// числовой диапазон для X = A по B, продолжить/прервать.
функ проверка_циклов() -> Строка
    пер счетчик = 0
    пока счетчик < 3 цикл
        счетчик = счетчик + 1
    конец

    пер числа = массив(1, 2, 3, 4)
    пер сумма_for_in = 0
    для x в числа цикл
        сумма_for_in = сумма_for_in + x
    конец

    пер карта: Соответствие(Строка, Число) = соответствие(
        "a" = 1,
        "b" = 2,
        "c" = 3,
    )
    пер сумма_записей = 0
    для (ключ, значение) в карта.записи() цикл
        сумма_записей = сумма_записей + значение
    конец

    пер сумма_диапазона = 0
    для i = 1 по 5 цикл
        сумма_диапазона = сумма_диапазона + i
    конец

    пер поток = 0
    пока поток < 10 цикл
        поток = поток + 1
        если поток == 2 тогда
            продолжить
        конец
        если поток > 5 тогда
            прервать
        конец
    конец

    если счетчик == 3 и сумма_for_in == 10 и сумма_записей == 6 и сумма_диапазона == 15 и поток == 6 тогда
        "циклы: ок; "
    иначе
        "циклы: СБОЙ; "
    конец
конец

// If как выражение и паника() в недостижимой ветке (тип Никогда).
функ проверка_if_и_паники() -> Строка
    пер жив: Булево = истина
    пер безопасное_число = если жив тогда
        42
    иначе
        паника("эта ветка не должна выполниться")
    конец

    если безопасное_число == 42 тогда
        "if-выражение и паника: ок; "
    иначе
        "if-выражение и паника: СБОЙ; "
    конец
конец

// --- ГЛАВНАЯ ФУНКЦИЯ ---

экспорт функ старт() -> Строка
    пер итог = ""
    итог = итог + проверка_базовых_типов()
    итог = итог + проверка_туплов_и_структур()
    итог = итог + проверка_интерфейсов()
    итог = итог + проверка_generics()
    итог = итог + проверка_enum_и_выбора()
    итог = итог + проверка_функций()
    итог = итог + проверка_опции()
    итог = итог + проверка_результата()
    итог = итог + проверка_массивов_и_карт()
    итог = итог + проверка_циклов()
    итог = итог + проверка_if_и_паники()
    итог
конец

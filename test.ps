// Демонстрационный файл Panos.
// Его можно запускать командой:
// odin run . -debug -vet -strict-style -vet-tabs -warnings-as-errors -- test.ps

импорт математика

// --- СТРУКТУРЫ ---

тип Игрок = структура
    имя: Строка
    здоровье: Число
    координаты: (Число, Число)
конец

тип Отчет = структура
    статус: Строка
    очки: Число
конец

// --- ИНТЕРФЕЙСЫ ---

тип Атакующий = интерфейс
    функ атаковать(урон: Число) -> Число
конец

// --- РЕАЛИЗАЦИИ И МЕТОДЫ ---

реализация Атакующий для Игрок
    функ атаковать(это: Игрок, урон: Число) -> Число
        это.здоровье - урон
    конец
конец

реализация Игрок
    функ лечить(это: Игрок, значение: Число) -> Число
        это.здоровье + значение
    конец

    функ описание(это: Игрок) -> Строка
        это.имя + " готов"
    конец
конец

// --- ПЕРЕЧИСЛЕНИЯ (ADT) И ВЫБОР ---

тип Фигура = перечисление
    Точка
    Круг(Число)
    Прямоугольник(Число, Число)
конец

функ площадь(ф: Фигура) -> Число
    возврат выбор ф
        Точка -> 0
        Круг(р) -> р * р * 314 / 100
        Прямоугольник(ш, в) -> ш * в
    конец
конец

функ описание_фигуры(ф: Фигура) -> Строка
    возврат выбор ф
        Точка -> "точка"
        Круг(_) -> "круг"
        Прямоугольник(_, _) -> "прямоугольник"
    конец
конец

функ разобрать_опцию(о: Опция(Число)) -> Число
    возврат выбор о
        Есть(х) -> х
        Нет -> -1
    конец
конец

функ разобрать_результат(р: Результат(Число, Ошибка)) -> Число
    возврат выбор р
        Успех(з) -> з
        Неудача(_) -> 0
    конец
конец

// --- ФУНКЦИИ И ЯВНЫЙ RETURN ---

функ удвоить(значение: Число) -> Число
    возврат значение * 2
конец

функ применить(ф: функ(Число, Число) -> Число, a: Число, b: Число) -> Число
    ф(a, b)
конец

// --- ОПЦИЯ И ОПЕРАТОР ? ---

функ найти_бонус(имя: Строка) -> Опция(Число)
    Есть(7)
конец

функ бонус_с_прибавкой(имя: Строка) -> Опция(Число)
    Есть(найти_бонус(имя)? + 1)
конец

// --- РЕЗУЛЬТАТ И ОПЕРАТОР ? ---

функ прочитать_счет(имя: Строка) -> Результат(Число, Ошибка)
    Успех(100)
конец

функ итоговый_счет(имя: Строка) -> Результат(Число, Ошибка)
    Успех(прочитать_счет(имя)? + бонус_с_прибавкой(имя).получить(0))
конец

// --- ГЛАВНАЯ ФУНКЦИЯ ---

функ старт() -> Строка
    // Базовые типы, арифметика, сравнения и строки.
    пер жив: Булево = истина
    пер базовый_урон = -5 + 10 * 2 / 4
    пер имя = "Гайдар"
    пер первая_буква = имя[0]
    пер строка = "pan" + "os"
    пер управляющие = "\n" + "\t" + "\r" + "\"" + "\\"
    пер проверка = 1 == 1

    // Туплы и доступ к элементам тупла.
    пер позиция = (10, 25)
    пер x = позиция.0
    пер y = позиция.1

    // Структуры, поля и методы.
    пер герой = Игрок(имя, 100, позиция)
    пер здоровье_после_лечения = герой.лечить(20)
    пер описание = герой.описание()
    пер отчет = Отчет("начало", здоровье_после_лечения)

    // Интерфейс и динамический вызов метода.
    пер атакующий: Атакующий = герой
    пер здоровье_после_атаки = атакующий.атаковать(15)

    // Лямбда с выводом типов из ожидаемого типа функции.
    пер сумма_с_бонусом = применить(функ(a, b)
        a + b
    конец, здоровье_после_атаки, 3)

    // Массивы: литерал, добавление, индексирование, безопасное чтение.
    пер числа = массив(1, 2, 3)
    числа.добавить(4)
    числа[0] = математика.прибавить(числа[0], 9)
    пер массив_ок = числа.есть(3)
    пер сумма_массива = числа[0] + числа.получить(2, 0) + числа.длина()
    пер содержит_четыре = числа.содержит(4)

    // Соответствия: литерал, запись по ключу, проверки и безопасное чтение.
    пер цены = соответствие(
        "яблоко" = 10,
        "груша" = 20,
    )
    цены["банан"] = 5
    пер есть_банан = цены.есть("банан")
    пер цена_банана = цены.получить("банан", 0)
    цены.удалить("груша")
    пер размер_цен = цены.длина()

    // Опция: проверки, fallback, замена значения, конвертация в Результат.
    пер бонус = бонус_с_прибавкой(имя)
    пер бонус_числом = бонус.получить(0)
    пер запасная_опция = бонус.запас(Есть(1))
    пер замененная_опция = запасная_опция.заменить_значение("бонус есть")
    пер текст_опции = замененная_опция.ожидать("опция должна быть заполнена")
    пер результат_из_опции = бонус.результат_или(Ошибка("бонус", "нет бонуса"))

    // Результат: проверки, fallback, замена значения/ошибки, конвертация.
    пер счет = итоговый_счет(имя)
    пер счет_числом = счет.ожидать("счет должен быть доступен")
    пер нулевой_счет: Результат(Число, Ошибка) = Успех(0)
    пер запасной_результат = счет.запас(нулевой_счет)
    пер результат_строкой = запасной_результат.заменить_значение("счет готов")
    пер результат_с_другой_ошибкой = результат_строкой.заменить_ошибку(Ошибка("итог", "нет итога"))
    пер текст_результата = результат_с_другой_ошибкой.получить("нет")
    пер опция_счета = счет.опция()
    пер опция_ошибки = счет.ошибка_опция()
    пер ошибка_по_умолчанию = счет.получить_ошибку(Ошибка("нет", "ошибки нет")).сообщение
    пер ожидаемая_неудача: Результат(Число, Ошибка) = Неудача(Ошибка("пример", "ожидаемая ошибка"))
    пер причина_из_неудачи = ожидаемая_неудача.ожидать_ошибку("должна быть ошибка").сообщение

    // If-выражение, ветка с panic и тип Никогда.
    пер безопасное_число = если жив тогда
        42
    иначе
        паника("эта ветка не должна выполниться")
    конец

    // Цикл while и присваивание.
    пер счетчик = 0
    пока счетчик < 3 цикл
        счетчик = счетчик + 1
    конец

    // ADT и выбор: пользовательские варианты и разбор Опции/Результата.
    пер круг: Фигура = Круг(10)
    пер площадь_круга = площадь(круг)
    пер имя_фигуры = описание_фигуры(Прямоугольник(3, 4))
    пер площадь_прямоугольника = площадь(Прямоугольник(3, 4))
    пер разобранный_бонус = разобрать_опцию(бонус)
    пер разобранный_счет = разобрать_результат(счет)

    // Управление циклом: продолжить и прервать.
    пер шаг = 0
    пер поток = 0
    пока шаг < 5 цикл
        шаг = шаг + 1
        если шаг == 2 тогда
            продолжить
        конец
        если шаг > 4 тогда
            прервать
        конец
        поток = поток + шаг
    конец

    // Итоговое выражение использует значения из разных частей примера,
    // чтобы type checker и VM прошли все конструкции.
    если проверка тогда
        описание + ": " +
        строка + ", " +
        первая_буква + ", " +
        отчет.статус + ", " +
        текст_опции + ", " +
        текст_результата + ", " +
        ошибка_по_умолчанию + ", " +
        причина_из_неудачи + ", " +
        если жив тогда "жив" иначе "не жив" конец + ", " +
        если массив_ок тогда "массив ок" иначе "массив пуст" конец + ", " +
        если содержит_четыре тогда "есть 4" иначе "нет 4" конец + ", " +
        если есть_банан тогда "есть банан" иначе "нет банана" конец + ", " +
        если счет_числом > 0 тогда "счет положительный" иначе "счет ноль" конец + ", " +
        если сумма_с_бонусом > 0 тогда "сумма положительная" иначе "сумма ноль" конец + ", " +
        если сумма_массива > 0 тогда "массив посчитан" иначе "массив пуст" конец + ", " +
        если цена_банана > 0 тогда "цена есть" иначе "цены нет" конец + ", " +
        если x < y тогда "позиция ок" иначе "позиция обратная" конец + ", " +
        если счетчик == 3 тогда "цикл ок" иначе "цикл сбой" конец + ", " +
        если безопасное_число == 42 тогда "panic не вызван" иначе "неожиданно" конец + ", " +
        если опция_счета.есть() тогда "опция счета есть" иначе "опции счета нет" конец + ", " +
        если опция_ошибки.пусто() тогда "ошибки нет" иначе "ошибка есть" конец + ", " +
        если результат_из_опции.успех() тогда "результат из опции есть" иначе "результата нет" конец + ", " +
        если базовый_урон < 10 тогда "урон малый" иначе "урон большой" конец + ", " +
        если длина(управляющие) == 5 тогда "escape ok" иначе "escape сбой" конец + ", " +
        если поток == 8 тогда "управление циклом ok" иначе "управление циклом сбой" конец + ", " +
        если размер_цен == 2 тогда "соответствие ок" иначе "соответствие другое" конец + ", " +
        если площадь_круга > 0 тогда "круг посчитан" иначе "круг пуст" конец + ", " +
        имя_фигуры + ", " +
        если площадь_прямоугольника == 12 тогда "прямоугольник ок" иначе "прямоугольник сбой" конец + ", " +
        если разобранный_бонус == 8 тогда "бонус разобран" иначе "бонус сбой" конец + ", " +
        если разобранный_счет > 0 тогда "счет разобран" иначе "счет сбой" конец
    иначе
        "невозможно"
    конец
конец

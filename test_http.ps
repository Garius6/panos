импорт "сеть/http" как хттп
импорт строки
импорт ввод_вывод как ио

функ старт() -> Пусто
	пер ответ = хттп.запросить("http://127.0.0.1:8973/index.txt")
	если ответ.ошибка() тогда
		ио.строка("ошибка: " + ответ.причина().сообщение)
		возврат
	конец

	пер р = ответ.ожидать("запрос должен быть успешным")
	ио.строка("статус: " + строки.из_числа(р.статус))
	ио.строка("тело: " + р.тело)
	ио.строка("успех: " + если р.успех() тогда "да" иначе "нет" конец)

	пер тип_содержимого = р.заголовок("Content-type")
	если тип_содержимого.есть() тогда
		ио.строка("content-type: " + тип_содержимого.значение())
	иначе
		ио.строка("content-type: нет заголовка")
	конец

	пер параметры: Соответствие(Строка, Строка) = соответствие(
		"поиск" = "привет мир",
		"стр" = "1",
	)
	ио.строка("query: " + хттп.построить_query(параметры))
конец

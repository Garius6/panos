импорт супервизор

тип Задача = перечисление
    Выполнить
конец

функ падающий_рабочий() -> Пусто
    выбор получить()
        Задача.Выполнить -> паника("рабочий сломался")
    конец
конец

функ старт_рабочего() -> Целое
    пер proc: Процесс(Задача) = запусти падающий_рабочий()
    наблюдать(proc)
    отправить(proc, Задача.Выполнить)
    proc.номер()
конец

тип ПадающаяЗадача = структура
конец

реализация супервизор.ДочерняяЗадача для ПадающаяЗадача
    функ запустить(это: ПадающаяЗадача) -> Целое
        старт_рабочего()
    конец
    функ имя(это: ПадающаяЗадача) -> Строка
        "падающий-рабочий"
    конец
конец

// Демонстрирует one_for_one супервизию: рабочий падает, супервизор
// перезапускает его до макс_рестартов_на_ребёнка раз, затем сам
// паникует понятным сообщением ("let it crash" — если этот супервизор
// был бы под наблюдением, крах был бы замечен вызывающим кодом).
функ старт() -> Пусто
    пер задачи: Массив(супервизор.ДочерняяЗадача) = массив(ПадающаяЗадача())
    супервизор.супервизировать(задачи, 2)
конец

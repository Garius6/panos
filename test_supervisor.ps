импорт супервизор
импорт ввод_вывод

тип Задача = перечисление
    Выполнить
конец

функ падающий_рабочий() -> Пусто
    выбор получить()
        Задача.Выполнить -> паника("рабочий сломался")
    конец
конец

функ старт_рабочего() -> Процесс(Задача)
    запусти падающий_рабочий()
конец

// Стадия 45: наблюдать(proc) больше не вызывается тут напрямую —
// наблюдать() регистрирует ТЕКУЩИЙ процесс наблюдателем, значит
// наблюдателем должен быть relay (см. ретранслятор_рабочего ниже),
// иначе крах пришёл бы не в mailbox супервизора (получить()), а в его
// сигналы, которые супервизировать() после Стадии 45 больше не слушает
// напрямую.
функ ретранслятор_рабочего(proc: Процесс(Задача), супервизор_h: Процесс(супервизор.СобытиеСупервизора)) -> Пусто
    наблюдать(proc)
    пер (id, причина) = получить_сигнал()
    отправить(супервизор_h, супервизор.СобытиеСупервизора.Сигнал(id, причина))
конец

тип ПадающаяЗадача = структура
    последний: Опция(Процесс(Задача))
конец

реализация супервизор.ДочерняяЗадача для ПадающаяЗадача
    функ запустить(это: ПадающаяЗадача, супервизор_h: Процесс(супервизор.СобытиеСупервизора)) -> Целое
        пер proc = старт_рабочего()
        запусти ретранслятор_рабочего(proc, супервизор_h)
        отправить(proc, Задача.Выполнить)
        это.последний = Опция.Есть(proc)
        proc.номер()
    конец
    функ имя(это: ПадающаяЗадача) -> Строка
        "падающий-рабочий"
    конец
    функ остановить(это: ПадающаяЗадача) -> Пусто
        если это.последний.есть() тогда
            убить(это.последний.значение())
        конец
    конец
конец

// Демонстрирует one_for_one супервизию + Стадия 45 (динамическое
// добавление ребёнка): супервизор спавнится НАПРЯМУЮ через `запусти
// супервизор.супервизировать(...)` (qualified-форма запусти) — вызывающий
// получает типобезопасный Процесс(СобытиеСупервизора) и шлёт ему
// ДобавитьЗадачу(...) во время работы. Второй рабочий падает, супервизор
// его перезапускает до макс_рестартов раз, затем сам паникует понятным
// сообщением ("let it crash") — старт() сам наблюдает за супервизором и
// видит эту панику через получить_сигнал().
функ старт() -> Пусто
    пер задачи: Массив(супервизор.ДочерняяЗадача) = массив(ПадающаяЗадача(Опция.Нет()))
    пер супервизор_h = запусти супервизор.супервизировать(задачи, супервизор.Стратегия.ОдинЗаОдного, 2, 60000.0)
    наблюдать(супервизор_h)

    отправить(супервизор_h, супервизор.СобытиеСупервизора.ДобавитьЗадачу(ПадающаяЗадача(Опция.Нет())))

    пер (id, причина) = получить_сигнал()
    выбор причина
        Нет -> ввод_вывод.печать("супервизор завершился штатно (неожиданно)")
        Есть(текст) -> ввод_вывод.печать("супервизор упал как ожидалось: " + текст)
    конец
конец

импорт "кодирование/toml" как томл
импорт ввод_вывод как ио

функ старт() -> Пусто
	пер текст = "имя = \"panos\"\nверсия = 1\n\n[автор]\nник = \"Гайдар\"\nактивен = true\nтеги = [1, 2, 3]\n"

	пер результат = томл.разобрать(текст)
	если результат.ошибка() тогда
		ио.строка("ошибка разбора: " + результат.причина().сообщение)
		возврат
	конец

	пер документ = результат.ожидать("разбор должен быть успешным")

	пер имя = документ.поле("имя")
	если имя.есть() тогда
		ио.строка("имя: " + имя.значение().как_строку().получить("?"))
	конец

	пер автор = документ.поле("автор")
	если автор.есть() тогда
		пер ник = автор.значение().поле("ник")
		если ник.есть() тогда
			ио.строка("ник автора: " + ник.значение().как_строку().получить("?"))
		конец

		пер активен = автор.значение().поле("активен")
		если активен.есть() тогда
			если активен.значение().как_булево().получить(ложь) тогда
				ио.строка("автор активен")
			иначе
				ио.строка("автор неактивен")
			конец
		конец
	конец

	пер теги = документ.поле("автор").значение().поле("теги")
	если теги.есть() тогда
		пер второй_тег = теги.значение().элемент(1)
		если второй_тег.есть() и второй_тег.значение().как_число().получить(0) == 2 тогда
			ио.строка("второй тег: 2 (как и ожидалось)")
		конец
	конец
конец
